<% content_for :title, "Admin — #{@event.name}" %>

<div style="margin-bottom:1.5rem;">
  <%= link_to "← Retour", admin_events_path,
      style: "font-size:0.8rem;color:#888;text-decoration:none;" %>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;">

      <% if @event.banner.attached? %>
        <%= image_tag @event.banner,
            style: "width:100%;height:140px;object-fit:cover;display:block;margin-bottom:1rem;" %>
      <% else %>
        <div style="width:100%;height:140px;background:#111;display:flex;align-items:center;
                    justify-content:center;font-size:3rem;margin-bottom:1rem;">🎪</div>
      <% end %>

      <div style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#fff;margin-bottom:0.25rem;">
        <%= @event.name %>
        <% if @event.featured? %><span style="color:#F5C500;">⭐</span><% end %>
      </div>

      <% [
        ["Date début",  @event.start_date&.strftime("%d/%m/%Y à %Hh%M")],
        ["Date fin",    @event.end_date&.strftime("%d/%m/%Y à %Hh%M")],
        ["Lieu",        @event.location],
        ["Organisateur", @event.tatoueur&.nickname || @event.shop&.name],
        ["Participants", @event.event_participations.count],
        ["Public",      @event.is_public? ? "Oui" : "Non"],
      ].each do |label, val| %>
        <% next unless val.present? %>
        <div style="display:flex;justify-content:space-between;padding:0.5rem 0;
                    border-bottom:1px solid #2A2A2A;">
          <span style="font-size:0.75rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
            <%= label %>
          </span>
          <span style="font-size:0.85rem;color:#bbb;"><%= val %></span>
        </div>
      <% end %>

      <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:0.5rem;">
        <% if @event.featured? %>
          <%= button_to "✕ Retirer la mise en avant",
              unfeature_admin_event_path(@event), method: :patch,
              style: "background:transparent;border:1px solid #555;color:#555;
                      font-family:'Bebas Neue',sans-serif;font-size:0.9rem;
                      padding:0.6rem;cursor:pointer;width:100%;" %>
        <% else %>
          <%= button_to "⭐ Mettre en avant",
              feature_admin_event_path(@event), method: :patch,
              style: "background:transparent;border:1px solid #F5C500;color:#F5C500;
                      font-family:'Bebas Neue',sans-serif;font-size:0.9rem;
                      padding:0.6rem;cursor:pointer;width:100%;" %>
        <% end %>

        <%= link_to "✏️ Modifier", edit_admin_event_path(@event),
            style: "display:block;text-align:center;background:#2A2A2A;color:#fff;
                    font-family:'Bebas Neue',sans-serif;font-size:0.9rem;letter-spacing:0.05em;
                    padding:0.6rem;text-decoration:none;" %>

        <%= button_to "🗑️ Supprimer", admin_event_path(@event), method: :delete,
            data: { turbo_confirm: "Supprimer \"#{@event.name}\" définitivement ?" },
            style: "background:#E74C3C;color:#fff;border:none;font-family:'Bebas Neue',sans-serif;
                    font-size:1rem;padding:0.6rem;cursor:pointer;width:100%;" %>

        <%= link_to "Voir l'événement →", event_path(@event), target: "_blank",
            style: "display:block;text-align:center;color:#888;font-size:0.8rem;
                    text-decoration:none;padding:0.5rem;border:1px solid #2A2A2A;" %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <% if @event.description.present? %>
      <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;margin-bottom:1rem;">
        <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                   border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
          Description
        </h3>
        <p style="color:#888;line-height:1.7;font-size:0.9rem;"><%= @event.description %></p>
      </div>
    <% end %>

    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Participants (<%= @event.event_participations.count %>)
      </h3>
      <% if @event.participants.any? %>
        <% @event.participants.limit(20).each do |user| %>
          <div style="display:flex;justify-content:space-between;padding:0.4rem 0;
                      border-bottom:1px solid #2A2A2A;font-size:0.85rem;">
            <span style="color:#bbb;"><%= user.nickname %></span>
            <span style="color:#555;"><%= user.email %></span>
          </div>
        <% end %>
      <% else %>
        <p style="color:#555;font-size:0.85rem;">Aucun participant.</p>
      <% end %>
    </div>
  </div>
</div>