<% content_for :title, "Admin — #{@shop.name}" %>

<div style="margin-bottom:1.5rem;">
  <%= link_to "← Retour", admin_shops_path,
      style: "font-size:0.8rem;color:#888;text-decoration:none;" %>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;">
      <div style="text-align:center;margin-bottom:1.5rem;">
        <% if @shop.cover.attached? %>
          <%= image_tag @shop.cover,
              style: "width:100%;height:100px;object-fit:cover;border:2px solid #F5C500;
                      display:block;margin-bottom:0.75rem;" %>
        <% end %>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#fff;">
          <%= @shop.name %>
          <% if @shop.featured? %><span style="color:#F5C500;">⭐</span><% end %>
        </div>
        <div style="font-size:0.8rem;color:#888;"><%= @shop.address %></div>
        <% if @shop.banned? %>
          <span style="font-size:0.75rem;color:#E74C3C;text-transform:uppercase;
                       border:1px solid rgba(231,76,60,0.3);padding:0.15rem 0.5rem;
                       display:inline-block;margin-top:0.5rem;">Banni</span>
        <% end %>
      </div>

      <% [
        ["Email",      @shop.email],
        ["Téléphone",  @shop.phone],
        ["Horaires",   @shop.open_hours],
        ["Tatoueurs",  @shop.tatoueurs.count],
        ["Réservations", @shop.bookings.count],
      ].each do |label, val| %>
        <% next unless val.present? %>
        <div style="display:flex;justify-content:space-between;padding:0.5rem 0;
                    border-bottom:1px solid #2A2A2A;">
          <span style="font-size:0.78rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
            <%= label %>
          </span>
          <span style="font-size:0.85rem;color:#bbb;"><%= val %></span>
        </div>
      <% end %>

      <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:0.5rem;">
        <% if @shop.featured? %>
          <%= button_to "✕ Retirer la mise en avant", unfeature_admin_shop_path(@shop), method: :patch,
              style: "background:transparent;border:1px solid #555;color:#555;font-family:'Bebas Neue',sans-serif;
                      font-size:0.9rem;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% else %>
          <%= button_to "⭐ Mettre en avant", feature_admin_shop_path(@shop), method: :patch,
              style: "background:transparent;border:1px solid #F5C500;color:#F5C500;font-family:'Bebas Neue',sans-serif;
                      font-size:0.9rem;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% end %>
        <% if @shop.banned? %>
          <%= button_to "✅ Lever le bannissement", unban_admin_shop_path(@shop), method: :patch,
              style: "background:#27AE60;color:#fff;border:none;font-family:'Bebas Neue',sans-serif;
                      font-size:1rem;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% else %>
          <%= button_to "🚫 Bannir", ban_admin_shop_path(@shop), method: :patch,
              data: { turbo_confirm: "Bannir #{@shop.name} ?" },
              style: "background:#E74C3C;color:#fff;border:none;font-family:'Bebas Neue',sans-serif;
                      font-size:1rem;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% end %>
        <%= link_to "Voir la page publique →", shop_path(@shop), target: "_blank",
            style: "display:block;text-align:center;color:#888;font-size:0.8rem;
                    text-decoration:none;padding:0.5rem;border:1px solid #2A2A2A;" %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;margin-bottom:1rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Tatoueurs du shop
      </h3>
      <% if @shop.tatoueurs.any? %>
        <% @shop.tatoueurs.each do |t| %>
          <div style="display:flex;align-items:center;justify-content:space-between;
                      padding:0.5rem 0;border-bottom:1px solid #2A2A2A;">
            <span style="color:#fff;font-family:'Bebas Neue',sans-serif;"><%= t.nickname %></span>
            <%= link_to "→", admin_tatoueur_path(t),
                style: "color:#F5C500;text-decoration:none;font-size:0.85rem;" %>
          </div>
        <% end %>
      <% else %>
        <p style="color:#555;font-size:0.85rem;">Aucun tatoueur.</p>
      <% end %>
    </div>

    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Signalements (<%= @reports.count %>)
      </h3>
      <% if @reports.any? %>
        <% @reports.each do |r| %>
          <div style="padding:0.5rem 0;border-bottom:1px solid #2A2A2A;font-size:0.85rem;">
            <span style="color:#E74C3C;">⚠️ <%= r.reason.humanize %></span>
            <span style="color:#555;margin-left:0.5rem;">· <%= r.created_at.strftime("%d/%m/%Y") %></span>
          </div>
        <% end %>
      <% else %>
        <p style="color:#555;font-size:0.85rem;">Aucun signalement.</p>
      <% end %>
    </div>
  </div>
</div>