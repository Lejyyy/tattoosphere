<% content_for :title, "Admin — #{@user.nickname}" %>

<div style="margin-bottom:1.5rem;">
  <%= link_to "← Retour", admin_users_path,
      style: "font-size:0.8rem;color:#888;text-decoration:none;" %>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;">
      <div style="text-align:center;margin-bottom:1.5rem;">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar,
              style: "width:80px;height:80px;object-fit:cover;border:3px solid #F5C500;
                      display:block;margin:0 auto 0.75rem;" %>
        <% else %>
          <div style="width:80px;height:80px;background:#2A2A2A;border:3px solid #2A2A2A;
                      display:flex;align-items:center;justify-content:center;
                      font-size:2rem;margin:0 auto 0.75rem;">👤</div>
        <% end %>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#fff;">
          <%= @user.nickname %>
        </div>
        <div style="font-size:0.8rem;color:#888;"><%= @user.email %></div>
        <div style="margin-top:0.5rem;">
          <span style="font-size:0.75rem;color:#F5C500;text-transform:uppercase;
                       letter-spacing:0.05em;border:1px solid rgba(245,197,0,0.3);
                       padding:0.15rem 0.5rem;">
            <%= @user.role %>
          </span>
          <% if @user.banned? %>
            <span style="font-size:0.75rem;color:#E74C3C;text-transform:uppercase;
                         letter-spacing:0.05em;border:1px solid rgba(231,76,60,0.3);
                         padding:0.15rem 0.5rem;margin-left:0.3rem;">
              Banni
            </span>
          <% end %>
        </div>
      </div>

      <%# Infos %>
      <% [
        ["Prénom",     @user.first_name],
        ["Nom",        @user.last_name],
        ["Inscrit le", @user.created_at.strftime("%d/%m/%Y")],
        ["Banni le",   @user.banned_at&.strftime("%d/%m/%Y")],
      ].each do |label, val| %>
        <% next unless val.present? %>
        <div style="display:flex;justify-content:space-between;padding:0.5rem 0;
                    border-bottom:1px solid #2A2A2A;">
          <span style="font-size:0.78rem;color:#555;text-transform:uppercase;
                       letter-spacing:0.05em;"><%= label %></span>
          <span style="font-size:0.85rem;color:#bbb;"><%= val %></span>
        </div>
      <% end %>

      <%# Actions %>
      <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:0.5rem;">
        <% if @user.banned? %>
          <%= button_to "✅ Lever le bannissement", unban_admin_user_path(@user),
              method: :patch,
              style: "background:#27AE60;color:#fff;border:none;font-family:'Bebas Neue',sans-serif;
                      font-size:1rem;letter-spacing:0.08em;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% else %>
          <%= button_to "🚫 Bannir", ban_admin_user_path(@user),
              method: :patch,
              params: { note: "" },
              data: { turbo_confirm: "Bannir #{@user.nickname} ?" },
              style: "background:#E74C3C;color:#fff;border:none;font-family:'Bebas Neue',sans-serif;
                      font-size:1rem;letter-spacing:0.08em;padding:0.6rem;cursor:pointer;width:100%;" %>
        <% end %>

        <%# Changer le rôle %>
        <%= form_with url: admin_user_path(@user), method: :patch,
                      html: { style: "display:flex;gap:0.5rem;" } do |f| %>
          <%= f.select "user[role]",
              options_for_select(User::ROLES.reject { |r| r == "admin" }.map { |r| [r.humanize, r] }, @user.role),
              {},
              style: "flex:1;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;
                      padding:0.5rem;font-size:0.9rem;outline:none;" %>
          <%= f.submit "Changer",
              style: "background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;
                      font-size:0.9rem;padding:0.5rem 0.75rem;cursor:pointer;" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <%# Signalements %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;margin-bottom:1rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Signalements (<%= @reports.count %>)
      </h3>
      <% if @reports.any? %>
        <% @reports.each do |r| %>
          <div style="padding:0.6rem 0;border-bottom:1px solid #2A2A2A;font-size:0.85rem;">
            <span style="color:#E74C3C;">⚠️ <%= r.reason.humanize %></span>
            <span style="color:#555;margin-left:0.5rem;">· <%= r.created_at.strftime("%d/%m/%Y") %></span>
            <% if r.details.present? %>
              <p style="color:#888;margin:0.25rem 0 0;font-size:0.8rem;"><%= r.details.truncate(100) %></p>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p style="color:#555;font-size:0.85rem;">Aucun signalement.</p>
      <% end %>
    </div>

    <%# Logs admin %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Historique admin
      </h3>
      <% if @logs.any? %>
        <% @logs.each do |log| %>
          <div style="display:flex;justify-content:space-between;padding:0.5rem 0;
                      border-bottom:1px solid #2A2A2A;font-size:0.82rem;">
            <span style="color:#F5C500;font-family:'Bebas Neue',sans-serif;">
              <%= log.action.humanize %>
            </span>
            <span style="color:#555;"><%= log.created_at.strftime("%d/%m/%Y %Hh%M") %></span>
          </div>
        <% end %>
      <% else %>
        <p style="color:#555;font-size:0.85rem;">Aucune action.</p>
      <% end %>
    </div>
  </div>
</div>