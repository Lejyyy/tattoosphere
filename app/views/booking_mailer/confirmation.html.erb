
<h1>Réservation confirmée</h1>
<p>Bonjour <strong style="color:#fff"><%= @user.first_name %></strong>,</p>
<p>Votre réservation auprès de <strong style="color:#ffc107"><%= @tatoueur.nickname %></strong> a bien été enregistrée.</p>

<table class="detail-table">
  <tr><td>Tatoueur</td><td><%= @tatoueur.nickname %></td></tr>
  <tr><td>Shop</td><td><%= @shop.name %></td></tr>
  <tr><td>Adresse</td><td><%= @shop.address %></td></tr>
  <tr><td>Date</td><td><%= @booking.date.strftime("%d/%m/%Y") %></td></tr>
  <tr><td>Horaire</td><td><%= @booking.start_time&.strftime("%H:%M") %> — <%= @booking.end_time&.strftime("%H:%M") %></td></tr>
  <tr><td>Prix estimé</td><td><%= @booking.price_estimated %> €</td></tr>
  <tr><td>Acompte</td><td><%= @booking.deposit_amount %> €</td></tr>
  <tr><td>Statut</td><td><%= @booking.status.humanize %></td></tr>
</table>

<div class="alert-box">
  Un acompte de <strong><%= @booking.deposit_amount %> €</strong> est à régler pour valider définitivement votre réservation.
</div>

<a href="<%= booking_url(@booking) %>" class="btn">Voir ma réservation</a>

<p>À bientôt sur Tattoosphere !</p>

