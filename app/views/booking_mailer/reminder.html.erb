<h1>Rappel — Rendez-vous demain</h1>
<p>Bonjour <strong style="color:#fff"><%= @user.first_name %></strong>,</p>
<p>Petit rappel : vous avez un rendez-vous <strong style="color:#fff">demain</strong> avec <strong style="color:#ffc107"><%= @tatoueur.nickname %></strong>.</p>

<table class="detail-table">
  <tr><td>Tatoueur</td><td><%= @tatoueur.nickname %></td></tr>
  <tr><td>Shop</td><td><%= @shop.name %></td></tr>
  <tr><td>Adresse</td><td><%= @shop.address %></td></tr>
  <tr><td>Date</td><td><%= @booking.date.strftime("%d/%m/%Y") %></td></tr>
  <tr><td>Horaire</td><td><%= @booking.start_time&.strftime("%H:%M") %> — <%= @booking.end_time&.strftime("%H:%M") %></td></tr>
  <tr><td>Reste à régler</td><td><%= (@booking.price_estimated.to_f - @booking.deposit_amount.to_f).round(2) %> € (le jour du RDV)</td></tr>
</table>

<div class="alert-box">
  Pensez à vous hydrater la veille et à porter des vêtements confortables permettant d'accéder à la zone à tatouer.
</div>

<a href="<%= booking_url(@booking) %>" class="btn">Voir ma réservation</a>
