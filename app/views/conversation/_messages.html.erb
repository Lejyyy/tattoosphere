<% is_own = message.user == current_user %>

<div class="message <%= is_own ? "message--own" : "message--other" %>" id="message-<%= message.id %>">
  <div class="message__bubble">
    <p class="message__content mb-0"><%= message.content %></p>
  </div>
  <span class="message__meta text-secondary">
    <%= message.user.nickname || message.user.first_name %> · <%= message.created_at.strftime("%H:%M") %>
  </span>
</div>
