<div class="container py-4">
  <div class="d-flex align-items-center gap-3 mb-4">
    <%= link_to "←", conversations_path, class: "btn btn-outline-secondary btn-sm" %>
    <% other = @conversation.other_participant(current_user) %>
    <h1 class="h5 mb-0">
      <%= other.respond_to?(:nickname) ? other.nickname : other.name %>
    </h1>
  </div>

  <%# MESSAGES %>
  <div id="messages"
       class="d-flex flex-column gap-2 mb-4"
       style="height: 60vh; overflow-y: auto; padding: 1rem;"
       data-conversation-id="<%= @conversation.id %>"
       data-current-user-nickname="<%= current_user.nickname || current_user.first_name %>">

    <% @messages.each do |message| %>
      <%= render "message", message: message %>
    <% end %>

  </div>

  <%# FORMULAIRE %>
  <div class="border-top border-secondary pt-3">
    <%= form_with model: [@conversation, @message],
                  data: { controller: "message-form", turbo: true },
                  class: "d-flex gap-2" do |f| %>
      <%= f.text_area :content,
          rows: 1,
          placeholder: "Écrire un message...",
          class: "form-control",
          required: true,
          data: { message_form_target: "input" },
          style: "resize: none;" %>
      <%= f.submit "Envoyer", class: "btn btn-warning" %>
    <% end %>
  </div>
</div>

