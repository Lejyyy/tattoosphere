<%# Header de la conversation %>
<div style="padding:.6rem .75rem;border-bottom:1px solid #1e1e1e;display:flex;align-items:center;gap:.6rem;flex-shrink:0;">
  <% name = @other&.try(:nickname) || @other&.try(:name) || "Inconnu" %>
  <% avatar_obj = @other&.try(:avatar) %>
  <% if avatar_obj&.attached? %>
    <%= image_tag avatar_obj, style: "width:28px;height:28px;border-radius:50%;object-fit:cover;" %>
  <% else %>
    <span style="width:28px;height:28px;border-radius:50%;background:#2a2a2a;color:#c8a84b;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0;"><%= name.first.upcase %></span>
  <% end %>
  <span style="font-size:.85rem;font-weight:600;color:#fff;flex:1;"><%= name %></span>
  <%= link_to "↗", conversation_path(@conversation), style: "color:#c8a84b;font-size:.8rem;text-decoration:none;", title: "Ouvrir" %>
</div>

<%# Messages %>
<div class="bubble-messages" id="bubble-messages-<%= @conversation.id %>">
  <% @messages.each do |msg| %>
    <div class="bubble-msg <%= msg.user_id == current_user.id ? 'bubble-msg--mine' : 'bubble-msg--other' %>">
      <%= msg.content %>
      <div class="bubble-msg-time"><%= msg.created_at.strftime("%H:%M") %></div>
    </div>
  <% end %>
</div>

<%# Formulaire %>
<div class="bubble-form">
  <%= form_with url: conversation_messages_path(@conversation),
        data: { controller: "bubble-form", conversation_id: @conversation.id },
        class: "d-flex gap-2 w-100" do |f| %>
    <%= f.text_area :content,
          rows: 1,
          placeholder: "Écrire…",
          class: "bubble-input",
          data: { bubble_form_target: "input" } %>
    <%= f.submit "→", class: "bubble-send" %>
  <% end %>
</div>

<script>
  // Scroll en bas à l'ouverture
  const bm = document.getElementById("bubble-messages-<%= @conversation.id %>")
  if (bm) bm.scrollTop = bm.scrollHeight
</script>