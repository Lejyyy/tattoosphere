<div class="ts-inbox">

  <%# Header %>
  <div class="ts-inbox__header">
    <div class="d-flex align-items-center gap-3">
      <h1>Messages</h1>
      <% if @conversations.any? %>
        <span class="ts-inbox__count"><%= @conversations.size %></span>
      <% end %>
    </div>
    <button class="ts-inbox__new-btn" onclick="openNewConversation()">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Nouvelle conversation
    </button>
  </div>

  <%# Modal nouvelle conversation %>
  <div id="new-conv-modal" class="ts-modal" style="display:none;">
    <div class="ts-modal__backdrop" onclick="closeNewConversation()"></div>
    <div class="ts-modal__box">
      <div class="ts-modal__header">
        <span>Nouvelle conversation</span>
        <button onclick="closeNewConversation()" class="ts-modal__close">✕</button>
      </div>
      <div class="ts-modal__body">
        <input id="recipient-search"
               type="text"
               placeholder="Rechercher un pseudo, tatoueur ou shop…"
               class="ts-modal__input"
               oninput="searchRecipients(this.value)"
               autocomplete="off" />
        <div id="recipient-results" class="ts-modal__results"></div>
      </div>
    </div>
  </div>

  <% if @conversations.any? %>
    <div class="ts-inbox__list">
      <% @conversations.each do |conversation| %>
        <% other      = conversation.other_participant(@current_participant) %>
        <% unread     = conversation.unread_count_for(current_user) %>
        <% last_msg   = conversation.last_message %>
        <% name       = Conversation.participant_name(other) %>
        <% avatar_obj = other&.try(:avatar) %>

        <div class="ts-inbox__row">
          <%= link_to conversation_path(conversation),
                class: "ts-inbox__item #{'ts-inbox__item--unread' if unread > 0}" do %>
            <div class="ts-inbox__avatar">
              <% if avatar_obj&.attached? %>
                <%= image_tag avatar_obj, class: "ts-inbox__avatar-img" %>
              <% else %>
                <span class="ts-inbox__avatar-fallback"><%= name.first.upcase %></span>
              <% end %>
              <% if other.is_a?(Tatoueur) && other.verified? %>
                <span class="ts-inbox__verified" title="Tatoueur vérifié">✓</span>
              <% end %>
            </div>
            <div class="ts-inbox__body">
              <div class="ts-inbox__top">
                <span class="ts-inbox__name"><%= name %></span>
                <span class="ts-inbox__time"><%= last_msg&.created_at&.strftime("%d/%m %H:%M") %></span>
              </div>
              <div class="ts-inbox__preview">
                <span class="ts-inbox__preview-text">
                  <% if last_msg %>
                    <% if last_msg.user == current_user %>
                      <span class="ts-inbox__you">Vous : </span>
                    <% end %>
                    <%= last_msg.content&.truncate(55) %>
                  <% else %>
                    <em>Aucun message</em>
                  <% end %>
                </span>
                <% if unread > 0 %>
                  <span class="ts-inbox__badge"><%= unread %></span>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Bouton supprimer %>
          <%= button_to conversation_path(conversation),
                method: :delete,
                data: { confirm: "Supprimer cette conversation ?" },
                class: "ts-inbox__delete",
                title: "Supprimer" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="ts-inbox__empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <p>Aucune conversation pour le moment.</p>
      <button class="ts-inbox__new-btn mt-3" onclick="openNewConversation()">Démarrer une conversation</button>
    </div>
  <% end %>
</div>

<%# CSS supplémentaire %>
<style>
  .ts-inbox__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .ts-inbox__new-btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: #c8a84b;
    color: #000;
    border: none;
    border-radius: 8px;
    padding: .45rem .9rem;
    font-size: .82rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .15s;
  }
  .ts-inbox__new-btn:hover { opacity: .85; }

  .ts-inbox__row {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .ts-inbox__item {
    flex: 1;
    min-width: 0;
  }

  .ts-inbox__delete {
    flex-shrink: 0;
    background: transparent;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    color: #555;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color .15s, border-color .15s;
    padding: 0;
  }
  .ts-inbox__delete:hover { color: #e53e3e; border-color: #e53e3e44; }

  /* Modal */
  .ts-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ts-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.7);
  }
  .ts-modal__box {
    position: relative;
    background: #111;
    border: 1px solid #222;
    border-radius: 12px;
    width: 420px;
    max-width: 95vw;
    box-shadow: 0 16px 48px rgba(0,0,0,.8);
    overflow: hidden;
  }
  .ts-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .9rem 1rem;
    border-bottom: 1px solid #222;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: .05em;
    color: #c8a84b;
  }
  .ts-modal__close {
    background: transparent;
    border: none;
    color: #666;
    cursor: pointer;
    font-size: 1rem;
  }
  .ts-modal__body { padding: 1rem; }
  .ts-modal__input {
    width: 100%;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    color: #fff;
    padding: .6rem .9rem;
    font-size: .9rem;
    outline: none;
    margin-bottom: .75rem;
  }
  .ts-modal__input:focus { border-color: #c8a84b55; }

  .ts-modal__results { display: flex; flex-direction: column; gap: .4rem; max-height: 280px; overflow-y: auto; }

  .ts-recipient {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem .75rem;
    border-radius: 8px;
    background: #1a1a1a;
    cursor: pointer;
    transition: background .15s;
    border: none;
    width: 100%;
    text-align: left;
  }
  .ts-recipient:hover { background: #222; }

  .ts-recipient__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c8a84b;
    font-weight: 700;
    font-size: .85rem;
    flex-shrink: 0;
  }
  .ts-recipient__name { font-size: .88rem; font-weight: 600; color: #fff; }
  .ts-recipient__sub  { font-size: .72rem; color: #666; }

  .ts-modal__empty { color: #555; font-size: .82rem; text-align: center; padding: 1.5rem 0; }
</style>

<script>
  let searchTimeout = null

  function openNewConversation() {
    document.getElementById("new-conv-modal").style.display = "flex"
    setTimeout(() => document.getElementById("recipient-search").focus(), 50)
  }

  function closeNewConversation() {
    document.getElementById("new-conv-modal").style.display = "none"
    document.getElementById("recipient-search").value = ""
    document.getElementById("recipient-results").innerHTML = ""
  }

  function searchRecipients(q) {
    clearTimeout(searchTimeout)
    const results = document.getElementById("recipient-results")
    if (q.length < 2) { results.innerHTML = ""; return }

    searchTimeout = setTimeout(() => {
      fetch(`/conversations/search_recipients?q=${encodeURIComponent(q)}`, {
        headers: { "Accept": "application/json" }
      })
      .then(r => r.json())
      .then(data => {
        if (!data.length) {
          results.innerHTML = '<div class="ts-modal__empty">Aucun résultat</div>'
          return
        }
        results.innerHTML = data.map(r => `
          <button class="ts-recipient" onclick="startConversation('${r.type}', ${r.id})">
            ${r.avatar
              ? `<img src="${r.avatar}" class="ts-recipient__avatar" />`
              : `<div class="ts-recipient__avatar">${r.name[0].toUpperCase()}</div>`
            }
            <div>
              <div class="ts-recipient__name">${r.name}</div>
              <div class="ts-recipient__sub">${r.subtitle}</div>
            </div>
          </button>
        `).join("")
      })
    }, 300)
  }

  function startConversation(type, id) {
    const form = document.createElement("form")
    form.method = "POST"
    form.action = "/conversations"

    const token = document.querySelector('meta[name="csrf-token"]').content
    const csrf  = document.createElement("input")
    csrf.type = "hidden"; csrf.name = "authenticity_token"; csrf.value = token
    form.appendChild(csrf)

    const param = document.createElement("input")
    param.type = "hidden"
    param.name = type === "Tatoueur" ? "tatoueur_id" : type === "Shop" ? "shop_id" : "user_id"
    param.value = id
    form.appendChild(param)

    document.body.appendChild(form)
    form.submit()
  }

  // Fermer avec Escape
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") closeNewConversation()
  })
</script>

<%# ─── Styles ──────────────────────────────────────────────────── %>
<style>
  .ts-inbox {
    max-width: 680px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }

  .ts-inbox__header {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 1.5rem;
  }

  .ts-inbox__header h1 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .ts-inbox__count {
    background: #c8a84b;
    color: #000;
    font-size: .72rem;
    font-weight: 700;
    border-radius: 999px;
    padding: .15rem .55rem;
  }

  .ts-inbox__list {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .ts-inbox__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: .9rem 1rem;
    background: #111;
    border: 1px solid #222;
    border-radius: 10px;
    text-decoration: none;
    transition: background .15s, border-color .15s;
  }

  .ts-inbox__item:hover {
    background: #1a1a1a;
    border-color: #c8a84b55;
  }

  .ts-inbox__item--unread {
    border-left: 3px solid #c8a84b;
  }

  /* Avatar */
  .ts-inbox__avatar {
    position: relative;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
  }

  .ts-inbox__avatar-img {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
  }

  .ts-inbox__avatar-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: #2a2a2a;
    color: #c8a84b;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .ts-inbox__verified {
    position: absolute;
    bottom: 0;
    right: -2px;
    background: #c8a84b;
    color: #000;
    font-size: .6rem;
    font-weight: 800;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Body */
  .ts-inbox__body {
    flex: 1;
    min-width: 0;
  }

  .ts-inbox__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: .2rem;
  }

  .ts-inbox__name {
    font-weight: 600;
    font-size: .95rem;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ts-inbox__time {
    font-size: .72rem;
    color: #666;
    flex-shrink: 0;
    margin-left: .5rem;
  }

  .ts-inbox__preview {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }

  .ts-inbox__preview-text {
    font-size: .82rem;
    color: #888;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ts-inbox__you {
    color: #c8a84b;
    font-weight: 500;
  }

  .ts-inbox__badge {
    flex-shrink: 0;
    background: #c8a84b;
    color: #000;
    font-size: .7rem;
    font-weight: 700;
    border-radius: 999px;
    padding: .1rem .5rem;
    min-width: 20px;
    text-align: center;
  }

  /* Empty state */
  .ts-inbox__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .75rem;
    padding: 4rem 1rem;
    color: #555;
    text-align: center;
  }

  .ts-inbox__empty p {
    font-size: 1rem;
    color: #888;
    margin: 0;
  }

  .ts-inbox__empty span {
    font-size: .82rem;
    color: #555;
  }
</style>