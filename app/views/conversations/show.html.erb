<div class="container py-4" style="max-width:800px;">

  <%# Header %>
  <div class="d-flex align-items-center gap-3 mb-4" style="border-bottom:2px solid #F5C500;padding-bottom:1rem;">
    <%= link_to "←", conversations_path, class: "btn btn-outline-primary btn-sm" %>
    <% other = @conversation.other_participant(@current_participant) %>
    <h1 class="mb-0" style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;">
      <%= other&.try(:nickname) || other&.try(:name) || other&.try(:first_name) || "Inconnu" %>
    </h1>
  </div>

  <%# Messages %>
  <div id="messages"
       class="d-flex flex-column gap-2 mb-4"
       style="height:60vh;overflow-y:auto;padding:1rem;background:#1A1A1A;border:1px solid #2A2A2A;"
       data-conversation-id="<%= @conversation.id %>"
       data-current-user-nickname="<%= current_user.nickname || current_user.first_name %>">
    <% @messages.each do |message| %>
      <%= render "message", message: message %>
    <% end %>
  </div>

  <%# Formulaire %>
  <div id="new_message_form" style="border-top:2px solid #2A2A2A;padding-top:1rem;">
    <%= form_with model: [@conversation, Message.new],
                  data: { controller: "message-form", turbo: true },
                  class: "d-flex flex-column gap-2" do |f| %>

      <%# Carte de partage (injectée dynamiquement) %>
      <div id="share-preview" style="display:none;background:#111;border:1px solid #2a2a2a;border-left:3px solid #F5C500;padding:0.75rem 1rem;border-radius:2px;position:relative;">
        <button type="button" onclick="clearSharePreview()"
                style="position:absolute;top:0.4rem;right:0.6rem;background:transparent;border:none;color:#666;cursor:pointer;font-size:0.85rem;">✕</button>
        <div id="share-preview-type" style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#F5C500;margin-bottom:0.2rem;"></div>
        <div id="share-preview-name" style="font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#fff;"></div>
        <%= f.hidden_field :shared_profile_type, id: "share-type-input" %>
        <%= f.hidden_field :shared_profile_id,   id: "share-id-input" %>
      </div>

      <div class="d-flex gap-2 align-items-end">
        <%= f.text_area :content,
            rows: 1,
            placeholder: "Écrire un message...",
            class: "form-control",
            data: { message_form_target: "input" },
            style: "resize:none;background:#1A1A1A;border:1px solid #2A2A2A;color:#fff;" %>

        <%# Bouton partager %>
        <button type="button"
                onclick="toggleSharePanel()"
                id="share-btn"
                title="Partager un profil"
                style="background:transparent;border:1px solid #2a2a2a;color:#888;width:38px;height:38px;flex-shrink:0;display:flex;align-items:center;justify-content:center;cursor:pointer;border-radius:3px;transition:all .15s;"
                onmouseover="this.style.borderColor='#F5C500';this.style.color='#F5C500'"
                onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#888'">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </button>

        <%= f.submit "Envoyer", class: "hero-cta" %>
      </div>

      <%# Panel de partage ── recherche inline %>
      <div id="share-panel" style="display:none;background:#0d0d0d;border:1px solid #2a2a2a;border-radius:3px;padding:0.75rem;">
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#555;margin-bottom:0.5rem;">Partager un profil</div>
        <div style="position:relative;">
          <svg style="position:absolute;left:0.65rem;top:50%;transform:translateY(-50%);color:#555;pointer-events:none;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="share-search-input"
                 type="text"
                 placeholder="Rechercher un tatoueur ou shop…"
                 oninput="shareSearch(this.value)"
                 autocomplete="off"
                 style="width:100%;background:#1a1a1a;border:1px solid #2a2a2a;color:#fff;padding:0.5rem 0.75rem 0.5rem 2rem;font-size:0.85rem;outline:none;border-radius:2px;transition:border-color .2s;"
                 onfocus="this.style.borderColor='#F5C500'"
                 onblur="this.style.borderColor='#2a2a2a'" />
        </div>
        <div id="share-search-results" style="margin-top:0.5rem;max-height:180px;overflow-y:auto;"></div>

        <%# Accès rapide événements %>
        <div style="margin-top:0.75rem;border-top:1px solid #1e1e1e;padding-top:0.6rem;">
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:#555;margin-bottom:0.4rem;">Événements à venir</div>
          <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
            <% Event.where("start_date >= ?", Time.current).order(start_date: :asc).limit(5).each do |event| %>
              <button type="button"
                      onclick="selectShare('Event', <%= event.id %>, 'Événement', '<%= j event.name %>')"
                      style="font-size:11px;padding:3px 9px;background:transparent;border:1px solid #2a2a2a;color:#888;border-radius:2px;cursor:pointer;transition:all .15s;"
                      onmouseover="this.style.borderColor='#F5C500';this.style.color='#F5C500'"
                      onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#888'">
                🎪 <%= event.name.truncate(28) %>
              </button>
            <% end %>
          </div>
        </div>
      </div>

      <%# Pièce jointe %>
      <div class="d-flex align-items-center gap-2">
        <%= f.file_field :attachment,
            accept: "image/png,image/jpeg,application/pdf",
            class: "form-control form-control-sm",
            style: "background:#1A1A1A;border:1px solid #2A2A2A;color:#888;font-size:0.8rem;",
            data: { message_form_target: "file" } %>
        <span class="text-secondary" style="font-size:0.75rem;white-space:nowrap;">PDF, PNG, JPG</span>
      </div>

    <% end %>
  </div>
</div>

<script>
  let shareTimeout = null

  function toggleSharePanel() {
    const panel = document.getElementById('share-panel')
    const visible = panel.style.display !== 'none'
    panel.style.display = visible ? 'none' : 'block'
    if (!visible) document.getElementById('share-search-input').focus()
  }

  function shareSearch(q) {
    const box = document.getElementById('share-search-results')
    clearTimeout(shareTimeout)
    if (q.length < 2) { box.innerHTML = ''; return }

    shareTimeout = setTimeout(() => {
      fetch(`/conversations/search_recipients?q=${encodeURIComponent(q)}`, {
        headers: { 'Accept': 'application/json' }
      })
      .then(r => r.json())
      .then(data => {
        if (!data.length) {
          box.innerHTML = '<div style="font-size:12px;color:#555;padding:0.5rem 0;">Aucun résultat</div>'
          return
        }
        box.innerHTML = data.map(r => `
          <button type="button"
                  onclick="selectShare('${r.type}', ${r.id}, '${r.subtitle}', '${r.name.replace(/'/g, "\\'")}')"
                  style="display:flex;align-items:center;gap:0.6rem;width:100%;padding:0.45rem 0.5rem;background:transparent;border:none;border-radius:2px;cursor:pointer;text-align:left;transition:background .12s;"
                  onmouseover="this.style.background='#1a1a1a'"
                  onmouseout="this.style.background='transparent'">
            ${r.avatar ? `<img src="${r.avatar}" style="width:26px;height:26px;border-radius:50%;object-fit:cover;flex-shrink:0;">` : `<span style="width:26px;height:26px;background:#2a2a2a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">${r.type === 'Tatoueur' ? '🖋' : '🏠'}</span>`}
            <div style="min-width:0;">
              <div style="font-size:13px;color:#fff;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name}</div>
              <div style="font-size:11px;color:#666;">${r.subtitle}</div>
            </div>
          </button>
        `).join('')
      })
    }, 280)
  }

  function selectShare(type, id, subtitle, name) {
    document.getElementById('share-type-input').value = type
    document.getElementById('share-id-input').value   = id
    document.getElementById('share-preview-type').textContent = subtitle
    document.getElementById('share-preview-name').textContent = name
    document.getElementById('share-preview').style.display = 'block'
    document.getElementById('share-panel').style.display   = 'none'
    document.getElementById('share-search-input').value    = ''
    document.getElementById('share-search-results').innerHTML = ''
  }

  function clearSharePreview() {
    document.getElementById('share-type-input').value = ''
    document.getElementById('share-id-input').value   = ''
    document.getElementById('share-preview').style.display = 'none'
  }
</script>