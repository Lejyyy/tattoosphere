<div class="container py-4" style="max-width:800px;">

  <%# Header %>
  <div class="d-flex align-items-center gap-3 mb-4" style="border-bottom:2px solid #F5C500;padding-bottom:1rem;">
    <%= link_to "←", conversations_path, class: "btn btn-outline-primary btn-sm" %>
    <% other = @conversation.other_participant(current_user) %>
    <h1 class="mb-0" style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;">
      <%= other&.try(:nickname) || other&.try(:name) || other&.first_name || "Inconnu" %>
    </h1>
  </div>

  <%# Messages %>
  <div id="messages"
       class="d-flex flex-column gap-2 mb-4"
       style="height:60vh;overflow-y:auto;padding:1rem;background:#1A1A1A;border:1px solid #2A2A2A;"
       data-conversation-id="<%= @conversation.id %>"
       data-current-user-nickname="<%= current_user.nickname || current_user.first_name %>">
    <% @messages.each do |message| %>
      <%= render "message", message: message %>
    <% end %>
  </div>

  <%# Formulaire %>
  <div id="new_message_form" style="border-top:2px solid #2A2A2A;padding-top:1rem;">
  <%= form_with model: [@conversation, Message.new],
                data: { controller: "message-form", turbo: true },
                class: "d-flex flex-column gap-2" do |f| %>

    <div class="d-flex gap-2">
      <%= f.text_area :content,
          rows: 1,
          placeholder: "Écrire un message...",
          class: "form-control",
          data: { message_form_target: "input" },
          style: "resize:none;background:#1A1A1A;border:1px solid #2A2A2A;color:#fff;" %>
      <%= f.submit "Envoyer", class: "hero-cta" %>
    </div>

    <%# Pièce jointe %>
    <div class="d-flex align-items-center gap-2">
      <%= f.file_field :attachment,
          accept: "image/png,image/jpeg,application/pdf",
          class: "form-control form-control-sm",
          style: "background:#1A1A1A;border:1px solid #2A2A2A;color:#888;font-size:0.8rem;",
          data: { message_form_target: "file" } %>
      <span class="text-secondary" style="font-size:0.75rem;white-space:nowrap;">PDF, PNG, JPG</span>
    </div>

  <% end %>
</div>

</div>