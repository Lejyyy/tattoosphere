<div class="row g-4">

  <%# Colonne principale %>
  <div class="col-lg-8">

    <%# Stats %>
    <div class="row g-3 mb-4">
      <div class="col-4">
        <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;text-align:center;">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#F5C500;"><%= @shop.tatoueurs.count %></div>
          <div class="text-secondary" style="font-size:0.8rem;text-transform:uppercase;">Tatoueurs</div>
        </div>
      </div>
      <div class="col-4">
        <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;text-align:center;">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#F5C500;"><%= @shop.bookings.count %></div>
          <div class="text-secondary" style="font-size:0.8rem;text-transform:uppercase;">Réservations</div>
        </div>
      </div>
      <div class="col-4">
        <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;text-align:center;">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#F5C500;"><%= @unread_count %></div>
          <div class="text-secondary" style="font-size:0.8rem;text-transform:uppercase;">Non lus</div>
        </div>
      </div>
    </div>

    <%# Tatoueurs %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-title mb-0">Mes tatoueurs</h2>
      <button onclick="document.getElementById('equipe-modal').style.display='flex'"
              style="background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:0.08em;padding:0.5rem 1.25rem;cursor:pointer;text-transform:uppercase;">
        ✏️ Modifier l'équipe
      </button>
    </div>

    <div id="tatoueurs-list">
      <% if @shop.tatoueurs.any? %>
        <% @shop.tatoueurs.each do |tatoueur| %>
          <div id="dash-tatoueur-<%= tatoueur.id %>" style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1rem 1.5rem;margin-bottom:0.75rem;display:flex;justify-content:space-between;align-items:center;">
            <div class="d-flex align-items-center gap-3">
              <% if tatoueur.avatar.attached? %>
                <%= image_tag tatoueur.avatar, style: "width:40px;height:40px;object-fit:cover;border-radius:50%;border:2px solid #F5C500;" %>
              <% else %>
                <div style="width:40px;height:40px;border-radius:50%;background:#2A2A2A;display:flex;align-items:center;justify-content:center;">🖋️</div>
              <% end %>
              <div>
                <span style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;"><%= tatoueur.nickname %></span>
                <div class="text-secondary" style="font-size:0.8rem;"><%= tatoueur.tattoo_styles.map(&:name).join(", ") %></div>
              </div>
            </div>
            <%= link_to "Voir", tatoueur_path(tatoueur), class: "btn btn-outline-primary btn-sm" %>
          </div>
        <% end %>
      <% else %>
        <p id="dash-no-tatoueurs" class="text-secondary">Aucun tatoueur rattaché.</p>
      <% end %>
    </div>


<h2 class="section-title mb-3 mt-4">Disponibilités de l'équipe</h2>

<% if @shop.tatoueurs.any? %>
  <% days_label = %w[Dim Lun Mar Mer Jeu Ven Sam] %>
  <% @shop.tatoueurs.each do |tatoueur| %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1rem 1.5rem;
                margin-bottom:0.75rem;">

      <%# En-tête tatoueur %>
      <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="d-flex align-items-center gap-2">
          <% if tatoueur.avatar.attached? %>
            <%= image_tag tatoueur.avatar,
                style: "width:32px;height:32px;object-fit:cover;border:2px solid #F5C500;" %>
          <% else %>
            <div style="width:32px;height:32px;background:#2A2A2A;display:flex;
                        align-items:center;justify-content:center;">🖋️</div>
          <% end %>
          <span style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#fff;">
            <%= tatoueur.nickname %>
          </span>
        </div>
        <%= link_to "Voir les dispos →",
            tatoueur_availabilities_path(tatoueur),
            style: "font-size:0.75rem;color:#F5C500;text-decoration:none;
                    border:1px solid rgba(245,197,0,0.4);padding:0.2rem 0.6rem;
                    font-family:'Bebas Neue',sans-serif;letter-spacing:0.05em;" %>
      </div>

      <%# Mini grille Lun→Dim %>
      <% avails = tatoueur.availabilities.group_by(&:day_of_week) %>
      <% confirmed_days = tatoueur.bookings
             .where(status: "confirmed")
             .where(date: Date.today.beginning_of_week..Date.today.end_of_week)
             .pluck(:date).map(&:wday).uniq %>

      <div style="display:flex;gap:0.3rem;">
        <% [1,2,3,4,5,6,0].each do |day_num| %>
          <% slots      = avails[day_num] %>
          <% has_rdv    = confirmed_days.include?(day_num) %>
          <% color      = if has_rdv then "#E67E22"
                          elsif slots&.any? then "#F5C500"
                          else nil end %>
          <div style="flex:1;text-align:center;">
            <div style="font-size:0.65rem;color:#555;text-transform:uppercase;
                        letter-spacing:0.04em;margin-bottom:0.25rem;">
              <%= days_label[day_num] %>
            </div>
            <div style="height:26px;border-radius:2px;
                        background:<%= color || '#111' %>;
                        border:<%= color ? 'none' : '1px solid #2A2A2A' %>;"
                 title="<%= has_rdv ? 'RDV confirmé' : (slots&.any? ? "#{slots.count} créneaux" : 'Indisponible') %>">
            </div>
            <% if slots&.any? && !has_rdv %>
              <div style="font-size:0.6rem;color:#888;margin-top:0.2rem;"><%= slots.count %></div>
            <% elsif has_rdv %>
              <div style="font-size:0.6rem;color:#E67E22;margin-top:0.2rem;">RDV</div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Légende compacte %>
      <div style="display:flex;gap:1rem;margin-top:0.75rem;">
        <span style="font-size:0.7rem;color:#888;display:flex;align-items:center;gap:0.3rem;">
          <span style="width:10px;height:10px;background:#F5C500;display:inline-block;border-radius:1px;"></span> Disponible
        </span>
        <span style="font-size:0.7rem;color:#888;display:flex;align-items:center;gap:0.3rem;">
          <span style="width:10px;height:10px;background:#E67E22;display:inline-block;border-radius:1px;"></span> RDV confirmé
        </span>
        <span style="font-size:0.7rem;color:#888;display:flex;align-items:center;gap:0.3rem;">
          <span style="width:10px;height:10px;background:#111;border:1px solid #2A2A2A;display:inline-block;border-radius:1px;"></span> Indisponible
        </span>
      </div>

    </div>
  <% end %>
<% else %>
  <p class="text-secondary">Aucun tatoueur rattaché.</p>
<% end %>

    <%# Réservations à venir %>
    <h2 class="section-title mb-3 mt-4">Réservations à venir</h2>
    <% shop_bookings = @shop.bookings.where("date >= ?", Date.today).order(date: :asc).limit(5) %>
    <% if shop_bookings.any? %>
      <% shop_bookings.each do |booking| %>
        <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-left:4px solid #F5C500;padding:1rem 1.5rem;margin-bottom:0.75rem;">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;">
                <%= booking.date&.strftime("%d %B %Y") %>
              </div>
              <div class="text-secondary" style="font-size:0.85rem;">
                <%= booking.user.nickname %> · <%= booking.tatoueur.nickname %>
              </div>
            </div>
            <span class="badge <%= booking.status == 'confirmed' ? 'bg-success' : 'bg-warning' %>">
              <%= booking.status %>
            </span>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-secondary">Aucune réservation à venir.</p>
    <% end %>

  </div>

  <%# Colonne droite %>
  <div class="col-lg-4">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;margin-bottom:1.5rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;">
        Mon shop
      </h3>
      <div class="d-flex flex-column gap-2 mt-3">
        <%= link_to "👁️ Voir ma page", shop_path(@shop), class: "btn btn-outline-primary btn-sm w-100" %>
        <%= link_to "✏️ Modifier ma page", edit_shop_path(@shop), class: "btn btn-outline-primary btn-sm w-100" %>
        <%= link_to "❤️ Mes favoris", favorites_path, class: "btn btn-outline-primary btn-sm w-100" %>
        <%= link_to "🖼️ Créer un portfolio", new_shop_portfolio_path(@shop), class: "btn btn-outline-primary btn-sm w-100" %>
        <%= link_to "🎉 Créer un événement", new_event_path, class: "hero-cta w-100 text-center mt-2" %>
      </div>
    </div>
  </div>
</div>

<%# ================================ %>
<%# MODAL ÉQUIPE %>
<%# ================================ %>
<div id="equipe-modal"
     style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.85);z-index:1000;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;padding:2rem;position:relative;">

    <%# Header modal %>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#F5C500;margin:0;">Mon équipe</h2>
      <button onclick="document.getElementById('equipe-modal').style.display='none'"
              style="background:transparent;border:none;color:#888;font-size:1.5rem;cursor:pointer;line-height:1;">✕</button>
    </div>

    <%# Tags tatoueurs actuels %>
    <p style="font-size:0.8rem;color:#888;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Actuellement rattachés</p>
    <div id="modal-tatoueurs-panel" class="d-flex flex-wrap gap-2 mb-4">
      <% if @shop.tatoueurs.any? %>
        <% @shop.tatoueurs.each do |tatoueur| %>
          <div id="modal-tag-<%= tatoueur.id %>"
               style="background:#0D0D0D;border:1px solid #2A2A2A;padding:0.4rem 0.75rem;display:flex;align-items:center;gap:0.5rem;">
            <% if tatoueur.avatar.attached? %>
              <%= image_tag tatoueur.avatar, style: "width:24px;height:24px;object-fit:cover;border-radius:50%;border:1px solid #F5C500;" %>
            <% else %>
              <span>🖋️</span>
            <% end %>
            <span style="font-family:'Bebas Neue',sans-serif;font-size:0.95rem;color:#fff;"><%= tatoueur.nickname %></span>
            <button type="button"
                    data-id="<%= tatoueur.id %>"
                    data-name="<%= j tatoueur.nickname %>"
                    onclick="modalRemoveTatoueur(this)"
                    style="background:transparent;border:none;color:#C0392B;cursor:pointer;font-size:1rem;padding:0 0 0 0.25rem;line-height:1;">✕</button>
          </div>
        <% end %>
      <% else %>
        <p id="modal-no-tatoueurs" class="text-secondary" style="font-size:0.85rem;">Aucun tatoueur rattaché.</p>
      <% end %>
    </div>

    <%# Recherche & ajout %>
    <p style="font-size:0.8rem;color:#888;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Ajouter un tatoueur</p>
    <% available_tatoueurs = Tatoueur.where(is_active: true).where.not(id: @shop.tatoueur_ids) %>
    <% if available_tatoueurs.any? %>
      <div style="position:relative;">
        <input type="text"
               id="modal-tatoueur-search"
               placeholder="Rechercher par nom ou email..."
               autocomplete="off"
               style="width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;"
               onfocus="this.style.borderColor='#F5C500';document.getElementById('modal-tatoueur-results').style.display='block'"
               onblur="setTimeout(()=>document.getElementById('modal-tatoueur-results').style.display='none',250)"
               oninput="modalFilterTatoueurs(this.value)" />
        <div id="modal-tatoueur-results"
             style="display:none;position:absolute;top:100%;left:0;right:0;background:#1A1A1A;border:1px solid #F5C500;border-top:none;z-index:200;max-height:200px;overflow-y:auto;">
          <% available_tatoueurs.each do |t| %>
            <div class="modal-tatoueur-option"
                 data-id="<%= t.id %>"
                 data-name="<%= t.nickname.downcase %>"
                 data-email="<%= t.email.downcase %>"
                 data-display="<%= t.nickname %>"
                 onmousedown="modalAddTatoueur(this)"
                 style="padding:0.75rem 1rem;cursor:pointer;border-bottom:1px solid #2A2A2A;"
                 onmouseover="this.style.background='#2A2A2A'"
                 onmouseout="this.style.background='transparent'">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#fff;"><%= t.nickname %></div>
              <div style="font-size:0.8rem;color:#666;"><%= t.email %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-secondary" style="font-size:0.85rem;margin-top:0.5rem;">Aucun tatoueur disponible.</p>
    <% end %>

  </div>
</div>

<script>
  const dashCsrf = () => document.querySelector('meta[name="csrf-token"]').content
  const shopId   = <%= @shop.id %>

  function modalFilterTatoueurs(query) {
    const q = query.toLowerCase()
    document.querySelectorAll(".modal-tatoueur-option").forEach(el => {
      const match = el.dataset.name.includes(q) || el.dataset.email.includes(q)
      el.style.display = (q === "" || match) ? "block" : "none"
    })
  }

  async function modalAddTatoueur(el) {
    const id   = el.dataset.id
    const name = el.dataset.display
    const res  = await fetch(`/shops/${shopId}/add_tatoueur`, {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded",
        "X-CSRF-Token": dashCsrf()
      },
      body: `tatoueur_id=${id}`
    })
    if (res.ok || res.redirected) {
      el.style.display = "none"
      document.getElementById("modal-tatoueur-search").value = ""
      document.getElementById("modal-tatoueur-results").style.display = "none"

      const msg = document.getElementById("modal-no-tatoueurs")
      if (msg) msg.remove()

      // Ajouter tag dans le modal
      const panel = document.getElementById("modal-tatoueurs-panel")
      const tag   = document.createElement("div")
      tag.id      = `modal-tag-${id}`
      tag.style   = "background:#0D0D0D;border:1px solid #F5C500;padding:0.4rem 0.75rem;display:flex;align-items:center;gap:0.5rem;"
      tag.innerHTML = `
        <span style="font-family:'Bebas Neue',sans-serif;font-size:0.95rem;color:#F5C500;">🖋️ ${name}</span>
        <button type="button" data-id="${id}" data-name="${name}" onclick="modalRemoveTatoueur(this)"
                style="background:transparent;border:none;color:#C0392B;cursor:pointer;font-size:1rem;padding:0 0 0 0.25rem;line-height:1;">✕</button>
      `
      panel.appendChild(tag)

      // Ajouter dans la liste principale du dashboard
      const list    = document.getElementById("tatoueurs-list")
      const noMsg   = document.getElementById("dash-no-tatoueurs")
      if (noMsg) noMsg.remove()
      const dashTag = document.createElement("div")
      dashTag.id    = `dash-tatoueur-${id}`
      dashTag.style = "background:#1A1A1A;border:1px solid #2A2A2A;padding:1rem 1.5rem;margin-bottom:0.75rem;display:flex;justify-content:space-between;align-items:center;"
      dashTag.innerHTML = `
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <div style="width:40px;height:40px;border-radius:50%;background:#2A2A2A;display:flex;align-items:center;justify-content:center;">🖋️</div>
          <span style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;">${name}</span>
        </div>
      `
      list.appendChild(dashTag)
    }
  }

  async function modalRemoveTatoueur(btn) {
    const id   = btn.dataset.id
    const name = btn.dataset.name
    if (!confirm(`Retirer ${name} du shop ?`)) return

    const res = await fetch(`/shops/${shopId}/remove_tatoueur?tatoueur_id=${id}`, {
      method: "DELETE",
      headers: {
        "X-CSRF-Token": dashCsrf(),
        "Accept": "application/json"
      }
    })
    if (res.ok) {
      // Supprimer tag modal
      document.getElementById(`modal-tag-${id}`)?.remove()
      // Supprimer dans la liste dashboard
      document.getElementById(`dash-tatoueur-${id}`)?.remove()
      // Réafficher dans dropdown
      document.querySelectorAll(".modal-tatoueur-option").forEach(el => {
        if (el.dataset.id === id) el.style.display = "block"
      })
      // Message si panel vide
      const panel = document.getElementById("modal-tatoueurs-panel")
      if (panel.querySelectorAll("[id^='modal-tag-']").length === 0) {
        panel.innerHTML = '<p id="modal-no-tatoueurs" class="text-secondary" style="font-size:0.85rem;">Aucun tatoueur rattaché.</p>'
      }
      // Message si liste dashboard vide
      const list = document.getElementById("tatoueurs-list")
      if (list.querySelectorAll("[id^='dash-tatoueur-']").length === 0) {
        list.innerHTML = '<p id="dash-no-tatoueurs" class="text-secondary">Aucun tatoueur rattaché.</p>'
      }
    }
  }

  // Fermer modal en cliquant en dehors
  document.getElementById("equipe-modal").addEventListener("click", function(e) {
    if (e.target === this) this.style.display = "none"
  })
</script>