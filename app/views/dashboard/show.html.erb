<%# HEADER %>
<section class="section pb-0">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1 class="mb-0">Bonjour, <span class="text-yellow"><%= current_user.nickname %></span></h1>
        <p class="text-secondary mt-1 mb-0">
          <% if @tatoueur %>Tatoueur
          <% elsif @shop %>Shop owner
          <% else %>Membre
          <% end %>
          · Inscrit depuis <%= current_user.created_at.strftime("%B %Y") %>
        </p>
      </div>
      <%= link_to "Modifier mon profil", edit_user_registration_path, class: "hero-cta-outline" %>
    </div>
  </div>
</section>

<hr style="border-color:#2A2A2A;margin:2rem 0;">

<div class="container pb-5">
  <% if @tatoueur %>
    <%= render "tatoueur" %>
  <% elsif @shop %>
    <%= render "shop" %>
  <% else %>
    <%= render "user" %>
  <% end %>
</div>