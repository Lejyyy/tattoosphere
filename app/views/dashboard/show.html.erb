<%# HEADER %>
<section class="section pb-0">
  <div class="container">
    <div class="d-flex align-items-center gap-4 flex-wrap">

      <%# Avatar %>
      <% if @tatoueur&.avatar&.attached? %>
        <%= image_tag @tatoueur.avatar,
            style: "width:90px;height:90px;object-fit:cover;border-radius:50%;
                    border:3px solid #F5C500;flex-shrink:0;" %>
      <% elsif @shop&.cover&.attached? %>
        <%= image_tag @shop.cover,
            style: "width:90px;height:90px;object-fit:cover;
                    border:3px solid #F5C500;flex-shrink:0;" %>
      <% elsif current_user.avatar.attached? %>
        <%= image_tag current_user.avatar,
            style: "width:90px;height:90px;object-fit:cover;border-radius:50%;
                    border:3px solid #F5C500;flex-shrink:0;" %>
      <% else %>
        <div style="width:90px;height:90px;background:#1A1A1A;border:3px solid #2A2A2A;
                    border-radius:50%;display:flex;align-items:center;justify-content:center;
                    font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#F5C500;flex-shrink:0;">
          <%= current_user.nickname.first.upcase %>
        </div>
      <% end %>

      <%# Infos %>
      <div class="flex-grow-1">
        <h1 class="mb-0">
          Bonjour, <span class="text-yellow"><%= current_user.nickname %></span>
        </h1>
        <p class="text-secondary mt-1 mb-0">
          <% if @tatoueur %>🖋️ Tatoueur
          <% elsif @shop %>🏠 Shop owner
          <% else %>👤 Membre
          <% end %>
          · Inscrit depuis <%= current_user.created_at.strftime("%B %Y") %>
        </p>
      </div>

      <%# Actions %>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
        <% if @tatoueur %>
          <%= link_to "✏️ Modifier mon profil", edit_tatoueur_path(@tatoueur), class: "hero-cta-outline" %>
        <% elsif @shop %>
          <%= link_to "✏️ Modifier mon shop", edit_shop_path(@shop), class: "hero-cta-outline" %>
        <% else %>
          <%= link_to "✏️ Modifier mon profil", edit_user_registration_path, class: "hero-cta-outline" %>
        <% end %>

        <% if current_user.admin? %>
          <%= link_to admin_root_path,
              style: "display:inline-flex;align-items:center;gap:0.5rem;
                      background:#F5C500;color:#000;font-family:'Bebas Neue',sans-serif;
                      font-size:1rem;letter-spacing:0.08em;padding:0.6rem 1.25rem;
                      text-decoration:none;" do %>
            ⚙️ Panel Admin
          <% end %>
        <% end %>
      </div>

    </div>
  </div>
</section>

<hr style="border-color:#2A2A2A;margin:2rem 0;">

<div class="container pb-5">
  <% if @tatoueur %>
    <%= render "tatoueur" %>
  <% elsif @shop %>
    <%= render "shop" %>
  <% else %>
    <%= render "user" %>
  <% end %>
</div>