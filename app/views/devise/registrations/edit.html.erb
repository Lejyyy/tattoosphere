<div class="container py-5" style="max-width:620px;">

  <%# Header %>
  <div class="mb-5">
    <%= link_to "← Dashboard", dashboard_path, class: "btn btn-outline-secondary btn-sm mb-3" %>
    <h1 style="font-size:2.5rem;">
      Mon <span class="text-yellow">compte</span>
    </h1>
  </div>

  <%# Erreurs %>
  <% if resource.errors.any? %>
    <div class="alert alert-danger mb-4">
      <% resource.errors.full_messages.each do |msg| %>
        <div>⚠️ <%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
      html: { method: :put }) do |f| %>

    <%# PHOTO DE PROFIL %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Photo de profil
      </h2>

      <div class="d-flex align-items-center gap-4">
        <%# Avatar actuel %>
        <% if resource.avatar.attached? %>
          <%= image_tag resource.avatar,
              style: "width:80px;height:80px;object-fit:cover;border-radius:50%;border:3px solid #F5C500;flex-shrink:0;" %>
        <% else %>
          <div style="width:80px;height:80px;border-radius:50%;background:#0D0D0D;border:3px solid #2A2A2A;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#F5C500;flex-shrink:0;">
            <%= resource.nickname.first.upcase %>
          </div>
        <% end %>

        <div class="flex-grow-1">
          <%= f.label :avatar, "Changer la photo",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.file_field :avatar,
              accept: "image/png,image/jpeg,image/webp",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#888;padding:0.6rem 1rem;font-size:0.85rem;cursor:pointer;" %>
          <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;">PNG, JPG ou WEBP · Max 5MB</p>
        </div>
      </div>
    </div>

    <%# INFOS PERSONNELLES %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Informations personnelles
      </h2>

      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :first_name, "Prénom",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :first_name,
              required: true,
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <%= f.label :last_name, "Nom",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :last_name,
              required: true,
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-12">
          <%= f.label :nickname, "Pseudo",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :nickname,
              required: true,
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <%# À insérer après le champ :nickname et avant le champ :email %>
        <div class="col-12">
        <%= f.label :phone, "Téléphone",
      style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
      <%= f.telephone_field :phone,
      placeholder: "+33 6 00 00 00 00",
      style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
      onfocus: "this.style.borderColor='#F5C500'",
      onblur:  "this.style.borderColor='#2A2A2A'" %>
</div>
        <div class="col-12">
          <%= f.label :email, "Email",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.email_field :email,
              required: true,
              autocomplete: "email",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <p style="font-size:0.8rem;color:#F5C500;margin-top:0.4rem;">
              ⏳ En attente de confirmation : <%= resource.unconfirmed_email %>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <%# MOT DE PASSE %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">
        Mot de passe
      </h2>
      <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">
        Laisse vide si tu ne souhaites pas le modifier.
      </p>

      <div class="row g-3">
        <div class="col-12">
          <%= f.label :password, "Nouveau mot de passe",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.password_field :password,
              autocomplete: "new-password",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
          <% if @minimum_password_length %>
            <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;"><%= @minimum_password_length %> caractères minimum</p>
          <% end %>
        </div>
        <div class="col-12">
          <%= f.label :password_confirmation, "Confirmer le nouveau mot de passe",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>
    </div>

    <%# SUBMIT %>
    <%= f.submit "Enregistrer les modifications",
        style: "width:100%;background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:0.1em;padding:1rem;cursor:pointer;text-transform:uppercase;transition:background 0.2s;",
        onmouseover: "this.style.background='#d4a800'",
        onmouseout:  "this.style.background='#F5C500'" %>

  <% end %>

  <%# SUPPRIMER LE COMPTE %>
  <div style="border-top:1px solid #2A2A2A;margin-top:3rem;padding-top:2rem;">
    <p class="text-secondary" style="font-size:0.85rem;margin-bottom:1rem;">
      ⚠️ La suppression de votre compte est irréversible.
    </p>
    <%= button_to "Supprimer mon compte",
        registration_path(resource_name),
        data: { turbo_confirm: "Êtes-vous sûr ? Cette action est irréversible." },
        method: :delete,
        style: "background:transparent;border:1px solid #C0392B;color:#C0392B;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:0.08em;padding:0.6rem 1.5rem;cursor:pointer;text-transform:uppercase;transition:all 0.2s;",
        onmouseover: "this.style.background='rgba(192,57,43,0.15)'",
        onmouseout:  "this.style.background='transparent'" %>
  </div>

</div>