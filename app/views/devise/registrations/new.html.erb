<div class="container py-5" style="max-width: 480px;">
  <h1 class="h3 mb-4">Créer un compte</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

    <%# Erreurs %>
    <% if resource.errors.any? %>
      <div class="alert alert-danger mb-4">
        <ul class="mb-0 ps-3">
          <% resource.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="row g-3">

      <div class="col-md-6">
        <%= f.label :first_name, "Prénom", class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control", required: true, autofocus: true %>
      </div>

      <div class="col-md-6">
        <%= f.label :last_name, "Nom", class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control", required: true %>
      </div>

      <div class="col-12">
        <%= f.label :nickname, "Pseudo", class: "form-label" %>
        <%= f.text_field :nickname, class: "form-control", required: true %>
        <div class="form-text text-secondary">Visible publiquement sur la plateforme</div>
      </div>

      <div class="col-12">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true, autocomplete: "email" %>
      </div>

      <div class="col-12">
        <%= f.label :password, "Mot de passe", class: "form-label" %>
        <%= f.password_field :password, class: "form-control",
            required: true, autocomplete: "new-password" %>
        <div class="form-text text-secondary">6 caractères minimum</div>
      </div>

      <div class="col-12">
        <%= f.label :password_confirmation, "Confirmation du mot de passe", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control",
            required: true, autocomplete: "new-password" %>
      </div>

      <div class="col-12 mt-2">
        <%= f.submit "S'inscrire", class: "btn btn-warning w-100 fw-bold" %>
      </div>

    </div>
  <% end %>

  <div class="text-center mt-4">
    <span class="text-secondary small">Déjà un compte ?</span>
    <%= link_to "Se connecter", new_user_session_path, class: "text-warning small ms-1" %>
  </div>
</div>