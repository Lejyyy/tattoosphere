<% content_for :title, "Explorer" %>

<%# ================================ %>
<%# LIGHTBOX %>
<%# ================================ %>
<div id="lightbox"
     onclick="if(event.target===this) closeLightbox()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.95);
            z-index:9999;align-items:center;justify-content:center;flex-direction:column;">

  <button onclick="shiftLightbox(-1)"
          style="position:fixed;left:1.5rem;top:50%;transform:translateY(-50%);
                 background:none;border:none;color:#fff;font-size:3rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">&#8249;</button>

  <button onclick="shiftLightbox(1)"
          style="position:fixed;right:1.5rem;top:50%;transform:translateY(-50%);
                 background:none;border:none;color:#fff;font-size:3rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">&#8250;</button>

  <button onclick="closeLightbox()"
          style="position:fixed;top:1.25rem;right:1.5rem;background:none;border:none;
                 color:#fff;font-size:1.75rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">✕</button>

  <img id="lightbox-img"
       style="max-width:88vw;max-height:80vh;object-fit:contain;
              box-shadow:0 0 80px rgba(0,0,0,0.9);" src="" alt="">

  <div id="lightbox-info"
       style="margin-top:1.25rem;display:flex;align-items:center;gap:1rem;">
    <img id="lightbox-avatar"
         style="width:40px;height:40px;object-fit:cover;border:2px solid #F5C500;"
         src="" alt="">
    <div>
      <div id="lightbox-name"
           style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;
                  color:#fff;letter-spacing:0.05em;"></div>
      <div id="lightbox-styles" style="font-size:0.8rem;color:#888;"></div>
    </div>
    <a id="lightbox-link" href="#"
       style="margin-left:1rem;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;
              color:#F5C500;text-decoration:none;border:1px solid #F5C500;
              padding:0.3rem 0.8rem;letter-spacing:0.05em;"
       onmouseover="this.style.background='#F5C500';this.style.color='#000'"
       onmouseout="this.style.background='transparent';this.style.color='#F5C500'">
      Voir le profil →
    </a>
  </div>

  <div id="lightbox-caption"
       style="margin-top:0.5rem;color:#555;font-family:'Barlow Condensed',sans-serif;
              font-size:0.85rem;letter-spacing:0.05em;"></div>
</div>

<%# ================================ %>
<%# EN-TÊTE %>
<%# ================================ %>
<section class="section pb-0">
  <div class="container">
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:3.5rem;
               letter-spacing:0.05em;margin-bottom:0.25rem;">
      Explorer les <span style="color:#F5C500;">réalisations</span>
    </h1>
    <p style="color:#888;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;">
      <%= @realisations.count %> réalisation<%= @realisations.count > 1 ? "s" : "" %>
    </p>
  </div>
</section>

<%# ================================ %>
<%# FILTRES %>
<%# ================================ %>
<section class="section pb-0">
  <div class="container">
    <%= form_with url: explore_path, method: :get,
                  html: { style: "display:flex;flex-wrap:wrap;gap:0.75rem;align-items:flex-end;" } do |f| %>

      <div style="flex:1;min-width:160px;">
        <label style="display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;
                      letter-spacing:0.08em;color:#888;margin-bottom:0.4rem;">Style</label>
        <%= f.select :style_id,
            options_for_select([["Tous les styles", ""]] + @tattoo_styles.map { |s| [s.name, s.id] }, params[:style_id]),
            {},
            style: "width:100%;background:#1A1A1A;border:1px solid #2A2A2A;color:#fff;
                    padding:0.7rem 1rem;font-family:'Barlow Condensed',sans-serif;
                    font-size:1rem;outline:none;cursor:pointer;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>

      <div style="flex:1;min-width:160px;">
        <label style="display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;
                      letter-spacing:0.08em;color:#888;margin-bottom:0.4rem;">Ville</label>
        <%= f.text_field :city,
            value: params[:city],
            placeholder: "Paris, Lyon…",
            style: "width:100%;background:#1A1A1A;border:1px solid #2A2A2A;color:#fff;
                    padding:0.7rem 1rem;font-family:'Barlow Condensed',sans-serif;
                    font-size:1rem;outline:none;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>

      <div>
        <label style="display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;
                      letter-spacing:0.08em;color:#888;margin-bottom:0.4rem;">Localisation</label>
        <button type="button" onclick="useMyLocation()"
                style="background:<%= params[:near].present? ? '#F5C500' : 'transparent' %>;
                       color:<%= params[:near].present? ? '#000' : '#F5C500' %>;
                       border:1px solid #F5C500;font-family:'Bebas Neue',sans-serif;
                       font-size:1rem;letter-spacing:0.05em;padding:0.7rem 1.25rem;
                       cursor:pointer;white-space:nowrap;">
          📍 Autour de moi
        </button>
        <%= f.hidden_field :near, value: params[:near] %>
        <%= f.hidden_field :distance, value: params[:distance] || 5 %>
      </div>

      <div>
        <label style="display:block;font-size:0.75rem;color:transparent;margin-bottom:0.4rem;">.</label>
        <%= f.submit "Rechercher",
            style: "background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;
                    font-size:1.1rem;letter-spacing:0.1em;padding:0.7rem 1.75rem;cursor:pointer;",
            onmouseover: "this.style.background='#d4a800'",
            onmouseout:  "this.style.background='#F5C500'" %>
      </div>

      <% if params.except("controller", "action").to_unsafe_h.any? %>
        <div>
          <label style="display:block;font-size:0.75rem;color:transparent;margin-bottom:0.4rem;">.</label>
          <%= link_to "✕ Réinitialiser", explore_path,
              style: "display:inline-block;padding:0.7rem 1rem;border:1px solid #444;
                      color:#888;font-family:'Bebas Neue',sans-serif;font-size:1rem;
                      letter-spacing:0.05em;text-decoration:none;" %>
        </div>
      <% end %>

    <% end %>
  </div>
</section>

<%# ================================ %>
<%# GRILLE %>
<%# ================================ %>
<section class="section">
  <div class="container">
    <% if @realisations.any? %>

      <div class="explore-grid">
        <% @realisations.each_with_index do |r, idx| %>
          <div style="position:relative;overflow:hidden;cursor:pointer;border-radius:8px;"
               onclick="openLightbox(<%= idx %>)"
               onmouseover="this.querySelector('.explore-overlay').style.opacity='1'"
               onmouseout="this.querySelector('.explore-overlay').style.opacity='0'">

            <%= image_tag r[:image],
                style: "width:100%;height:320px;object-fit:cover;display:block;
                        transition:transform 0.4s;border-radius:8px;",
                onmouseover: "this.style.transform='scale(1.04)'",
                onmouseout:  "this.style.transform='scale(1)'" %>

            <div class="explore-overlay"
                 style="position:absolute;inset:0;border-radius:8px;
                        background:linear-gradient(to top,rgba(0,0,0,0.8) 0%,transparent 55%);
                        opacity:0;transition:opacity 0.25s;pointer-events:none;">
              <div style="position:absolute;bottom:0;left:0;right:0;padding:0.75rem;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:0.95rem;
                            color:#fff;letter-spacing:0.04em;">
                  <%= r[:tatoueur].nickname %>
                </div>
                <% if r[:styles].any? %>
                  <div style="font-size:0.7rem;color:#F5C500;">
                    <%= r[:styles].map(&:name).join(", ") %>
                  </div>
                <% end %>
                <% if r[:price].present? %>
                  <div style="font-family:'Bebas Neue',sans-serif;font-size:0.9rem;color:#F5C500;">
                    <%= number_to_currency(r[:price], unit: "€", format: "%n %u") %>
                  </div>
                <% end %>
              </div>
            </div>

          </div>
        <% end %>
      </div>

      <script>
        const exploreData = <%= raw @realisations.map { |r|
          {
            src:         url_for(r[:image]),
            avatar:      r[:tatoueur].avatar.attached? ? url_for(r[:tatoueur].avatar) : "",
            name:        r[:tatoueur].nickname,
            styles:      r[:styles].map(&:name).join(", "),
            price:       r[:price] ? number_to_currency(r[:price], unit: "€", format: "%n %u") : nil,
            description: r[:description],
            profile:     r[:source_path]
          }
        }.to_json %>
      </script>

    <% else %>
      <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:5rem;text-align:center;">
        <div style="font-size:3rem;margin-bottom:1rem;">🎨</div>
        <p style="color:#888;margin-bottom:1.5rem;">Aucune réalisation trouvée.</p>
        <%= link_to "Réinitialiser les filtres", explore_path,
            style: "color:#F5C500;text-decoration:none;font-family:'Bebas Neue',sans-serif;
                    font-size:1.1rem;letter-spacing:0.05em;" %>
      </div>
    <% end %>
  </div>
</section>

<style>
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
  }
  @media (max-width: 768px) {
    .explore-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .explore-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  let lbIdx = 0

  function openLightbox(idx) {
    lbIdx = idx
    renderLightbox()
    document.getElementById('lightbox').style.display = 'flex'
    document.body.style.overflow = 'hidden'
  }

  function renderLightbox() {
    const d = exploreData[lbIdx]
    document.getElementById('lightbox-img').src      = d.src
    document.getElementById('lightbox-avatar').src   = d.avatar || ''
    document.getElementById('lightbox-avatar').style.display = d.avatar ? 'block' : 'none'
    document.getElementById('lightbox-name').textContent    = d.name
    document.getElementById('lightbox-styles').textContent  = d.styles
    document.getElementById('lightbox-link').href           = d.profile
    document.getElementById('lightbox-caption').textContent =
      [d.description, d.price].filter(Boolean).join(' · ')
  }

  function shiftLightbox(dir) {
    lbIdx = (lbIdx + dir + exploreData.length) % exploreData.length
    renderLightbox()
  }

  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none'
    document.getElementById('lightbox-img').src = ''
    document.body.style.overflow = ''
  }

  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('lightbox')
    if (!lb || lb.style.display === 'none') return
    if (e.key === 'Escape')     closeLightbox()
    if (e.key === 'ArrowRight') shiftLightbox(1)
    if (e.key === 'ArrowLeft')  shiftLightbox(-1)
  })

  function useMyLocation() {
    if (!navigator.geolocation) return alert("Géolocalisation non supportée.")
    navigator.geolocation.getCurrentPosition((pos) => {
      const coords = `${pos.coords.latitude},${pos.coords.longitude}`
      document.querySelector('input[name="near"]').value     = coords
      document.querySelector('input[name="distance"]').value = 5
      document.querySelector('input[name="city"]').value     = ''
      document.querySelector('form').submit()
    }, () => alert("Impossible d'obtenir votre position."))
  }
</script>