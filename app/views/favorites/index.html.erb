<div class="container py-4">
  <h1 class="h4 mb-4">Mes favoris</h1>

  <h2 class="h5">Tatoueurs</h2>
  <% if @favorite_tatoueurs.any? %>
    <% @favorite_tatoueurs.each do |t| %>
      <p><%= link_to t.nickname, tatoueur_path(t) %></p>
    <% end %>
  <% else %>
    <p class="text-secondary">Aucun tatoueur en favori.</p>
  <% end %>

  <h2 class="h5 mt-4">Shops</h2>
  <% if @favorite_shops.any? %>
    <% @favorite_shops.each do |s| %>
      <p><%= link_to s.name, shop_path(s) %></p>
    <% end %>
  <% else %>
    <p class="text-secondary">Aucun shop en favori.</p>
  <% end %>

  <h2 class="h5 mt-4">Portfolios</h2>
  <% if @favorite_portfolios.any? %>
    <% @favorite_portfolios.each do |p| %>
      <p><%= link_to p.name, tatoueur_portfolio_path(p.tatoueur, p) %></p>
    <% end %>
  <% else %>
    <p class="text-secondary">Aucun portfolio en favori.</p>
  <% end %>

  <h2 class="h5 mt-4">Réalisations</h2>
  <% if @favorite_portfolio_items.any? %>
    <% @favorite_portfolio_items.each do |pi| %>
      <p><%= link_to "Réalisation ##{pi.id}", tatoueur_portfolio_portfolio_item_path(pi.portfolio.tatoueur, pi.portfolio, pi) %></p>
    <% end %>
  <% else %>
    <p class="text-secondary">Aucune réalisation en favori.</p>
  <% end %>
</div>