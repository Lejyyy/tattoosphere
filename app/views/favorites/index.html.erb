<div class="container py-5">

  <h1 class="section-title mb-5">Mes favoris</h1>

  <%# ================================ %>
  <%# TATOUEURS %>
  <%# ================================ %>
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;border-left:4px solid #F5C500;padding-left:0.75rem;margin:0;">
        Tatoueurs
        <span style="font-size:1rem;color:#F5C500;margin-left:0.5rem;">(<%= @favorite_tatoueurs.count %>)</span>
      </h2>
      <%= link_to "Explorer →", tatoueurs_path, class: "card-link mb-0" %>
    </div>

    <% if @favorite_tatoueurs.any? %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <% @favorite_tatoueurs.each do |t| %>
          <div class="col" id="favorite-card-tatoueur-<%= t.id %>">
            <div class="card-dark h-100 d-flex flex-column">
              <% if t.avatar.attached? %>
                <%= image_tag t.avatar, style: "width:100%;height:180px;object-fit:cover;" %>
              <% else %>
                <div class="card-img-placeholder" style="height:180px;">🖋️</div>
              <% end %>
              <div class="card-body d-flex flex-column flex-grow-1">
                <div class="card-name mb-1"><%= t.nickname %></div>
                <p class="card-meta mb-2">
                  <%= t.tattoo_styles.map(&:name).join(", ").presence || "Style non renseigné" %>
                </p>
                <% if t.address.present? %>
                  <p class="card-meta mb-0">📍 <%= t.address.split(",").first %></p>
                <% end %>
                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                  <%= link_to "Voir le profil →", tatoueur_path(t), class: "card-link mb-0" %>
                  <%= render "favorites/button", favoritable: t %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;text-align:center;">
        <p class="text-secondary mb-2">Aucun tatoueur en favori.</p>
        <%= link_to "Découvrir des tatoueurs →", tatoueurs_path, class: "card-link" %>
      </div>
    <% end %>
  </div>

  <%# ================================ %>
  <%# SHOPS %>
  <%# ================================ %>
  <div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;border-left:4px solid #F5C500;padding-left:0.75rem;margin:0;">
        Shops
        <span style="font-size:1rem;color:#F5C500;margin-left:0.5rem;">(<%= @favorite_shops.count %>)</span>
      </h2>
      <%= link_to "Explorer →", shops_path, class: "card-link mb-0" %>
    </div>

    <% if @favorite_shops.any? %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% @favorite_shops.each do |s| %>
          <div class="col" id="favorite-card-shop-<%= s.id %>">
            <div class="card-dark h-100 d-flex flex-column">
              <% if s.cover.attached? %>
                <%= image_tag s.cover, style: "width:100%;height:180px;object-fit:cover;" %>
              <% else %>
                <div class="card-img-placeholder" style="height:180px;">🏠</div>
              <% end %>
              <div class="card-body d-flex flex-column flex-grow-1">
                <div class="card-name mb-1"><%= s.name %></div>
                <% if s.address.present? %>
                  <p class="card-meta mb-2">📍 <%= s.address %></p>
                <% end %>
                <p class="card-meta mb-0">🖋️ <%= s.tatoueurs.count %> tatoueur(s)</p>
                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                  <%= link_to "Voir le shop →", shop_path(s), class: "card-link mb-0" %>
                  <%= render "favorites/button", favoritable: s %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;text-align:center;">
        <p class="text-secondary mb-2">Aucun shop en favori.</p>
        <%= link_to "Découvrir des shops →", shops_path, class: "card-link" %>
      </div>
    <% end %>
  </div>

  <%# ================================ %>
  <%# PORTFOLIOS %>
  <%# ================================ %>
  <% if @favorite_portfolios.any? %>
    <div class="mb-5">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Portfolios
        <span style="font-size:1rem;color:#F5C500;margin-left:0.5rem;">(<%= @favorite_portfolios.count %>)</span>
      </h2>
      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% @favorite_portfolios.each do |p| %>
          <div class="col">
            <div class="card-dark h-100 d-flex flex-column">
              <div class="card-img-placeholder" style="height:140px;">🖼️</div>
              <div class="card-body d-flex flex-column flex-grow-1">
                <div class="card-name mb-1"><%= p.name %></div>
                <p class="card-meta mb-0"><%= p.portfolio_items.count %> réalisation(s)</p>
                <div class="mt-auto pt-3 d-flex justify-content-between align-items-center">
                  <%= link_to "Voir →", tatoueur_portfolio_path(p.tatoueur, p), class: "card-link mb-0" %>
                  <%= render "favorites/button", favoritable: p %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ================================ %>
  <%# RÉALISATIONS %>
  <%# ================================ %>
  <% if @favorite_portfolio_items.any? %>
    <div class="mb-5">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#fff;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Réalisations
        <span style="font-size:1rem;color:#F5C500;margin-left:0.5rem;">(<%= @favorite_portfolio_items.count %>)</span>
      </h2>
      <div class="row row-cols-2 row-cols-md-4 g-3">
        <% @favorite_portfolio_items.each do |pi| %>
          <div class="col">
            <div class="card-dark h-100">
              <div class="card-img-placeholder" style="height:160px;">🎨</div>
              <div class="card-body">
                <p class="card-meta mb-2">Par <%= pi.portfolio.tatoueur.nickname %></p>
                <div class="d-flex justify-content-between align-items-center">
                  <%= link_to "Voir →",
                      tatoueur_portfolio_portfolio_item_path(pi.portfolio.tatoueur, pi.portfolio, pi),
                      class: "card-link mb-0" %>
                  <%= render "favorites/button", favoritable: pi %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>