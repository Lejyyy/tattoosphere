<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin — Tattoosphere</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <div style="display:flex;min-height:100vh;">

      <%# SIDEBAR %>
      <aside style="width:240px;background:#111;border-right:2px solid #F5C500;padding:2rem 1rem;flex-shrink:0;">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:#F5C500;margin-bottom:2rem;">
          ADMIN
          <div style="font-size:0.9rem;color:#888;font-family:'Barlow Condensed',sans-serif;">Tattoosphere</div>
        </div>

        <nav class="d-flex flex-column gap-2">
          <%= link_to "📊 Dashboard", admin_root_path,
              style: "color:#fff;padding:0.5rem 1rem;text-transform:uppercase;letter-spacing:0.05em;font-size:0.9rem;#{'background:#1A1A1A;color:#F5C500;' if current_page?(admin_root_path)}" %>
          <%= link_to "👥 Utilisateurs", admin_users_path,
              style: "color:#fff;padding:0.5rem 1rem;text-transform:uppercase;letter-spacing:0.05em;font-size:0.9rem;#{'background:#1A1A1A;color:#F5C500;' if request.path.start_with?('/admin/users')}" %>
          <%= link_to "🖋️ Tatoueurs", admin_tatoueurs_path,
              style: "color:#fff;padding:0.5rem 1rem;text-transform:uppercase;letter-spacing:0.05em;font-size:0.9rem;#{'background:#1A1A1A;color:#F5C500;' if request.path.start_with?('/admin/tatoueurs')}" %>
          <%= link_to "🏠 Shops", admin_shops_path,
              style: "color:#fff;padding:0.5rem 1rem;text-transform:uppercase;letter-spacing:0.05em;font-size:0.9rem;#{'background:#1A1A1A;color:#F5C500;' if request.path.start_with?('/admin/shops')}" %>
        </nav>

        <div style="position:absolute;bottom:2rem;">
          <%= link_to "← App", root_path, style: "color:#888;font-size:0.85rem;" %>
        </div>
      </aside>

      <%# CONTENU %>
      <main style="flex:1;padding:2rem;overflow-y:auto;">
        <% flash.each do |type, message| %>
          <% css = { "notice" => "alert-success", "alert" => "alert-danger" }[type] || "alert-info" %>
          <div class="alert <%= css %> alert-dismissible fade show mb-4">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        <%= yield %>
      </main>

    </div>
  </body>
</html>