<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) : "Admin — Tattoosphere" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_importmap_tags %>
</head>
<body style="background:#0D0D0D;color:#fff;min-height:100vh;margin:0;">

  <%# ── Sidebar ── %>
  <div style="display:flex;min-height:100vh;">
    <aside style="width:220px;background:#111;border-right:1px solid #2A2A2A;
                  display:flex;flex-direction:column;flex-shrink:0;position:fixed;
                  top:0;bottom:0;left:0;overflow-y:auto;">

      <div style="padding:1.5rem 1.25rem;border-bottom:1px solid #2A2A2A;">
        <%= link_to admin_root_path, style: "text-decoration:none;" do %>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:0.05em;">
            <span style="color:#fff;">Tattoo</span><span style="color:#F5C500;">sphere</span>
          </div>
          <div style="font-size:0.7rem;color:#555;text-transform:uppercase;letter-spacing:0.1em;">
            Admin
          </div>
        <% end %>
      </div>

      <nav style="padding:1rem 0;flex:1;">
        <% nav_items = [
          ["🏠", "Dashboard",    admin_root_path],
          ["👥", "Utilisateurs", admin_users_path],
          ["🖋️", "Tatoueurs",   admin_tatoueurs_path],
          ["🏠", "Shops",        admin_shops_path],
          ["🎪", "Événements",   admin_events_path],
          ["🚨", "Signalements", admin_reports_path],
          ["🎨", "Styles",       admin_tattoo_styles_path],
          ["📋", "Logs",         admin_admin_logs_path],
        ] %>
        <% nav_items.each do |icon, label, path| %>
          <% active = request.path.start_with?(path) && path != admin_root_path ||
                      request.path == path %>
          <%= link_to path,
              style: "display:flex;align-items:center;gap:0.75rem;padding:0.65rem 1.25rem;
                      text-decoration:none;font-family:'Barlow Condensed',sans-serif;
                      font-size:1rem;letter-spacing:0.03em;transition:all 0.15s;
                      color:#{active ? '#F5C500' : '#888'};
                      background:#{active ? 'rgba(245,197,0,0.08)' : 'transparent'};
                      border-left:#{active ? '3px solid #F5C500' : '3px solid transparent'};" do %>
            <span><%= icon %></span>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </nav>

      <div style="padding:1rem 1.25rem;border-top:1px solid #2A2A2A;">
        <%= link_to root_path,
            style: "display:block;font-size:0.8rem;color:#555;text-decoration:none;margin-bottom:0.5rem;" do %>
          ← Retour au site
        <% end %>
        <div style="font-size:0.75rem;color:#333;"><%= current_user.email %></div>
      </div>
    </aside>

    <%# ── Contenu principal ── %>
    <main style="margin-left:220px;flex:1;padding:2rem;">

      <%# Flash %>
      <% flash.each do |type, msg| %>
        <% color = type == "notice" ? "#27AE60" : "#E74C3C" %>
        <div style="background:rgba(<%= type == 'notice' ? '39,174,96' : '231,76,60' %>,0.1);
                    border:1px solid <%= color %>;color:<%= color %>;
                    padding:0.75rem 1.25rem;margin-bottom:1.5rem;font-size:0.9rem;">
          <%= msg %>
        </div>
      <% end %>

      <%# Breadcrumb %>
      <div style="font-size:0.75rem;color:#555;margin-bottom:1.5rem;
                  text-transform:uppercase;letter-spacing:0.08em;">
        Admin › <%= content_for?(:title) ? yield(:title).gsub("Admin — ", "") : controller_name.humanize %>
      </div>

      <%= yield %>
    </main>
  </div>

</body>
</html>