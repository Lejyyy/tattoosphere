<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>Admin — Tattoosphere</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </head>
  <body>

    <%# TOPBAR %>
    <nav class="navbar navbar-expand-lg sticky-top border-bottom border-warning">
      <div class="container-fluid px-4">
        <%= link_to "Tattoosphere", root_path, class: "navbar-brand fw-bold text-warning" %>
        <span class="badge bg-warning text-dark ms-2">Admin</span>
        <div class="ms-auto d-flex align-items-center gap-3">
          <span class="text-secondary small"><%= current_user.first_name %> <%= current_user.last_name %></span>
          <%= link_to "Retour au site", root_path, class: "btn btn-outline-secondary btn-sm" %>
          <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-warning btn-sm" %>
        </div>
      </div>
    </nav>

    <div class="d-flex" style="min-height: calc(100vh - 56px)">

      <%# SIDEBAR %>
      <aside class="border-end border-secondary p-3" style="width: 220px; min-width: 220px;">
        <ul class="nav flex-column gap-1">
          <li class="nav-item">
            <%= link_to admin_root_path, class: "nav-link text-secondary #{"text-warning fw-bold" if controller_name == "dashboard"}" do %>
              Dashboard
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to admin_verifications_path, class: "nav-link text-secondary #{"text-warning fw-bold" if controller_name == "verifications"}" do %>
              Vérifications
              <% pending_count = Tatoueur.where(verification_status: "pending").count %>
              <% if pending_count > 0 %>
                <span class="badge bg-warning text-dark ms-1"><%= pending_count %></span>
              <% end %>
            <% end %>
          </li>
        </ul>
      </aside>

      <%# CONTENU %>
      <main class="flex-grow-1 p-4">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        <%= yield %>
      </main>

    </div>

  </body>
</html>