<%= link_to "← Retour", admin_shops_path, class: "btn btn-outline-secondary btn-sm mb-4" %>

<h1 style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#F5C500;">
  <%= @shop.name %>
  <span class="badge <%= @shop.is_active ? 'bg-success' : 'bg-danger' %> ms-2" style="font-size:1rem;">
    <%= @shop.is_active ? "Actif" : "Inactif" %>
  </span>
</h1>

<div class="row g-4 mt-2">

  <div class="col-md-6">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 class="section-title mb-3">Informations</h3>
      <p><span class="text-secondary">Email :</span> <%= @shop.email %></p>
      <p><span class="text-secondary">Téléphone :</span> <%= @shop.phone || "Non renseigné" %></p>
      <p><span class="text-secondary">Adresse :</span> <%= @shop.address || "Non renseignée" %></p>
      <p><span class="text-secondary">Tatoueurs :</span> <%= @shop.tatoueurs.count %></p>
      <p><span class="text-secondary">Réservations :</span> <%= @shop.bookings.count %></p>
    </div>
  </div>

  <div class="col-md-6">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 class="section-title mb-3">Actions</h3>
      <div class="d-flex gap-3">
        <% if @shop.is_active %>
          <%= button_to "🔴 Désactiver",
              admin_shop_path(@shop, action_type: "deactivate"),
              method: :patch,
              class: "btn btn-outline-danger",
              data: { turbo_confirm: "Désactiver ce shop ?" } %>
        <% else %>
          <%= button_to "🟢 Activer",
              admin_shop_path(@shop, action_type: "activate"),
              method: :patch,
              class: "btn btn-outline-success" %>
        <% end %>
        <%= link_to "Voir la page publique →", shop_path(@shop), target: "_blank", class: "card-link" %>
      </div>
    </div>
  </div>

</div>