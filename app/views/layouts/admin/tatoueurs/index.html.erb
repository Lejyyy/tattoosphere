<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 style="font-family:'Bebas Neue',sans-serif;font-size:3rem;color:#F5C500;">Tatoueurs</h1>
  <div class="d-flex gap-2">
    <%= link_to "Tous", admin_tatoueurs_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "En attente", admin_tatoueurs_path(status: "pending"), class: "btn btn-outline-warning btn-sm" %>
    <%= link_to "Approuvés", admin_tatoueurs_path(status: "approved"), class: "btn btn-outline-success btn-sm" %>
    <%= link_to "Refusés", admin_tatoueurs_path(status: "rejected"), class: "btn btn-outline-danger btn-sm" %>
  </div>
</div>

<div class="table-responsive">
  <table class="table" style="color:#fff;">
    <thead style="border-bottom:2px solid #F5C500;">
      <tr>
        <th>Nickname</th>
        <th>Email</th>
        <th>Statut vérification</th>
        <th>Actif</th>
        <th>Inscrit le</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tatoueurs.each do |t| %>
        <tr style="border-bottom:1px solid #2A2A2A;">
          <td><%= t.nickname %></td>
          <td class="text-secondary"><%= t.email %></td>
          <td>
            <% color = { "pending" => "bg-warning", "approved" => "bg-success", "rejected" => "bg-danger", "unsubmitted" => "bg-secondary" }[t.verification_status] %>
            <span class="badge <%= color %>"><%= t.verification_status %></span>
          </td>
          <td>
            <span class="badge <%= t.is_active ? 'bg-success' : 'bg-danger' %>">
              <%= t.is_active ? "Actif" : "Inactif" %>
            </span>
          </td>
          <td class="text-secondary"><%= t.created_at.strftime("%d/%m/%Y") %></td>
          <td><%= link_to "Examiner →", admin_tatoueur_path(t), class: "card-link" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>