<h1 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#F5C500;">
  Modifier <%= @user.nickname %>
</h1>

<div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;max-width:500px;margin-top:2rem;">
  <%= form_with model: [:admin, @user] do |f| %>

    <div class="mb-3">
      <%= f.label :nickname, "Nickname", class: "form-label" %>
      <%= f.text_field :nickname, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :email, "Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :role, "Rôle", class: "form-label" %>
      <%= f.select :role, User::ROLES, {}, class: "form-select" %>
    </div>

    <div class="mb-4">
      <%= f.label :is_active, "Compte actif", class: "form-label" %>
      <%= f.select :is_active, [["Oui", true], ["Non", false]], {}, class: "form-select" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Enregistrer", class: "hero-cta" %>
      <%= link_to "Annuler", admin_users_path, class: "btn btn-outline-secondary" %>
    </div>

  <% end %>
</div>