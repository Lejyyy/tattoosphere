<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Tattoosphere</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    
  </head>

  <body>
    <%# NAVBAR %>
    <nav class="navbar navbar-expand-lg sticky-top">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand" do %>
          TATTOO<span>SPHERE</span>
        <% end %>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
            <li class="nav-item">
              <%= link_to "Tatoueurs", tatoueurs_path, class: "nav-link #{'active' if current_page?(tatoueurs_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Shops", shops_path, class: "nav-link #{'active' if current_page?(shops_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Événements", events_path, class: "nav-link #{'active' if current_page?(events_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Carte", map_path, class: "nav-link #{'active' if current_page?(map_path)}" %>
            </li>

            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "Mes réservations", bookings_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Messages", conversations_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Favoris", favorites_path, class: "nav-link" %>
              </li>
              <li class="nav-item ms-lg-2">
                <%= link_to "Dashboard", dashboard_path, class: "hero-cta" %>
              </li>
              <li class="nav-item ms-lg-2">
                <%= link_to "Déconnexion", destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "btn btn-outline-primary btn-sm" %>
              </li>
            <% else %>
              <li class="nav-item ms-lg-2">
                <%= link_to "Connexion", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
              </li>
              <li class="nav-item ms-lg-2">
                <%= link_to "Inscription", new_user_registration_path, class: "hero-cta" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# FLASH MESSAGES %>
    <div class="container mt-3">
      <% flash.each do |type, message| %>
        <% css_class = { "notice" => "alert-success", "alert" => "alert-danger", "warning" => "alert-warning" }[type] || "alert-info" %>
        <div class="alert <%= css_class %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    </div>

    <%# CONTENU PRINCIPAL %>
    <main>
      <%= yield %>
    </main>

    <%# FOOTER %>
    <footer class="footer mt-5">
      <div class="container">
        <p class="mb-1">
          <%= link_to "Tatoueurs", tatoueurs_path %> &bull;
          <%= link_to "Shops", shops_path %> &bull;
          <%= link_to "Événements", events_path %>
        </p>
        <p class="mb-0">&copy; <%= Date.today.year %> Tattoosphere — Tous droits réservés</p>
      </div>
    </footer>
  </body>
</html>