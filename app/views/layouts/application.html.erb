<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Tattoosphere</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%# NAVBAR %>
    <%= render "layouts/navbar" %>
    <%# FLASH MESSAGES %>
    <div class="container mt-3">
      <% flash.each do |type, message| %>
        <% css_class = { "notice" => "alert-success", "alert" => "alert-danger", "warning" => "alert-warning" }[type] || "alert-info" %>
        <div class="alert <%= css_class %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    </div>
    <%# CONTENU PRINCIPAL %>
    <main>
      <%= yield %>
    </main>
    <%# FOOTER %>
    <%= render "layouts/footer" %>
    <%# CHAT FLOTTANT %>
    <% if user_signed_in? %>
      <%= render "shared/chat_bubble" %>
    <% end %>
    <%= render "shared/share_modal" %>
  </body>
</html>