<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>Tattoosphere</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  </head>

  <body>
    <%# NAVBAR %>
    <nav class="navbar navbar-expand-lg sticky-top">
      <div class="container">
        <%= link_to "Tattoosphere", root_path, class: "navbar-brand" %>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center gap-2">
            <li class="nav-item">
              <%= link_to "Shops", shops_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Tatoueurs", tatoueurs_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Événements", events_path, class: "nav-link" %>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "Mes réservations", bookings_path, class: "nav-link" %>
              </li>
              <li class="nav-item ms-2">
                <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-warning btn-sm px-3" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Connexion", new_user_session_path, class: "nav-link" %>
              </li>
              <li class="nav-item ms-2">
                <%= link_to "Inscription", new_user_registration_path, class: "btn btn-warning btn-sm px-3 text-dark fw-bold" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# FLASH MESSAGES %>
    <% if notice %>
      <div class="container mt-3">
        <div class="flash-notice"><%= notice %></div>
      </div>
    <% end %>
    <% if alert %>
      <div class="container mt-3">
        <div class="flash-alert"><%= alert %></div>
      </div>
    <% end %>

    <%# CONTENU PRINCIPAL %>
    <main>
      <%= yield %>
    </main>

    <%# FOOTER %>
    <footer>
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="footer-brand">Tattoosphere</div>
            <p>Trouve ton artiste, réserve ton tatouage.</p>
          </div>
          <div class="col-md-6 text-md-end">
            <p class="mb-0">© <%= Date.current.year %> Tattoosphere. Tous droits réservés.</p>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>