<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) : "Mon espace — Tattoosphere" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_importmap_tags %>
</head>
<body style="background:#0D0D0D;color:#fff;min-height:100vh;margin:0;">

  <div style="display:flex;min-height:100vh;">

    <%# ── Sidebar ── %>
    <aside style="width:230px;background:#111;border-right:1px solid #2A2A2A;
                  display:flex;flex-direction:column;flex-shrink:0;
                  position:fixed;top:0;bottom:0;left:0;overflow-y:auto;">

      <%# Logo + identité %>
      <div style="padding:1.5rem 1.25rem;border-bottom:1px solid #2A2A2A;">
        <%= link_to tatoueur_panel_root_path, style: "text-decoration:none;" do %>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.05em;">
            <span style="color:#fff;">Tattoo</span><span style="color:#F5C500;">sphere</span>
          </div>
        <% end %>
        <div style="display:flex;align-items:center;gap:0.75rem;margin-top:1rem;">
          <% if current_tatoueur.avatar.attached? %>
            <%= image_tag current_tatoueur.avatar,
                style: "width:36px;height:36px;object-fit:cover;border:2px solid #F5C500;border-radius:50%;" %>
          <% else %>
            <div style="width:36px;height:36px;background:#2A2A2A;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🖋️</div>
          <% end %>
          <div>
            <div style="font-family:'Bebas Neue',sans-serif;font-size:0.95rem;color:#fff;
                        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">
              <%= current_tatoueur.nickname %>
            </div>
            <div style="font-size:0.7rem;color:#555;">
              <% if current_tatoueur.verified? %>
                <span style="color:#27AE60;">✅ Vérifié</span>
              <% else %>
                <span style="color:#E67E22;">⏳ Non vérifié</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%# Navigation %>
      <nav style="padding:1rem 0;flex:1;">
        <% nav = [
          ["🏠", "Dashboard",      tatoueur_panel_root_path],
          ["📅", "Rendez-vous",    tatoueur_panel_bookings_path],
          ["💬", "Messages",       tatoueur_panel_messages_path],
          ["🖼️", "Photos",        tatoueur_panel_photos_path],
          ["🗓️", "Disponibilités", tatoueur_panel_disponibilites_path],
          ["💳", "Paiements",      tatoueur_panel_paiements_path],
          ["📁", "Portfolio",      tatoueur_panel_portfolio_path],
          ["🎪", "Événements",     tatoueur_panel_evenements_path],
          ["⭐", "Avis reçus",     tatoueur_panel_avis_path],
          ["✅", "Vérification",   tatoueur_panel_verification_path],
        ] %>
        <% nav.each do |icon, label, path| %>
          <% active = request.path == path %>
          <%= link_to path,
              style: "display:flex;align-items:center;gap:0.75rem;padding:0.65rem 1.25rem;
                      text-decoration:none;font-family:'Barlow Condensed',sans-serif;
                      font-size:1rem;letter-spacing:0.03em;transition:all 0.15s;
                      color:#{active ? '#F5C500' : '#888'};
                      background:#{active ? 'rgba(245,197,0,0.08)' : 'transparent'};
                      border-left:#{active ? '3px solid #F5C500' : '3px solid transparent'};" do %>
            <span style="width:18px;text-align:center;"><%= icon %></span>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </nav>

      <%# Footer sidebar %>
      <div style="padding:1rem 1.25rem;border-top:1px solid #2A2A2A;">
        <%= link_to tatoueur_path(current_tatoueur),
            style: "display:block;font-size:0.8rem;color:#555;text-decoration:none;margin-bottom:0.4rem;" do %>
          👁️ Voir mon profil public
        <% end %>
        <%= link_to dashboard_path,
            style: "display:block;font-size:0.8rem;color:#555;text-decoration:none;margin-bottom:0.4rem;" do %>
          ← Dashboard général
        <% end %>
        <div style="font-size:0.72rem;color:#333;margin-top:0.5rem;"><%= current_user.email %></div>
      </div>
    </aside>

    <%# ── Contenu ── %>
    <main style="margin-left:230px;flex:1;padding:2rem;">

      <% flash.each do |type, msg| %>
        <% color = type == "notice" ? "#27AE60" : "#E74C3C" %>
        <div style="background:rgba(<%= type == 'notice' ? '39,174,96' : '231,76,60' %>,0.1);
                    border:1px solid <%= color %>;color:<%= color %>;
                    padding:0.75rem 1.25rem;margin-bottom:1.5rem;font-size:0.9rem;">
          <%= msg %>
        </div>
      <% end %>

      <%= yield %>
    </main>

  </div>
</body>
</html>