<%# ================================ %>
<%# TATOUEURS EN VEDETTE %>
<%# ================================ %>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="h4 mb-0">Tatoueurs en vedette</h2>
      <%= link_to "Voir tous →", tatoueurs_path, class: "text-warning text-decoration-none small" %>
    </div>
    <div class="row g-4">
      <% @tatoueurs.each do |tatoueur| %>
        <div class="col-md-3">
          <div class="card border-secondary h-100">
            <%# Avatar %>
            <% if tatoueur.avatar.attached? %>
              <%= image_tag tatoueur.avatar, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
            <% else %>
              <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                <span class="text-muted fs-1"><%= tatoueur.nickname.first.upcase %></span>
              </div>
            <% end %>
            <div class="card-body">
              <div class="d-flex align-items-center gap-2 mb-1">
                <h3 class="h6 mb-0"><%= tatoueur.nickname %></h3>
                <%= render "tatoueurs/verified_badge", tatoueur: tatoueur %>
              </div>
              <p class="text-secondary small mb-2">
                <%= tatoueur.tattoo_styles.map(&:name).join(", ").presence || "Style non renseigné" %>
              </p>
              <% if tatoueur.shops.any? %>
                <p class="text-secondary small mb-0">
                  <%= tatoueur.shops.first.name %>
                </p>
              <% end %>
            </div>
            <div class="card-footer border-secondary">
              <%= link_to "Voir le profil", tatoueur_path(tatoueur), class: "btn btn-outline-warning btn-sm w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================ %>
<%# SHOPS EN VEDETTE %>
<%# ================================ %>
<section class="py-5" style="background-color: #1e1e1e;">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="h4 mb-0">Shops à découvrir</h2>
      <%= link_to "Voir tous →", shops_path, class: "text-warning text-decoration-none small" %>
    </div>
    <div class="row g-4">
      <% @shops.each do |shop| %>
        <div class="col-md-4">
          <div class="card border-secondary h-100">
            <% if shop.cover.attached? %>
              <%= image_tag shop.cover, class: "card-img-top", style: "height: 180px; object-fit: cover;" %>
            <% else %>
              <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 180px;">
                <span class="text-muted small">Pas de photo</span>
              </div>
            <% end %>
            <div class="card-body">
              <h3 class="h6 mb-1"><%= shop.name %></h3>
              <p class="text-secondary small mb-0"><%= shop.address %></p>
            </div>
            <div class="card-footer border-secondary">
              <%= link_to "Voir le shop", shop_path(shop), class: "btn btn-outline-warning btn-sm w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ================================ %>
<%# ÉVÉNEMENTS À VENIR %>
<%# ================================ %>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="h4 mb-0">Événements à venir</h2>
      <%= link_to "Voir tous →", events_path, class: "text-warning text-decoration-none small" %>
    </div>
    <% if @events.any? %>
      <div class="row g-4">
        <% @events.each do |event| %>
          <div class="col-md-4">
            <div class="card border-secondary h-100">
              <% if event.banner.attached? %>
                <%= image_tag event.banner, class: "card-img-top", style: "height: 160px; object-fit: cover;" %>
              <% end %>
              <div class="card-body">
                <h3 class="h6 mb-1"><%= event.name %></h3>
                <p class="text-secondary small mb-1">
                  <%= event.start_date&.strftime("%d/%m/%Y") %>
                  <% if event.location.present? %>
                    — <%= event.location %>
                  <% end %>
                </p>
                <p class="text-secondary small mb-0"><%= event.description&.truncate(80) %></p>
              </div>
              <div class="card-footer border-secondary">
                <%= link_to "En savoir plus", event_path(event), class: "btn btn-outline-warning btn-sm w-100" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-secondary">Aucun événement à venir pour le moment.</p>
    <% end %>
  </div>
</section>