<%# ================================ %>
<%# HERO %>
<%# ================================ %>
<section class="hero">
  <div class="container position-relative">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <h1 class="hero-title">
          Trouve ton
          <span>artiste.</span>
        </h1>
        <p class="hero-subtitle mt-4">
          Explore les meilleurs tatoueurs et shops près de chez toi.
          Réserve en ligne, simplement.
        </p>
        <div class="d-flex gap-3 mt-5">
          <%= link_to "Explorer les tatoueurs", tatoueurs_path, class: "hero-cta" %>
          <% if user_signed_in? %>
            <%= link_to "Mes réservations", bookings_path, class: "hero-cta", style: "background: transparent; color: #c9a84c; border: 1px solid #c9a84c;" %>
          <% else %>
            <%= link_to "Rejoindre la plateforme", new_user_registration_path, class: "hero-cta", style: "background: transparent; color: #c9a84c; border: 1px solid #c9a84c;" %>
          <% end %>
        </div>
      </div>
    </div>
    <div class="hero-decoration">INK</div>
  </div>
</section>

<%# ================================ %>
<%# SEARCH BAR %>
<%# ================================ %>
<section class="search-section py-5">
  <div class="container">
    <%= form_with url: search_path,
                  method: :get,
                  id: "search-form",
                  data: { turbo_frame: "search-results", turbo_action: "advance" } do |f| %>

      <%# Ligne 1 — recherche principale %>
      <div class="row g-2 mb-3">
        <div class="col-md-4">
          <%= f.text_field :query,
              placeholder: "Nom du tatoueur...",
              value: params[:query],
              class: "form-control search-input",
              data: { action: "input->search#submit" } %>
        </div>
        <div class="col-md-4">
          <%= f.text_field :shop_name,
              placeholder: "Nom du shop...",
              value: params[:shop_name],
              class: "form-control search-input",
              data: { action: "input->search#submit" } %>
        </div>
        <div class="col-md-4">
          <%= f.text_field :location,
              placeholder: "Ville ou code postal...",
              value: params[:location],
              class: "form-control search-input",
              data: { action: "input->search#submit" } %>
        </div>
      </div>

      <%# Ligne 2 — filtres avancés %>
      <div class="row g-2 align-items-center">
        <div class="col-md-3">
          <%= f.select :style_id,
              TattooStyle.all.map { |s| [s.name, s.id] },
              { include_blank: "Tous les styles" },
              { class: "form-control search-input",
                data: { action: "change->search#submit" } } %>
        </div>
        <div class="col-md-2">
          <%= f.select :day,
              [["Lundi", 1], ["Mardi", 2], ["Mercredi", 3],
               ["Jeudi", 4], ["Vendredi", 5], ["Samedi", 6], ["Dimanche", 0]],
              { include_blank: "Disponibilité" },
              { class: "form-control search-input",
                data: { action: "change->search#submit" } } %>
        </div>
        <div class="col-md-2">
          <%= f.number_field :price_min,
              placeholder: "Prix min €",
              value: params[:price_min],
              class: "form-control search-input",
              data: { action: "input->search#submit" } %>
        </div>
        <div class="col-md-2">
          <%= f.number_field :price_max,
              placeholder: "Prix max €",
              value: params[:price_max],
              class: "form-control search-input",
              data: { action: "input->search#submit" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Rechercher", class: "btn search-btn w-100" %>
        </div>
        <div class="col-md-1">
          <%= link_to "✕", root_path, class: "btn btn-outline-secondary w-100", title: "Réinitialiser" %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# Résultats de recherche (Turbo Frame) %>
<%= turbo_frame_tag "search-results" do %>
  <% if params.slice(:query, :shop_name, :location, :style_id, :day, :price_min, :price_max).any?(&:present?) %>
    <%= render "searches/results", tatoueurs: @tatoueurs, shops: @shops %>
  <% else %>
    <%# Sections normales de la homepage quand pas de recherche %>
    <%= render "pages/home_sections" %>
  <% end %>
<% end %>
