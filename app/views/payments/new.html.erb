<div class="container py-5" style="max-width: 600px;">
  <h1 class="section-title">Payer l'acompte</h1>

  <div class="card-dark p-4 mt-4">
    <p>Réservation avec <strong style="color:#fff;"><%= @booking.tatoueur.nickname %></strong></p>
    <p>Date : <strong style="color:#fff;"><%= @booking.date.strftime("%d/%m/%Y") %></strong></p>

    <div style="border-top:1px solid #2a2a2a;margin:1rem 0;padding-top:1rem;">
      <p style="color:#888;">Acompte à régler</p>
      <p style="font-size:2rem;font-weight:700;color:#c9a84c;margin:0;">
        <%= @booking.deposit_amount %> €
      </p>
    </div>

    <h3 style="color:#fff;font-size:1rem;margin-top:1.5rem;">Choisir un moyen de paiement</h3>

    <%# Virement bancaire %>
    <% if @tatoueur.bank_details_complete? %>
      <%= link_to bank_transfer_booking_payment_path(@booking),
          class: "card-dark d-flex align-items-center gap-3 p-3 mt-3 text-decoration-none" do %>
        <span style="font-size:1.5rem;">🏦</span>
        <div>
          <div style="color:#fff;font-weight:700;">Virement bancaire</div>
          <div style="color:#888;font-size:0.85rem;">Gratuit — Confirmation manuelle par le tatoueur</div>
        </div>
      <% end %>
    <% else %>
      <div class="card-dark p-3 mt-3" style="opacity:0.5;">
        <span style="font-size:1.5rem;">🏦</span>
        <span style="color:#888;margin-left:0.5rem;">Virement bancaire non disponible</span>
      </div>
    <% end %>

    <%= link_to "Annuler", booking_path(@booking), class: "card-link d-block text-center mt-4" %>
  </div>
</div>
