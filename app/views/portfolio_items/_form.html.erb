<%= form_with model: [@tatoueur, @portfolio, portfolio_item],
    html: { enctype: "multipart/form-data" } do |f| %>

  <%# Erreurs %>
  <% if portfolio_item.errors.any? %>
    <div class="alert alert-danger mb-4">
      <% portfolio_item.errors.full_messages.each do |msg| %>
        <div>⚠️ <%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%# PHOTOS %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:2rem;margin-bottom:1.5rem;">
    <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
      Photos
    </h2>

    <%# Aperçu images existantes %>
    <% if portfolio_item.images.attached? %>
      <div class="row g-2 mb-3">
        <% portfolio_item.images.each do |img| %>
          <div class="col-4">
            <%= image_tag img,
                style: "width:100%;height:120px;object-fit:cover;border:1px solid #2A2A2A;" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= f.label :images, "Ajouter des photos",
        style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
    <%= f.file_field :images,
        multiple: true,
        accept: "image/png,image/jpeg,image/webp",
        style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#888;padding:0.6rem 1rem;font-size:0.85rem;cursor:pointer;" %>
    <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;">PNG, JPG ou WEBP · Max 10MB chacune · Plusieurs photos possibles</p>
  </div>

  <%# DESCRIPTION & PRIX %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
    <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
      Détails
    </h2>

    <div class="mb-4">
      <%= f.label :description, "Description",
          style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
      <%= f.text_area :description,
          rows: 4,
          placeholder: "Décris cette réalisation : placement, taille, technique utilisée...",
          style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;resize:vertical;",
          onfocus: "this.style.borderColor='#F5C500'",
          onblur:  "this.style.borderColor='#2A2A2A'" %>
    </div>

    <div>
      <%= f.label :price, "Prix (€)",
          style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
      <div style="position:relative;">
        <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#F5C500;font-family:'Bebas Neue',sans-serif;">€</span>
        <%= f.number_field :price,
            step: 0.01,
            min: 0,
            placeholder: "150.00",
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem 0.85rem 2.5rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>
    </div>
  </div>

  <%# STYLES %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:2rem;">
    <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
      Styles de tatouage
    </h2>
    <div class="d-flex flex-wrap gap-2">
      <% TattooStyle.all.each do |style| %>
        <label style="cursor:pointer;">
          <input type="checkbox"
                 name="portfolio_item[tattoo_style_ids][]"
                 value="<%= style.id %>"
                 <%= portfolio_item.tattoo_style_ids.include?(style.id) ? 'checked' : '' %>
                 style="display:none;"
                 onchange="toggleStyleBtn(this)" />
          <span id="style-btn-<%= style.id %>"
                style="display:inline-block;background:<%= portfolio_item.tattoo_style_ids.include?(style.id) ? '#F5C500' : '#0D0D0D' %>;color:<%= portfolio_item.tattoo_style_ids.include?(style.id) ? '#000' : '#888' %>;border:1px solid <%= portfolio_item.tattoo_style_ids.include?(style.id) ? '#F5C500' : '#2A2A2A' %>;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:0.05em;padding:0.4rem 1rem;transition:all 0.15s;">
            <%= style.name %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <%# SUBMIT %>
  <%= f.submit portfolio_item.persisted? ? "Enregistrer les modifications" : "Ajouter la réalisation",
      style: "width:100%;background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:0.1em;padding:1rem;cursor:pointer;text-transform:uppercase;",
      onmouseover: "this.style.background='#d4a800'",
      onmouseout:  "this.style.background='#F5C500'" %>

<% end %>

<script>
  function toggleStyleBtn(input) {
    const span = input.nextElementSibling
    if (input.checked) {
      span.style.background   = "#F5C500"
      span.style.color        = "#000"
      span.style.borderColor  = "#F5C500"
    } else {
      span.style.background   = "#0D0D0D"
      span.style.color        = "#888"
      span.style.borderColor  = "#2A2A2A"
    }
  }
</script>