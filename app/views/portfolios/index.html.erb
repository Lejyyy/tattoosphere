<div class="container py-5">

  <%# ── En-tête ── %>
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-5">
    <div>
      <%= link_to "← Retour", tatoueur_path(@tatoueur),
          style: "font-size:0.8rem;font-weight:700;text-transform:uppercase;
                  letter-spacing:0.08em;color:#888;text-decoration:none;" %>
      <h1 style="font-family:'Bebas Neue',sans-serif;font-size:3rem;
                 letter-spacing:0.05em;margin-top:1rem;margin-bottom:0.25rem;">
        Portfolios de <span style="color:#F5C500;"><%= @tatoueur.nickname %></span>
      </h1>
      <p style="color:#888;font-family:'Barlow Condensed',sans-serif;font-size:1rem;">
        <%= @portfolios.count %> portfolio<%= @portfolios.count > 1 ? "s" : "" %>
      </p>
    </div>

    <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
      <%= link_to new_tatoueur_portfolio_path(@tatoueur),
          style: "background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;
                  font-size:1.1rem;letter-spacing:0.08em;padding:0.65rem 1.5rem;
                  text-decoration:none;white-space:nowrap;align-self:flex-end;" do %>
        ➕ Nouveau portfolio
      <% end %>
    <% end %>
  </div>

  <%# ── Grille ── %>
  <% if @portfolios.any? %>
    <div class="row g-4">
      <% @portfolios.each do |portfolio| %>
        <div class="col-md-4">
          <%= link_to tatoueur_portfolio_path(@tatoueur, portfolio), style: "text-decoration:none;" do %>
            <div style="background:#1A1A1A;border:1px solid #2A2A2A;transition:border-color 0.2s;overflow:hidden;"
                 onmouseover="this.style.borderColor='#F5C500'"
                 onmouseout="this.style.borderColor='#2A2A2A'">

              <%# Couverture %>
              <% first_item = portfolio.portfolio_items.first %>
              <% if first_item&.images&.attached? %>
                <div style="overflow:hidden;">
                  <%= image_tag first_item.images.first,
                      style: "width:100%;height:220px;object-fit:cover;
                              transition:transform 0.3s;display:block;",
                      onmouseover: "this.style.transform='scale(1.05)'",
                      onmouseout:  "this.style.transform='scale(1)'" %>
                </div>
              <% else %>
                <div style="width:100%;height:220px;background:#111;
                            display:flex;align-items:center;justify-content:center;font-size:3rem;">
                  🖼️
                </div>
              <% end %>

              <%# Infos %>
              <div style="padding:1.25rem;">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;
                            color:#fff;letter-spacing:0.04em;margin-bottom:0.25rem;">
                  <%= portfolio.name %>
                </div>
                <% if portfolio.description.present? %>
                  <p style="color:#888;font-family:'Barlow Condensed',sans-serif;
                             font-size:0.95rem;line-height:1.5;margin-bottom:0.75rem;">
                    <%= portfolio.description.truncate(80) %>
                  </p>
                <% end %>
                <div style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;color:#555;">
                  <%= portfolio.portfolio_items.count %> réalisation<%= portfolio.portfolio_items.count > 1 ? "s" : "" %>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  <% else %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:4rem;text-align:center;">
      <div style="font-size:3rem;margin-bottom:1rem;">🖼️</div>
      <p style="color:#888;margin-bottom:1.5rem;">Aucun portfolio pour le moment.</p>
      <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
        <%= link_to "➕ Créer un portfolio", new_tatoueur_portfolio_path(@tatoueur),
            style: "background:#F5C500;color:#000;font-family:'Bebas Neue',sans-serif;
                    font-size:1.1rem;letter-spacing:0.08em;padding:0.65rem 1.5rem;
                    text-decoration:none;" %>
      <% end %>
    </div>
  <% end %>

</div>