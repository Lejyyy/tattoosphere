<%# Locals attendus : review, show_reply_form (optionnel) %>
<div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:6px;padding:1.25rem;margin-bottom:1rem;">

  <%# Header : auteur + note + date %>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;flex-wrap:wrap;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;">
      <% if review.user.avatar.attached? %>
        <%= image_tag review.user.avatar, style: "width:32px;height:32px;border-radius:50%;object-fit:cover;" %>
      <% else %>
        <div style="width:32px;height:32px;border-radius:50%;background:#2a2a2a;color:#F5C500;
                    display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;">
          <%= review.user.nickname&.first&.upcase %>
        </div>
      <% end %>
      <span style="color:#fff;font-weight:600;font-size:0.9rem;"><%= review.user.nickname %></span>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="color:#F5C500;font-size:1rem;letter-spacing:2px;">
        <%= "★" * review.rating %><span style="color:#2a2a2a;"><%= "★" * (5 - review.rating) %></span>
      </span>
      <span style="color:#555;font-size:0.78rem;"><%= review.created_at.strftime("%d/%m/%Y") %></span>
    </div>
  </div>

  <%# Commentaire %>
  <p style="color:#bbb;font-size:0.9rem;line-height:1.7;margin:0;"><%= review.comment %></p>

  <%# Réponse du tatoueur %>
  <% if review.replied? %>
    <div style="margin-top:1rem;padding:0.75rem 1rem;background:#141414;
                border-left:3px solid #F5C500;border-radius:2px;">
      <p style="color:#888;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">
        Réponse de <%= review.tatoueur.nickname %>
      </p>
      <p style="color:#ccc;font-size:0.88rem;line-height:1.6;margin:0;"><%= review.reply %></p>
    </div>
  <% end %>

  <%# Formulaire de réponse (tatoueur connecté, pas encore répondu) %>
  <% if local_assigns[:show_reply_form] && !review.replied? %>
    <div style="margin-top:1rem;">
      <%= form_with url: reply_review_path(review), method: :patch, local: true do |f| %>
        <%= f.text_area :reply,
              rows: 3,
              placeholder: "Répondre à cet avis...",
              style: "width:100%;background:#141414;border:1px solid #333;border-radius:6px;
                      padding:8px 12px;color:#fff;font-size:0.88rem;resize:vertical;outline:none;" %>
        <%= f.submit "Publier la réponse",
              style: "margin-top:8px;background:#2a2a2a;color:#F5C500;border:1px solid #F5C500;
                      padding:6px 16px;border-radius:4px;font-size:0.8rem;cursor:pointer;" %>
      <% end %>
    </div>
  <% end %>

</div>