<% content_for :title, "Laisser un avis — #{@booking.tatoueur.nickname}" %>

<div class="container py-5" style="max-width:600px;">

  <div class="text-center mb-5">
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:#fff;letter-spacing:1px;">
      Laisser un avis
    </h1>
    <p style="color:#888;">
      Votre expérience avec <strong style="color:#F5C500;"><%= @booking.tatoueur.nickname %></strong>
    </p>
  </div>

  <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:8px;padding:2rem;">

    <%= form_with model: [@booking, @review], url: booking_review_path(@booking), local: true do |f| %>

      <% if @review.errors.any? %>
        <div style="background:#2a1a1a;border:1px solid #dc3545;border-radius:6px;padding:1rem;margin-bottom:1.5rem;">
          <ul style="color:#f08080;font-size:0.9rem;padding-left:1.2rem;margin:0;">
            <% @review.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Étoiles %>
      <div class="mb-4">
        <label style="color:#aaa;font-size:0.85rem;display:block;margin-bottom:8px;">Note</label>
        <div style="display:flex;gap:8px;" id="star-rating">
          <% (1..5).each do |i| %>
            <label style="cursor:pointer;font-size:2rem;color:#2a2a2a;transition:color 0.15s;"
                   data-star="<%= i %>"
                   onmouseover="hoverStars(<%= i %>)"
                   onmouseout="resetStars()"
                   onclick="selectStar(<%= i %>)">★</label>
          <% end %>
        </div>
        <%= f.hidden_field :rating, id: "rating-value", value: @review.rating %>
        <p id="star-label" style="color:#555;font-size:0.8rem;margin-top:6px;"></p>
      </div>

      <%# Commentaire %>
      <div class="mb-4">
        <label style="color:#aaa;font-size:0.85rem;display:block;margin-bottom:4px;">Commentaire</label>
        <%= f.text_area :comment,
              rows: 5,
              placeholder: "Décrivez votre expérience (séance, accueil, résultat...)",
              style: "width:100%;background:#141414;border:1px solid #333;border-radius:6px;
                      padding:10px 14px;color:#fff;font-size:0.9rem;resize:vertical;outline:none;" %>
        <span style="color:#555;font-size:0.78rem;">10 caractères minimum, 1000 maximum.</span>
      </div>

      <%= f.submit "Publier mon avis",
            style: "width:100%;background:#F5C500;color:#000;font-weight:700;font-size:1rem;
                    padding:12px;border:none;border-radius:6px;cursor:pointer;" %>
    <% end %>
  </div>
</div>

<script>
  const labels = ["", "Mauvais", "Décevant", "Correct", "Bien", "Excellent"]
  let selected = <%= @review.rating || 0 %>

  function hoverStars(n) {
    document.querySelectorAll("#star-rating label").forEach((el, i) => {
      el.style.color = i < n ? "#F5C500" : "#2a2a2a"
    })
    document.getElementById("star-label").textContent = labels[n]
  }

  function resetStars() {
    document.querySelectorAll("#star-rating label").forEach((el, i) => {
      el.style.color = i < selected ? "#F5C500" : "#2a2a2a"
    })
    document.getElementById("star-label").textContent = selected ? labels[selected] : ""
  }

  function selectStar(n) {
    selected = n
    document.getElementById("rating-value").value = n
    resetStars()
  }

  // Init si rating déjà sélectionné
  if (selected > 0) resetStars()
</script>
<%# FIN DU FICHIER — ne rien ajouter après cette ligne %>