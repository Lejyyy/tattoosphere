<%
  current_participant = current_user.tatoueur || current_user.shop || current_user
  conv_ids = ConversationParticipant
    .where(participant_type: current_participant.class.name, participant_id: current_participant.id)
    .pluck(:conversation_id)
  bubble_convs = Conversation
    .where(id: conv_ids)
    .preload(:messages, conversation_participants: :participant)
    .order(updated_at: :desc)
    .limit(10)
  total_unread = bubble_convs.sum { |c| c.unread_count_for(current_user) }
%>

<div id="chat-bubble">

  <%# Bouton flottant %>
  <button id="chat-toggle-btn" onclick="toggleChat()">
    <span id="chat-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
    </span>
    <% if total_unread > 0 %>
      <span id="chat-badge"><%= total_unread %></span>
    <% end %>
  </button>

  <%# Fenêtre de chat %>
  <div id="chat-window">
    <div class="chat-header">
      <span class="chat-title">Messages</span>
      <button onclick="toggleChat()" class="chat-close">✕</button>
    </div>
    <div class="chat-body">
      <div class="chat-list" id="chat-list">
        <% if bubble_convs.any? %>
          <% bubble_convs.each do |conv| %>
            <% other = conv.other_participant(current_participant) %>
            <% unread_conv = conv.unread_count_for(current_user) %>
            <% last_msg = conv.messages.max_by(&:created_at) %>
            <% name = other&.try(:nickname) || other&.try(:name) || "#{other&.try(:first_name)}".strip.presence || "Inconnu" %>
            <% avatar_obj = other&.try(:avatar) %>
            <a href="#"
               class="chat-list-item <%= 'chat-list-item--unread' if unread_conv > 0 %>"
               data-conversation-id="<%= conv.id %>"
               onclick="loadConversation(<%= conv.id %>); return false;">
              <div class="chat-list-avatar">
                <% if avatar_obj&.attached? %>
                  <%= image_tag avatar_obj, class: "chat-list-avatar-img" %>
                <% else %>
                  <span class="chat-list-avatar-fallback"><%= name.first.upcase %></span>
                <% end %>
              </div>
              <div class="chat-list-info">
                <div class="chat-list-top">
                  <span class="chat-list-name"><%= name %></span>
                  <span class="chat-list-time"><%= last_msg&.created_at&.strftime("%H:%M") %></span>
                </div>
                <div class="chat-list-preview"><%= last_msg&.content&.truncate(35) || "Aucun message" %></div>
              </div>
              <% if unread_conv > 0 %>
                <span class="chat-list-badge"><%= unread_conv %></span>
              <% end %>
            </a>
          <% end %>
          <a href="<%= conversations_path %>" class="chat-see-all">Voir toutes les conversations →</a>
        <% else %>
          <div class="chat-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <p>Aucune conversation</p>
          </div>
        <% end %>
      </div>

      <div class="chat-convo" id="chat-convo">
        <div class="chat-convo-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          <span>Sélectionnez une conversation</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #chat-bubble { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 1000; }
  #chat-toggle-btn { width: 52px; height: 52px; border-radius: 50%; background: #F5C500; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(0,0,0,.5); position: relative; color: #000; margin-left: auto; }
  #chat-badge { position: absolute; top: -4px; right: -4px; background: #e53e3e; color: #fff; font-size: .65rem; font-weight: 700; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  #chat-window { display: none; flex-direction: column; position: absolute; bottom: 64px; right: 0; width: 640px; height: 480px; background: #111; border: 1px solid #222; border-radius: 12px; box-shadow: 0 12px 48px rgba(0,0,0,.7); overflow: hidden; }
  .chat-header { display: flex; justify-content: space-between; align-items: center; padding: .75rem 1rem; background: #0d0d0d; border-bottom: 1px solid #222; flex-shrink: 0; }
  .chat-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: #F5C500; letter-spacing: .05em; }
  .chat-close { background: transparent; border: none; color: #666; font-size: 1rem; cursor: pointer; line-height: 1; }
  .chat-body { display: flex; flex: 1; overflow: hidden; }
  .chat-list { width: 200px; flex-shrink: 0; border-right: 1px solid #1e1e1e; overflow-y: auto; display: flex; flex-direction: column; }
  .chat-list-item { display: flex; align-items: center; gap: .6rem; padding: .7rem .75rem; border-bottom: 1px solid #1a1a1a; text-decoration: none; transition: background .15s; cursor: pointer; }
  .chat-list-item:hover, .chat-list-item.active { background: #1a1a1a; }
  .chat-list-item--unread { border-left: 2px solid #c8a84b; }
  .chat-list-avatar { flex-shrink: 0; width: 34px; height: 34px; }
  .chat-list-avatar-img { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; }
  .chat-list-avatar-fallback { width: 34px; height: 34px; border-radius: 50%; background: #2a2a2a; color: #F5C500; display: flex; align-items: center; justify-content: center; font-size: .85rem; font-weight: 700; }
  .chat-list-info { flex: 1; min-width: 0; }
  .chat-list-top { display: flex; justify-content: space-between; align-items: baseline; }
  .chat-list-name { font-size: .8rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 80px; }
  .chat-list-time { font-size: .65rem; color: #555; flex-shrink: 0; }
  .chat-list-preview { font-size: .72rem; color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chat-list-badge { background: #F5C500; color: #000; font-size: .6rem; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .chat-see-all { display: block; text-align: center; padding: .6rem; color: #F5C500; font-size: .75rem; text-decoration: none; border-top: 1px solid #1e1e1e; margin-top: auto; }
  .chat-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .5rem; flex: 1; color: #444; padding: 1.5rem; text-align: center; font-size: .8rem; }
  .chat-convo { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  .chat-convo-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .5rem; flex: 1; color: #333; font-size: .8rem; }
  .bubble-messages { flex: 1; overflow-y: auto; padding: .75rem; display: flex; flex-direction: column; gap: .4rem; }
  .bubble-msg { max-width: 80%; padding: .4rem .7rem; border-radius: 10px; font-size: .8rem; line-height: 1.4; word-break: break-word; }
  .bubble-msg--mine { align-self: flex-end; background: #F5C500; color: #000; border-bottom-right-radius: 3px; }
  .bubble-msg--other { align-self: flex-start; background: #1e1e1e; color: #ddd; border-bottom-left-radius: 3px; }
  .bubble-msg-time { font-size: .6rem; opacity: .6; margin-top: .15rem; text-align: right; }
  .bubble-form { display: flex; gap: .5rem; padding: .6rem .75rem; border-top: 1px solid #1e1e1e; flex-shrink: 0; }
  .bubble-input { flex: 1; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; color: #fff; padding: .4rem .6rem; font-size: .8rem; resize: none; outline: none; }
  .bubble-input:focus { border-color: #c8a84b55; }
  .bubble-send { background: #F5C500; border: none; border-radius: 6px; color: #000; padding: .4rem .7rem; font-size: .8rem; font-weight: 700; cursor: pointer; }
</style>

<script>
  if (!window._chatBubbleInitialized) {
  window._chatBubbleInitialized = true

  let chatOpen = false

  function toggleChat() {
    chatOpen = !chatOpen
    const win = document.getElementById("chat-window")
    win.style.display = chatOpen ? "flex" : "none"
  }

  function loadConversation(id) {
    document.querySelectorAll(".chat-list-item").forEach(el => el.classList.remove("active"))
    const activeItem = document.querySelector(`[data-conversation-id="${id}"]`)
    if (activeItem) activeItem.classList.add("active")

    const convo = document.getElementById("chat-convo")
    convo.innerHTML = '<div class="chat-convo-placeholder"><span style="color:#555;font-size:.8rem;">Chargement…</span></div>'

    fetch(`/conversations/${id}/bubble`, {
      headers: { "Accept": "text/html", "X-Requested-With": "XMLHttpRequest" }
    })
    .then(r => r.text())
    .then(html => { convo.innerHTML = html })
    .catch(() => { convo.innerHTML = '<div class="chat-convo-placeholder"><span style="color:#555">Erreur</span></div>' })
  }

  document.addEventListener("click", function(e) {
    const bubble = document.getElementById("chat-bubble")
    if (chatOpen && bubble && !bubble.contains(e.target)) toggleChat()
  })

  } // end _chatBubbleInitialized
</script>