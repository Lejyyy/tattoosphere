<%# Bubble flottante %>
<div id="chat-bubble" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:1000;">

  <%# Bouton %>
  <button onclick="toggleChat()"
          style="width:56px;height:56px;border-radius:50%;background:#C0392B;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.4);position:relative;">
    <span id="chat-icon" style="font-size:1.4rem;">💬</span>
    <% unread = current_user.conversations.includes(:messages).sum { |c| c.unread_count_for(current_user) } %>
    <% if unread > 0 %>
      <span id="chat-badge"
            style="position:absolute;top:-4px;right:-4px;background:#F5C500;color:#000;font-size:0.7rem;font-weight:700;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
        <%= unread %>
      </span>
    <% end %>
  </button>

  <%# Fenêtre de chat %>
  <div id="chat-window"
       style="display:none;position:absolute;bottom:70px;right:0;width:360px;height:500px;background:#1A1A1A;border:1px solid #2A2A2A;box-shadow:0 8px 40px rgba(0,0,0,0.6);display:none;flex-direction:column;overflow:hidden;">

    <%# Header %>
    <div style="background:#111;border-bottom:1px solid #2A2A2A;padding:1rem;display:flex;justify-content:space-between;align-items:center;">
      <span style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F5C500;letter-spacing:0.05em;">Messages</span>
      <button onclick="toggleChat()" style="background:transparent;border:none;color:#888;font-size:1.2rem;cursor:pointer;">✕</button>
    </div>

    <%# Liste conversations %>
    <div id="chat-conversations" style="flex:1;overflow-y:auto;">
      <% convs = current_user.conversations.includes(:messages, :conversation_participants).order("messages.created_at DESC").limit(10) %>
      <% if convs.any? %>
        <% convs.each do |conv| %>
          <% other = conv.other_participant(current_user) %>
          <% unread_conv = conv.unread_count_for(current_user) %>
          <% last_msg = conv.messages.last %>
          <a href="<%= conversation_path(conv) %>"
             style="display:flex;align-items:center;gap:0.75rem;padding:0.875rem 1rem;border-bottom:1px solid #2A2A2A;text-decoration:none;transition:background 0.15s;"
             onmouseover="this.style.background='#222'"
             onmouseout="this.style.background='transparent'">
            <div style="width:40px;height:40px;border-radius:50%;background:#2A2A2A;border:2px solid <%= unread_conv > 0 ? '#F5C500' : '#2A2A2A' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;">
              🖋️
            </div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-family:'Bebas Neue',sans-serif;font-size:0.95rem;color:<%= unread_conv > 0 ? '#F5C500' : '#fff' %>;">
                  <%= other&.try(:nickname) || other&.try(:name) || "Inconnu" %>
                </span>
                <span style="font-size:0.7rem;color:#555;">
                  <%= last_msg&.created_at&.strftime("%H:%M") %>
                </span>
              </div>
              <div style="font-size:0.8rem;color:#666;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                <%= last_msg&.content&.truncate(40) || "Aucun message" %>
              </div>
            </div>
            <% if unread_conv > 0 %>
              <span style="background:#F5C500;color:#000;font-size:0.7rem;font-weight:700;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <%= unread_conv %>
              </span>
            <% end %>
          </a>
        <% end %>
        <a href="<%= conversations_path %>"
           style="display:block;text-align:center;padding:0.75rem;color:#F5C500;font-size:0.85rem;font-family:'Bebas Neue',sans-serif;letter-spacing:0.05em;border-top:1px solid #2A2A2A;text-decoration:none;">
          Voir toutes les conversations →
        </a>
      <% else %>
        <div style="padding:2rem;text-align:center;color:#555;">
          <div style="font-size:2rem;margin-bottom:0.5rem;">💬</div>
          <p style="font-size:0.85rem;">Aucune conversation</p>
        </div>
      <% end %>
    </div>

  </div>
</div>

<script>
  let chatOpen = false

  function toggleChat() {
    chatOpen = !chatOpen
    const win  = document.getElementById("chat-window")
    const icon = document.getElementById("chat-icon")
    win.style.display  = chatOpen ? "flex" : "none"
    icon.textContent   = chatOpen ? "✕" : "💬"
  }

  // Fermer en cliquant en dehors
  document.addEventListener("click", function(e) {
    const bubble = document.getElementById("chat-bubble")
    if (chatOpen && bubble && !bubble.contains(e.target)) {
      toggleChat()
    }
  })
</script>