<div class="container py-5" style="max-width:680px;">

  <%# Header %>
  <div class="mb-5">
    <%= link_to "← Retour", shop_path(@shop), class: "btn btn-outline-secondary btn-sm mb-3" %>
    <h1 style="font-size:2.5rem;">
      Modifier <span class="text-yellow"><%= @shop.name %></span>
    </h1>
  </div>

  <%# Erreurs %>
  <% if @shop.errors.any? %>
    <div class="alert alert-danger mb-4">
      <% @shop.errors.full_messages.each do |msg| %>
        <div>⚠️ <%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%# ================================ %>
  <%# FORMULAIRE PRINCIPAL %>
  <%# ================================ %>
  <%= form_with model: @shop, html: { enctype: "multipart/form-data" } do |f| %>

    <%# IDENTITÉ %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">Identité</h2>
      <div class="mb-4">
        <%= f.label :name, "Nom du shop", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_field :name, style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;", onfocus: "this.style.borderColor='#F5C500'", onblur: "this.style.borderColor='#2A2A2A'" %>
      </div>
      <div class="mb-4">
        <%= f.label :description, "Description", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_area :description, rows: 4, placeholder: "Présente ton shop...", style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;resize:vertical;", onfocus: "this.style.borderColor='#F5C500'", onblur: "this.style.borderColor='#2A2A2A'" %>
      </div>
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :email, "Email", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.email_field :email, style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;", onfocus: "this.style.borderColor='#F5C500'", onblur: "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <%= f.label :phone, "Téléphone", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.phone_field :phone, style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;", onfocus: "this.style.borderColor='#F5C500'", onblur: "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>
    </div>

    <%# LOCALISATION %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">Localisation</h2>
      <div>
        <%= f.label :address, "Adresse", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_field :address, placeholder: "1 rue de la Paix, 75001 Paris", style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;", onfocus: "this.style.borderColor='#F5C500'", onblur: "this.style.borderColor='#2A2A2A'" %>
      </div>
    </div>

    <%# HORAIRES %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">Horaires d'ouverture</h2>
      <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">Clique sur un jour pour l'activer, puis définis les horaires.</p>

      <%# Jours de la semaine %>
      <% days = [
        { key: "lun", label: "Lun" },
        { key: "mar", label: "Mar" },
        { key: "mer", label: "Mer" },
        { key: "jeu", label: "Jeu" },
        { key: "ven", label: "Ven" },
        { key: "sam", label: "Sam" },
        { key: "dim", label: "Dim" }
      ] %>

      <%# Parse les horaires existants si présents %>
      <%# Format stocké : "Lun 10:00-19:00,Mar 10:00-19:00" %>
      <% existing = {} %>
      <% if @shop.open_hours.present? %>
        <% @shop.open_hours.split(",").each do |part| %>
          <% parts = part.strip.split(" ") %>
          <% if parts.length == 2 %>
            <% existing[parts[0].downcase] = parts[1] %>
          <% end %>
        <% end %>
      <% end %>

      <%# Boutons jours %>
      <div class="d-flex gap-2 flex-wrap mb-4">
        <% days.each do |day| %>
          <% active = existing.key?(day[:key]) %>
          <button type="button"
                  id="btn-<%= day[:key] %>"
                  onclick="toggleDay('<%= day[:key] %>')"
                  style="background:<%= active ? '#F5C500' : '#0D0D0D' %>;color:<%= active ? '#000' : '#888' %>;border:1px solid <%= active ? '#F5C500' : '#2A2A2A' %>;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:0.05em;padding:0.5rem 1rem;cursor:pointer;transition:all 0.15s;">
            <%= day[:label] %>
          </button>
        <% end %>
      </div>

      <%# Plages horaires par jour %>
      <div id="hours-container" class="d-flex flex-column gap-3">
        <% days.each do |day| %>
          <% active  = existing.key?(day[:key]) %>
          <% times   = existing[day[:key]]&.split("-") || ["10:00", "19:00"] %>
          <div id="hours-<%= day[:key] %>"
               style="display:<%= active ? 'flex' : 'none' %>;align-items:center;gap:1rem;flex-wrap:wrap;">
            <span style="font-family:'Bebas Neue',sans-serif;font-size:1rem;color:#F5C500;min-width:40px;">
              <%= day[:label] %>
            </span>
            <div class="d-flex align-items-center gap-2">
              <input type="time"
                     id="open-<%= day[:key] %>"
                     value="<%= times[0] %>"
                     onchange="updateHours()"
                     style="background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.5rem 0.75rem;font-size:0.95rem;outline:none;color-scheme:dark;" />
              <span style="color:#666;">→</span>
              <input type="time"
                     id="close-<%= day[:key] %>"
                     value="<%= times[1] %>"
                     onchange="updateHours()"
                     style="background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.5rem 0.75rem;font-size:0.95rem;outline:none;color-scheme:dark;" />
            </div>
            <span id="preview-<%= day[:key] %>" style="font-size:0.8rem;color:#888;">
              <%= times[0] %> – <%= times[1] %>
            </span>
          </div>
        <% end %>
      </div>

      <%# Champ caché qui stocke le résultat formaté %>
      <%= f.hidden_field :open_hours, id: "open-hours-hidden", value: @shop.open_hours %>

      <div id="hours-preview" style="margin-top:1.5rem;padding:1rem;background:#0D0D0D;border:1px solid #2A2A2A;font-size:0.85rem;color:#888;min-height:2.5rem;">
        <% if @shop.open_hours.present? %>
          <%= @shop.open_hours %>
        <% else %>
          Aucun jour sélectionné
        <% end %>
      </div>
    </div>

    <script>
      const daysOrder = ["lun","mar","mer","jeu","ven","sam","dim"]
      const activeDays = new Set(<%= existing.keys.to_json %>)

      function toggleDay(key) {
        const btn = document.getElementById(`btn-${key}`)
        const row = document.getElementById(`hours-${key}`)
        if (activeDays.has(key)) {
          activeDays.delete(key)
          btn.style.background   = "#0D0D0D"
          btn.style.color        = "#888"
          btn.style.borderColor  = "#2A2A2A"
          row.style.display      = "none"
        } else {
          activeDays.add(key)
          btn.style.background   = "#F5C500"
          btn.style.color        = "#000"
          btn.style.borderColor  = "#F5C500"
          row.style.display      = "flex"
        }
        updateHours()
      }

      function updateHours() {
        const parts = []
        daysOrder.forEach(key => {
          if (!activeDays.has(key)) return
          const open  = document.getElementById(`open-${key}`)?.value  || "10:00"
          const close = document.getElementById(`close-${key}`)?.value || "19:00"
          const label = key.charAt(0).toUpperCase() + key.slice(1)
          parts.push(`${label} ${open}-${close}`)
          const preview = document.getElementById(`preview-${key}`)
          if (preview) preview.textContent = `${open} – ${close}`
        })
        const result = parts.join(", ")
        document.getElementById("open-hours-hidden").value = result
        document.getElementById("hours-preview").textContent = result || "Aucun jour sélectionné"
      }
    </script>

<%# PHOTOS %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">Photos</h2>
      <div class="mb-4">
        <%= f.label :cover, "Photo de profil", style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <% if @shop.cover.attached? %>
          <div class="mb-2">
            <%= image_tag @shop.cover, style: "width:100%;height:160px;object-fit:cover;border:1px solid #2A2A2A;" %>
          </div>
        <% end %>
        <%= f.file_field :cover, accept: "image/png,image/jpeg,image/webp", style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#888;padding:0.6rem 1rem;font-size:0.85rem;cursor:pointer;" %>
        <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;">PNG, JPG ou WEBP · Max 5MB</p>
      </div>
      <div>
    </div>

    <%# SUBMIT %>
    <%= f.submit "Enregistrer les modifications",
        style: "width:100%;background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:0.1em;padding:1rem;cursor:pointer;text-transform:uppercase;",
        onmouseover: "this.style.background='#d4a800'",
        onmouseout:  "this.style.background='#F5C500'" %>
  <% end %>
