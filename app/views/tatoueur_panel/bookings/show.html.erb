<% content_for :title, "Rendez-vous ##{@booking.id}" %>

<div style="margin-bottom:1.5rem;">
  <%= link_to "← Retour", tatoueur_panel_bookings_path,
      style: "font-size:0.8rem;color:#888;text-decoration:none;" %>
</div>

<div class="row g-4">
  <div class="col-lg-5">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Détails
      </h2>

      <% colors = { "pending"=>"#E67E22","confirmed"=>"#27AE60","done"=>"#888","cancelled"=>"#E74C3C" } %>
      <% [
        ["Client",    @booking.user.nickname],
        ["Date",      @booking.date.strftime("%d %B %Y")],
        ["Heure",     @booking.start_time&.strftime("%Hh%M") || "—"],
        ["Shop",      @booking.shop.name],
        ["Budget",    @booking.price_estimated ? "#{@booking.price_estimated} €" : "—"],
        ["Acompte",   @booking.deposit_paid? ? "✅ Payé" : "⏳ En attente"],
      ].each do |label, val| %>
        <div style="display:flex;justify-content:space-between;padding:0.6rem 0;
                    border-bottom:1px solid #2A2A2A;">
          <span style="font-size:0.78rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
            <%= label %>
          </span>
          <span style="font-size:0.88rem;color:#bbb;"><%= val %></span>
        </div>
      <% end %>

      <div style="margin-top:1rem;">
        <span style="font-size:0.78rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
          Statut
        </span>
        <div style="margin-top:0.4rem;">
          <span style="font-size:0.85rem;color:<%= colors[@booking.status] %>;
                       border:1px solid <%= colors[@booking.status] %>44;
                       padding:0.25rem 0.75rem;text-transform:uppercase;letter-spacing:0.05em;">
            <%= @booking.status %>
          </span>
        </div>
      </div>

      <% if @booking.description.present? %>
        <div style="margin-top:1rem;padding:1rem;background:#0D0D0D;border:1px solid #2A2A2A;">
          <p style="color:#888;font-size:0.85rem;line-height:1.6;margin:0;">
            <%= @booking.description %>
          </p>
        </div>
      <% end %>

      <%# Actions %>
      <% if @booking.status == "pending" %>
        <div style="display:flex;gap:0.5rem;margin-top:1.25rem;">
          <%= button_to "✅ Confirmer",
              tatoueur_panel_booking_path(@booking),
              method: :patch, params: { action_type: "confirm" },
              style: "flex:1;background:#27AE60;color:#fff;border:none;
                      font-family:'Bebas Neue',sans-serif;font-size:1rem;
                      padding:0.65rem;cursor:pointer;letter-spacing:0.05em;" %>
          <%= button_to "✕ Refuser",
              tatoueur_panel_booking_path(@booking),
              method: :patch, params: { action_type: "cancel" },
              data: { turbo_confirm: "Refuser cette réservation ?" },
              style: "flex:1;background:#E74C3C;color:#fff;border:none;
                      font-family:'Bebas Neue',sans-serif;font-size:1rem;
                      padding:0.65rem;cursor:pointer;letter-spacing:0.05em;" %>
        </div>
      <% elsif @booking.status == "confirmed" %>
        <%= button_to "🏁 Marquer comme terminé",
            tatoueur_panel_booking_path(@booking),
            method: :patch, params: { action_type: "done" },
            style: "width:100%;background:#F5C500;color:#000;border:none;margin-top:1.25rem;
                    font-family:'Bebas Neue',sans-serif;font-size:1rem;
                    padding:0.65rem;cursor:pointer;letter-spacing:0.05em;" %>
      <% end %>
    </div>
  </div>

  <div class="col-lg-7">
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1rem;">
        Informations client
      </h3>
      <% [
        ["Email",     @booking.user.email],
        ["Téléphone", @booking.user.phone],
        ["Inscrit le",@booking.user.created_at.strftime("%d/%m/%Y")],
      ].each do |label, val| %>
        <% next unless val.present? %>
        <div style="display:flex;justify-content:space-between;padding:0.5rem 0;
                    border-bottom:1px solid #2A2A2A;">
          <span style="font-size:0.78rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
            <%= label %>
          </span>
          <span style="font-size:0.85rem;color:#bbb;"><%= val %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>