<% content_for :title, "Mes événements" %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
  <h1 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:0.05em;margin:0;">
    Événements
  </h1>
  <%= link_to "➕ Créer un événement", new_event_path,
      style: "background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;
              font-size:1rem;letter-spacing:0.08em;padding:0.6rem 1.25rem;text-decoration:none;" %>
</div>

<% if @events.any? %>
  <div style="display:flex;flex-direction:column;gap:0.75rem;">
    <% @events.each do |event| %>
      <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.25rem;
                  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
        <div style="display:flex;gap:1rem;align-items:center;">
          <% if event.banner.attached? %>
            <%= image_tag event.banner,
                style: "width:60px;height:60px;object-fit:cover;flex-shrink:0;" %>
          <% else %>
            <div style="width:60px;height:60px;background:#111;display:flex;
                        align-items:center;justify-content:center;font-size:1.8rem;flex-shrink:0;">🎪</div>
          <% end %>
          <div>
            <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#fff;">
              <%= event.name %>
              <% if event.featured? %><span style="color:#8B5CF6;font-size:0.85rem;">⭐</span><% end %>
            </div>
            <div style="font-size:0.82rem;color:#888;margin-top:0.15rem;">
              📅 <%= event.start_date&.strftime("%d %B %Y") %>
              <% if event.location.present? %>· 📍 <%= event.location %><% end %>
            </div>
            <div style="font-size:0.78rem;color:#555;margin-top:0.1rem;">
              <%= event.event_participations.count %> participant(s)
            </div>
          </div>
        </div>
        <div style="display:flex;gap:0.5rem;">
          <%= link_to "Modifier", edit_event_path(event),
              style: "font-size:0.82rem;color:#888;text-decoration:none;
                      border:1px solid #444;padding:0.3rem 0.75rem;
                      font-family:'Bebas Neue',sans-serif;letter-spacing:0.05em;" %>
          <%= link_to "Voir →", event_path(event),
              style: "font-size:0.82rem;color:#F5C500;text-decoration:none;
                      border:1px solid #F5C500;padding:0.3rem 0.75rem;
                      font-family:'Bebas Neue',sans-serif;letter-spacing:0.05em;" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:3rem;text-align:center;">
    <div style="font-size:3rem;margin-bottom:1rem;">🎪</div>
    <p style="color:#555;margin-bottom:1.25rem;">Aucun événement créé.</p>
    <%= link_to "Créer mon premier événement", new_event_path,
        style: "color:#F5C500;text-decoration:none;font-family:'Bebas Neue',sans-serif;
                font-size:1rem;border:1px solid #F5C500;padding:0.5rem 1.25rem;" %>
  </div>
<% end %>