<div class="container py-5" style="max-width:720px;">

  <%# Header %>
  <div class="mb-5">
    <%= link_to "← Retour", tatoueur_path(@tatoueur), class: "btn btn-outline-secondary btn-sm mb-3" %>
    <h1 style="font-size:2.5rem;">
      Mon <span class="text-yellow">profil</span>
    </h1>
  </div>

  <%# Erreurs %>
  <% if @tatoueur.errors.any? %>
    <div class="alert alert-danger mb-4">
      <% @tatoueur.errors.full_messages.each do |msg| %>
        <div>⚠️ <%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @tatoueur, html: { enctype: "multipart/form-data" } do |f| %>

    <%# ================================ %>
    <%# PHOTO DE PROFIL %>
    <%# ================================ %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">Photo de profil</h2>

      <div class="d-flex align-items-center gap-4">
        <% if @tatoueur.avatar.attached? %>
          <%= image_tag @tatoueur.avatar,
              style: "width:90px;height:90px;object-fit:cover;border-radius:50%;border:3px solid #F5C500;flex-shrink:0;" %>
        <% else %>
          <div style="width:90px;height:90px;border-radius:50%;background:#0D0D0D;border:3px solid #2A2A2A;display:flex;align-items:center;justify-content:center;font-size:2rem;flex-shrink:0;">🖋️</div>
        <% end %>
        <div class="flex-grow-1">
          <%= f.label :avatar, "Changer la photo",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.file_field :avatar,
              accept: "image/png,image/jpeg,image/webp",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#888;padding:0.6rem 1rem;font-size:0.85rem;cursor:pointer;" %>
          <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;">PNG, JPG ou WEBP · Max 5MB</p>
        </div>
      </div>
    </div>

    <%# ================================ %>
    <%# PHOTOS DU PROFIL %>
    <%# ================================ %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">Flash & Photos</h2>
      <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">Ces photos apparaissent sur ton profil public comme flash disponibles.</p>

      <% if @tatoueur.photos.attached? %>
        <div class="row g-2 mb-3">
          <% @tatoueur.photos.each do |photo| %>
            <div class="col-3">
              <%= image_tag photo, style: "width:100%;height:80px;object-fit:cover;border:1px solid #2A2A2A;" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= f.label :photos, "Ajouter des photos",
          style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
      <%= f.file_field :photos,
          multiple: true,
          accept: "image/png,image/jpeg,image/webp",
          style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#888;padding:0.6rem 1rem;font-size:0.85rem;cursor:pointer;" %>
      <p style="font-size:0.75rem;color:#555;margin-top:0.4rem;">Plusieurs photos · PNG, JPG ou WEBP · Max 5MB chacune</p>
    </div>

    <%# ================================ %>
    <%# INFORMATIONS PERSONNELLES %>
    <%# ================================ %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">Informations</h2>

      <div class="mb-4">
        <%= f.label :nickname, "Pseudo",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_field :nickname,
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <%= f.label :first_name, "Prénom",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :first_name,
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <%= f.label :last_name, "Nom",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :last_name,
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>

      <div class="mb-4">
        <%= f.label :email, "Email",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.email_field :email,
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>

      <div class="mb-4">
        <%= f.label :address, "Adresse / Ville",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_field :address,
            placeholder: "Paris, France",
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>

      <div class="mb-4">
        <%= f.label :deposit_amount, "Montant de l'acompte (€)",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <div style="position:relative;">
          <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#F5C500;font-family:'Bebas Neue',sans-serif;">€</span>
          <%= f.number_field :deposit_amount,
              step: 1, min: 0,
              placeholder: "50",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem 0.85rem 2.5rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>

      <div>
        <%= f.label :description, "Description / Bio",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_area :description,
            rows: 4,
            placeholder: "Présente-toi, ton style, ton univers...",
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;resize:vertical;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>
    </div>

    <%# ================================ %>
    <%# STYLES DE TATOUAGE %>
    <%# ================================ %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">Mes styles</h2>
      <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">Sélectionne les styles que tu pratiques.</p>

      <div class="d-flex flex-wrap gap-2">
        <% TattooStyle.all.each do |style| %>
          <label style="cursor:pointer;">
            <input type="checkbox"
                   name="tatoueur[tattoo_style_ids][]"
                   value="<%= style.id %>"
                   <%= @tatoueur.tattoo_style_ids.include?(style.id) ? 'checked' : '' %>
                   style="display:none;"
                   onchange="toggleStyleBtn(this)" />
            <span style="display:inline-block;background:<%= @tatoueur.tattoo_style_ids.include?(style.id) ? '#F5C500' : '#0D0D0D' %>;color:<%= @tatoueur.tattoo_style_ids.include?(style.id) ? '#000' : '#888' %>;border:1px solid <%= @tatoueur.tattoo_style_ids.include?(style.id) ? '#F5C500' : '#2A2A2A' %>;font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:0.05em;padding:0.4rem 1rem;transition:all 0.15s;">
              <%= style.name %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%# SUBMIT %>
    <%= f.submit "Enregistrer le profil",
        style: "width:100%;background:#F5C500;color:#000;border:none;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:0.1em;padding:1rem;cursor:pointer;text-transform:uppercase;",
        onmouseover: "this.style.background='#d4a800'",
        onmouseout:  "this.style.background='#F5C500'" %>

  <% end %>

  <%# ================================ %>
  <%# COORDONNÉES BANCAIRES — FORMULAIRE SÉPARÉ %>
  <%# ================================ %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-top:1.5rem;">
    <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">Coordonnées bancaires</h2>
    <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">
      Utilisées pour que tes clients puissent te verser un acompte par virement.
    </p>

    <%= form_with model: @tatoueur, url: tatoueur_path(@tatoueur), method: :patch do |f| %>
      <div class="mb-4">
        <%= f.label :iban, "IBAN",
            style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
        <%= f.text_field :iban,
            placeholder: "FR76 3000 6000 0112 3456 7890 189",
            style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;letter-spacing:0.05em;",
            onfocus: "this.style.borderColor='#F5C500'",
            onblur:  "this.style.borderColor='#2A2A2A'" %>
      </div>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <%= f.label :bic, "BIC / SWIFT",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :bic,
              placeholder: "BNPAFRPP",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <%= f.label :bank_name, "Nom de la banque",
              style: "display:block;font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.5rem;" %>
          <%= f.text_field :bank_name,
              placeholder: "BNP Paribas",
              style: "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;",
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>
      <%= f.submit "Sauvegarder les coordonnées",
          style: "width:100%;background:transparent;color:#F5C500;border:1px solid #F5C500;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:0.1em;padding:0.85rem;cursor:pointer;text-transform:uppercase;transition:all 0.2s;",
          onmouseover: "this.style.background='#F5C500';this.style.color='#000'",
          onmouseout:  "this.style.background='transparent';this.style.color='#F5C500'" %>
    <% end %>
  </div>

  <%# ================================ %>
  <%# PAYPAL %>
  <%# ================================ %>
  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-top:1.5rem;">
    <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F5C500;border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:0.5rem;">PayPal</h2>
    <p style="font-size:0.8rem;color:#555;margin-bottom:1.5rem;">
      Connecte ton compte PayPal pour recevoir les acomptes directement.
    </p>
    <% if @tatoueur.paypal_onboarded? %>
      <div style="display:flex;align-items:center;gap:1rem;">
        <span style="background:rgba(39,174,96,0.15);color:#27AE60;border:1px solid #27AE60;padding:0.5rem 1rem;font-family:'Bebas Neue',sans-serif;font-size:1rem;">
          ✅ PayPal connecté
        </span>
        <%= link_to "Reconnecter", connect_paypal_tatoueur_path(@tatoueur),
            style: "color:#888;font-size:0.85rem;text-decoration:none;" %>
      </div>
    <% else %>
      <%= link_to "Connecter mon compte PayPal →",
          connect_paypal_tatoueur_path(@tatoueur),
          style: "display:inline-block;background:transparent;color:#F5C500;border:1px solid #F5C500;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:0.08em;padding:0.85rem 2rem;text-transform:uppercase;transition:all 0.2s;",
          onmouseover: "this.style.background='#F5C500';this.style.color='#000'",
          onmouseout:  "this.style.background='transparent';this.style.color='#F5C500'" %>
    <% end %>
  </div>

</div>

<script>
  function toggleStyleBtn(input) {
    const span = input.nextElementSibling
    if (input.checked) {
      span.style.background  = "#F5C500"
      span.style.color       = "#000"
      span.style.borderColor = "#F5C500"
    } else {
      span.style.background  = "#0D0D0D"
      span.style.color       = "#888"
      span.style.borderColor = "#2A2A2A"
    }
  }
</script>