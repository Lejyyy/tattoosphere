<h1>Modifier <%= @tatoueur.nickname %></h1>
<%= render "form" %>

<div class="card-dark p-4 mt-4">
  <h3 style="color:#fff;">Coordonnées bancaires</h3>
  <p style="color:#888;font-size:0.85rem;">
    Ces informations permettront à vos clients de vous verser l'acompte par virement.
  </p>

  <%= form_with model: @tatoueur do |f| %>
    <div class="mb-3">
      <%= f.label :iban, "IBAN", style: "color:#888;" %>
      <%= f.text_field :iban,
          placeholder: "FR76 3000 6000 0112 3456 7890 189",
          class: "form-control search-input",
          value: @tatoueur.iban %>
    </div>
    <div class="mb-3">
      <%= f.label :bic, "BIC / SWIFT", style: "color:#888;" %>
      <%= f.text_field :bic,
          placeholder: "BNPAFRPP",
          class: "form-control search-input" %>
    </div>
    <div class="mb-3">
      <%= f.label :bank_name, "Nom de la banque", style: "color:#888;" %>
      <%= f.text_field :bank_name,
          placeholder: "BNP Paribas",
          class: "form-control search-input" %>
    </div>
    <div class="mb-3">
      <%= f.label :deposit_amount, "Montant de l'acompte (€)", style: "color:#888;" %>
      <%= f.number_field :deposit_amount,
          step: 1,
          min: 0,
          class: "form-control search-input" %>
    </div>
    <%= f.submit "Sauvegarder", class: "btn search-btn" %>
  <% end %>
</div>
