<style>
/* ── Layout ── */
.ts-page { display: flex; min-height: calc(100vh - 60px); }

/* ── Sidebar ── */
.ts-sidebar {
  width: 240px; flex-shrink: 0;
  background: #0d0d0d;
  border-right: 1px solid rgba(255,255,255,0.06);
  padding: 1.5rem 1.25rem;
  display: flex; flex-direction: column; gap: 1.5rem;
  position: sticky; top: 0; height: calc(100vh - 60px); overflow-y: auto;
}
.ts-sidebar-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.2rem; letter-spacing: 0.07em; color: #fff; margin: 0;
}
.ts-filter-section { display: flex; flex-direction: column; gap: 0.6rem; }
.ts-filter-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #555; }
.ts-filter-input {
  background: #1a1a1a; border: 1px solid #2a2a2a; color: #fff;
  padding: 0.6rem 0.85rem; font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.9rem; outline: none; border-radius: 3px; transition: border-color .2s; width: 100%;
}
.ts-filter-input:focus { border-color: #F5C500; }
.ts-style-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.ts-style-tag {
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
  padding: 4px 9px; border-radius: 2px; cursor: pointer;
  border: 1px solid #2a2a2a; color: #666; background: transparent;
  transition: all .15s; text-decoration: none;
}
.ts-style-tag:hover { border-color: #F5C500; color: #F5C500; }
.ts-style-tag.active { background: rgba(245,197,0,0.12); border-color: #F5C500; color: #F5C500; }
.ts-filter-divider { border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 0; }
.ts-filter-btn {
  font-family: 'Bebas Neue', sans-serif; font-size: 0.88rem; letter-spacing: 0.07em;
  padding: 0.6rem 1rem; border: none; cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  text-decoration: none; border-radius: 3px; transition: opacity .15s; width: 100%;
}
.ts-filter-btn:hover { opacity: .85; }
.ts-filter-btn--primary { background: #F5C500; color: #000; }
.ts-filter-btn--ghost { background: transparent; color: #555; border: 1px solid rgba(255,255,255,0.1); }
.ts-filter-btn--ghost:hover { color: #fff; border-color: rgba(255,255,255,0.3); opacity: 1; }

/* ── Main ── */
.ts-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }

/* ── Topbar ── */
.ts-topbar {
  padding: 0.85rem 1.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
  background: #0d0d0d; position: sticky; top: 0; z-index: 10; flex-wrap: wrap;
}
.ts-topbar-left { display: flex; align-items: baseline; gap: 0.75rem; }
.ts-topbar-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 0.05em; color: #fff; margin: 0; }
.ts-topbar-count { font-size: 12px; color: #555; }
.ts-topbar-count strong { color: #F5C500; }

/* Vue toggle */
.ts-view-toggle { display: flex; gap: 0.3rem; }
.ts-view-btn {
  background: transparent; border: 1px solid #2a2a2a; color: #555;
  padding: 0.4rem 0.85rem; cursor: pointer; border-radius: 3px;
  font-family: 'Bebas Neue', sans-serif; font-size: 0.85rem; letter-spacing: 0.06em;
  transition: all .15s;
}
.ts-view-btn:hover, .ts-view-btn.active { border-color: #F5C500; color: #F5C500; }
.ts-view-btn.active { background: rgba(245,197,0,0.08); }

/* Active filter pills */
.ts-active-filters { display: flex; flex-wrap: wrap; gap: 0.35rem; align-items: center; }
.ts-filter-pill {
  display: inline-flex; align-items: center; gap: 4px;
  background: rgba(245,197,0,0.1); border: 1px solid rgba(245,197,0,0.3);
  color: #F5C500; font-size: 11px; padding: 3px 8px; border-radius: 2px;
}
.ts-filter-pill a { color: #F5C500; text-decoration: none; font-weight: 700; margin-left: 2px; }

/* ── Grid wrap ── */
.ts-grid-wrap { padding: 1.5rem; flex: 1; }
.ts-map-wrap { flex: 1; }

/* Cards — inchangées */
.tatoueur-card-link { text-decoration: none; display: block; height: 100%; }
.tatoueur-card { display: flex; flex-direction: column; height: 100%; background: #1A1A1A; border: 1px solid #2A2A2A; overflow: hidden; transition: border-color 0.2s; }
.tatoueur-card:hover { border-color: #F5C500 !important; }
.tatoueur-card__photo { position: relative; height: 280px; flex-shrink: 0; overflow: hidden; background: #111; }
.tatoueur-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s; }
.tatoueur-card:hover .tatoueur-card__img { transform: scale(1.03); }
.tatoueur-card__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 4rem; color: #333; }
.tatoueur-card__badges { position: absolute; top: 0.6rem; right: 0.6rem; display: flex; align-items: center; gap: 0.35rem; }
.tatoueur-card__badge { font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
.tatoueur-card__badge--verified { background: rgba(39,174,96,0.9); color: #fff; }
.tatoueur-card__badge--featured { background: #8B5CF6; color: #fff; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; padding: 0; font-size: 0.85rem; }
.tatoueur-card__body { padding: 1rem; background: linear-gradient(to top, #0D0D0D 0%, rgba(13,13,13,0.95) 100%); display: flex; flex-direction: column; gap: 0.35rem; min-height: 130px; }
.tatoueur-card__avatar { width: 36px; height: 36px; object-fit: cover; border-radius: 50%; border: 2px solid #F5C500; flex-shrink: 0; }
.tatoueur-card__name { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; color: #fff; letter-spacing: 0.03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tatoueur-card__shop { font-size: 0.8rem; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-height: 1.2em; }
.tatoueur-card__rating { font-size: 0.8rem; color: #F5C500; min-height: 1.2em; }
.tatoueur-card__styles { display: flex; flex-wrap: wrap; gap: 0.25rem; min-height: 1.6em; }
.tatoueur-card__style-tag { background: rgba(245,197,0,0.15); color: #F5C500; font-size: 0.7rem; padding: 0.15rem 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }

@media (max-width: 700px) { .ts-sidebar { display: none; } }
</style>

<div class="ts-page">

  <%# ── Sidebar filtres ── %>
  <aside class="ts-sidebar">
    <%= form_with url: tatoueurs_path, method: :get, id: "ts-form" do |f| %>

      <div class="ts-sidebar-title">Filtrer</div>

      <%# Recherche texte %>
      <div class="ts-filter-section">
        <label class="ts-filter-label">Recherche</label>
        <div style="position:relative;">
          <svg style="position:absolute;left:0.7rem;top:50%;transform:translateY(-50%);color:#555;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <%= f.text_field :q, value: params[:q], placeholder: "Nom, ville...",
              class: "ts-filter-input", style: "padding-left:2.1rem;" %>
        </div>
      </div>

      <hr class="ts-filter-divider">

      <%# Styles %>
      <div class="ts-filter-section">
        <div class="ts-filter-label">Style</div>
        <div class="ts-style-tags">
          <%= link_to "Tous", tatoueurs_path(params.except("style_id").to_unsafe_h),
              class: "ts-style-tag #{params[:style_id].blank? ? 'active' : ''}" %>
          <% TattooStyle.order(:name).each do |style| %>
            <%= link_to style.name,
                tatoueurs_path(params.to_unsafe_h.merge("style_id" => style.id)),
                class: "ts-style-tag #{params[:style_id].to_s == style.id.to_s ? 'active' : ''}" %>
          <% end %>
        </div>
      </div>

      <hr class="ts-filter-divider">

      <%# Ville %>
      <div class="ts-filter-section">
        <label class="ts-filter-label">Ville</label>
        <%= f.text_field :location, value: params[:location], placeholder: "Paris, Lyon…",
            class: "ts-filter-input" %>
      </div>

      <hr class="ts-filter-divider">

      <%= f.hidden_field :style_id, value: params[:style_id] %>
      <button type="submit" class="ts-filter-btn ts-filter-btn--primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Rechercher
      </button>

      <% if params[:q].present? || params[:style_id].present? || params[:location].present? %>
        <%= link_to tatoueurs_path, class: "ts-filter-btn ts-filter-btn--ghost" do %>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          Réinitialiser
        <% end %>
      <% end %>

    <% end %>
  </aside>

  <%# ── Zone principale ── %>
  <main class="ts-main">

    <%# Topbar %>
    <div class="ts-topbar">
      <div class="ts-topbar-left">
        <h1 class="ts-topbar-title">Tatoueurs</h1>
        <span class="ts-topbar-count">
          <strong><%= @tatoueurs.count %></strong> artiste<%= @tatoueurs.count > 1 ? "s" : "" %>
        </span>
      </div>
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
        <%# Filtres actifs %>
        <div class="ts-active-filters">
          <% if params[:q].present? %>
            <span class="ts-filter-pill">
              "<%= params[:q] %>"
              <%= link_to "×", tatoueurs_path(params.except("q").to_unsafe_h) %>
            </span>
          <% end %>
          <% if params[:style_id].present? %>
            <% style = TattooStyle.find_by(id: params[:style_id]) %>
            <span class="ts-filter-pill">
              <%= style&.name %>
              <%= link_to "×", tatoueurs_path(params.except("style_id").to_unsafe_h) %>
            </span>
          <% end %>
          <% if params[:location].present? %>
            <span class="ts-filter-pill">
              📍 <%= params[:location] %>
              <%= link_to "×", tatoueurs_path(params.except("location").to_unsafe_h) %>
            </span>
          <% end %>
        </div>
        <%# Toggle vue %>
        <div class="ts-view-toggle">
          <button class="ts-view-btn active" id="btn-grille" onclick="switchView('grille')">⊞ Grille</button>
          <button class="ts-view-btn" id="btn-carte" onclick="switchView('carte')">🗺 Carte</button>
        </div>
      </div>
    </div>

    <%# ── Vue Grille ── %>
    <div id="view-grille" class="ts-grid-wrap">
      <% if @tatoueurs.any? %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
          <% @tatoueurs.each do |tatoueur| %>
            <div class="col">
              <%= link_to tatoueur_path(tatoueur), class: "tatoueur-card-link" do %>
                <div class="tatoueur-card" style="border-color:<%= tatoueur.featured? ? '#8B5CF6' : '#2A2A2A' %>;">
                  <div class="tatoueur-card__photo">
                    <% photo = tatoueur.photos.first || (tatoueur.avatar.attached? ? tatoueur.avatar : nil) %>
                    <% if photo %>
                      <%= image_tag photo, class: "tatoueur-card__img" %>
                    <% else %>
                      <div class="tatoueur-card__placeholder">🖋️</div>
                    <% end %>
                    <div class="tatoueur-card__badges">
                      <% if tatoueur.verified? %>
                        <span class="tatoueur-card__badge tatoueur-card__badge--verified">✅ Vérifié</span>
                      <% end %>
                      <% if tatoueur.featured? %>
                        <span class="tatoueur-card__badge tatoueur-card__badge--featured">⭐</span>
                      <% end %>
                    </div>
                  </div>
                  <div class="tatoueur-card__body">
                    <div class="d-flex align-items-center gap-2 mb-1">
                      <% if tatoueur.avatar.attached? %>
                        <%= image_tag tatoueur.avatar, class: "tatoueur-card__avatar" %>
                      <% end %>
                      <div style="min-width:0;">
                        <div class="tatoueur-card__name"><%= tatoueur.nickname %></div>
                        <div class="tatoueur-card__shop"><%= tatoueur.shops.first&.name || "&nbsp;".html_safe %></div>
                      </div>
                    </div>
                    <div class="tatoueur-card__rating">
                      <% if tatoueur.reviews.any? %>
                        <% avg = tatoueur.reviews.average(:rating).to_f.round(1) %>
                        ⭐ <%= avg %> <span style="color:#666;">(<%= tatoueur.reviews.count %> avis)</span>
                      <% end %>
                    </div>
                    <div class="tatoueur-card__styles">
                      <% tatoueur.tattoo_styles.first(3).each do |style| %>
                        <span class="tatoueur-card__style-tag"><%= style.name %></span>
                      <% end %>
                      <% if tatoueur.tattoo_styles.count > 3 %>
                        <span style="color:#666;font-size:0.7rem;">+<%= tatoueur.tattoo_styles.count - 3 %></span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div style="text-align:center;padding:4rem 2rem;color:#555;">
          <div style="font-size:3rem;margin-bottom:1rem;">🖋️</div>
          <p>Aucun tatoueur trouvé.</p>
          <%= link_to "Réinitialiser la recherche", tatoueurs_path, style: "color:#F5C500;" %>
        </div>
      <% end %>
    </div>

    <%# ── Vue Carte ── %>
    <div id="view-carte" class="ts-map-wrap" style="display:none;">
      <%= render "shared/map",
          map_id: "tatoueurs-map",
          height: "calc(100vh - 108px)",
          tatoueurs_json: @tatoueurs_json,
          shops_json: "[]" %>
    </div>

  </main>
</div>

<script>
  window._tatoueurIndexInitialized = false

  if (!window._tatoueurIndexInitialized) {
  window._tatoueurIndexInitialized = true

  let mapInitialized = false

  function switchView(view) {
    const grille = document.getElementById("view-grille")
    const carte  = document.getElementById("view-carte")
    const btnG   = document.getElementById("btn-grille")
    const btnC   = document.getElementById("btn-carte")
    if (view === "grille") {
      grille.style.display = "block"; carte.style.display = "none"
      btnG.classList.add("active"); btnC.classList.remove("active")
    } else {
      grille.style.display = "none"; carte.style.display = "block"
      btnC.classList.add("active"); btnG.classList.remove("active")
      setTimeout(function() {
        const map = window["map_tatoueurs_map"]
        if (map) {
          map.invalidateSize()
        } else if (!mapInitialized) {
          mapInitialized = true
          document.dispatchEvent(new Event("tatoueurs:map:init"))
        }
      }, 50)
    }
  }

  } // end _tatoueurIndexInitialized
</script>