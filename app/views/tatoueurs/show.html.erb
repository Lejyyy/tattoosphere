<% content_for :title, @tatoueur.nickname %>

<style>
.ts-profile { max-width: 960px; margin: 0 auto; padding: 0 0 4rem; }

/* ── Cover ── */
.ts-cover {
  height: 260px;
  position: relative;
  overflow: hidden;
  border-radius: 0 0 12px 12px;
  background: #0d0d0d;
}
.ts-cover__img { width: 100%; height: 100%; object-fit: cover; display: block; }
.ts-cover__pattern {
  position: absolute; inset: 0;
  background-image:
    repeating-linear-gradient(45deg, #1a1a1a 0px, #1a1a1a 1px, transparent 1px, transparent 12px),
    repeating-linear-gradient(-45deg, #1a1a1a 0px, #1a1a1a 1px, transparent 1px, transparent 12px);
  background-color: #0d0d0d;
}
.ts-cover__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(13,13,13,0.85) 100%);
}
.ts-cover__edit { position: absolute; top: 1rem; right: 1rem; z-index: 10; }
/* ── Identity ── */
.ts-identity {
  display: flex; align-items: flex-end; gap: 1.5rem;
  padding: 0 1.5rem;
  margin-top: -52px;
  margin-bottom: 0;
  position: relative; z-index: 2;
}

.ts-identity__info {
  padding-bottom: 0.25rem; flex: 1; min-width: 0;
  display: flex; flex-direction: column;
}

.ts-avatar-wrap { position: relative; flex-shrink: 0; }
.ts-avatar {
  width: 104px; height: 104px;
  border-radius: 50%;
  border: 3px solid #f5c500;
  background: #1a1a1a;
  object-fit: cover;
  display: block;
}
.ts-avatar--placeholder {
  display: flex; align-items: center; justify-content: center;
  font-size: 2.5rem; color: #444;
}
.ts-avatar__ring {
  position: absolute; inset: -5px;
  border-radius: 50%;
  border: 1px solid rgba(200,168,75,0.25);
  pointer-events: none;
}
.ts-avatar__verified {
  position: absolute; bottom: 4px; right: 4px;
  width: 22px; height: 22px;
  background: #f5c500; border-radius: 50%;
  border: 2px solid #0d0d0d;
  display: flex; align-items: center; justify-content: center;
}
.ts-avatar__verified svg { width: 10px; height: 10px; stroke: #000; }

.ts-identity__info { padding-bottom: 0.25rem; flex: 1; min-width: 0; }

.ts-name-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.3rem; margin-top: 0.75rem; }
.ts-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.4rem; letter-spacing: 0.04em; line-height: 1; color: #fff;
}
.ts-featured-pill {
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 2px;
  background: rgba(139,92,246,0.2); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3);
}

.ts-meta { display: flex; gap: 1.25rem; flex-wrap: wrap; font-size: 13px; color: #888; }
.ts-meta__item { display: flex; align-items: center; gap: 5px; }
.ts-meta__item a { color: #f5c500; text-decoration: none; }
.ts-meta__item a:hover { text-decoration: underline; }

/* ── Stats strip ── */
.ts-stats {
  display: flex;
  padding: 0 1.5rem;
  margin: 1.5rem 0;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.ts-stat { flex: 1; padding: 1rem 0; text-align: center; border-right: 1px solid rgba(255,255,255,0.06); }
.ts-stat:last-child { border-right: none; }
.ts-stat__val {
  display: block; font-family: 'Bebas Neue', sans-serif;
  font-size: 2rem; color: #f5c500; line-height: 1;
}
.ts-stat__label {
  display: block; font-size: 10px; text-transform: uppercase;
  letter-spacing: 0.1em; color: #555; margin-top: 3px;
}

/* ── Body ── */
.ts-body {
  display: grid;
  grid-template-columns: 1fr 240px;
  gap: 1.5rem;
  padding: 0 1.5rem;
}

/* ── Style tags ── */
.ts-styles { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.25rem; }
.ts-style-tag {
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.07em;
  padding: 4px 10px; border-radius: 2px;
  border: 1px solid rgba(200,168,75,0.3);
  color: #f5c500; background: rgba(200,168,75,0.06);
}

/* ── Bio ── */
.ts-bio {
  font-size: 14px; line-height: 1.8; color: #888;
  margin-bottom: 1.25rem; padding-bottom: 1.25rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* ── Actions ── */
.ts-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
.ts-btn {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 0.9rem; letter-spacing: 0.07em;
  padding: 0.5rem 1.2rem; border: none; cursor: pointer;
  display: inline-flex; align-items: center; gap: 6px;
  text-decoration: none; border-radius: 2px; transition: opacity .15s;
}
.ts-btn:hover { opacity: .85; }
.ts-btn--primary { background: #f5c500; color: #000; }
.ts-btn--outline { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.2); }
.ts-btn--outline:hover { border-color: rgba(255,255,255,0.5); opacity: 1; }
.ts-btn--ghost  { background: transparent; color: #666; border: 1px solid rgba(255,255,255,0.1); }
.ts-btn--ghost:hover { color: #fff; border-color: rgba(255,255,255,0.3); opacity: 1; }
.ts-btn--disabled { background: #1a1a1a; color: #333; border: 1px solid rgba(255,255,255,0.06); cursor: default; }
.ts-btn--sm { font-size: 0.78rem; padding: 0.35rem 0.85rem; }
.ts-badge-success {
  font-size: 11px; padding: 4px 10px; border-radius: 2px;
  background: rgba(39,174,96,0.12); color: #2ecc71; border: 1px solid rgba(39,174,96,0.25);
}

/* ── Tabs ── */
.ts-tabs {
  display: flex; border-bottom: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 1.5rem;
  overflow: visible;
  flex-wrap: wrap;
  gap: 0;
}
.ts-tab {
  font-family: 'Bebas Neue', sans-serif; font-size: 0.95rem; letter-spacing: 0.06em;
  padding: 0.6rem 1.2rem; background: transparent; border: none; cursor: pointer;
  color: #555; border-bottom: 2px solid transparent; margin-bottom: -1px;
  transition: color .2s; white-space: nowrap;
}
.ts-tab:hover { color: #aaa; }
.ts-tab--active { color: #f5c500; border-bottom-color: #f5c500; }
.ts-tab__count { font-size: 10px; color: #444; margin-left: 3px; }

/* ── Section title ── */
.ts-section-title {
  font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 0.05em;
  color: #fff; border-left: 3px solid #f5c500; padding-left: 0.65rem;
  margin-bottom: 1.25rem;
}
.ts-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }

/* ── Masonry grid ── */
.ts-photo-grid { columns: 2; column-gap: 0.6rem; }
@media (max-width: 500px) { .ts-photo-grid { columns: 1; } }

.ts-photo-item {
  break-inside: avoid; margin-bottom: 0.6rem;
  overflow: hidden; position: relative; border-radius: 2px; cursor: zoom-in;
}
.ts-photo-img { width: 100%; display: block; transition: transform .35s; }
.ts-photo-item:hover .ts-photo-img { transform: scale(1.04); filter: brightness(.85); }
.ts-photo-del {
  position: absolute; top: 0.5rem; right: 0.5rem;
  background: rgba(0,0,0,.75); color: #fff;
  width: 24px; height: 24px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; text-decoration: none; cursor: pointer;
  opacity: 0; transition: opacity .2s;
}
.ts-photo-item:hover .ts-photo-del { opacity: 1; }

/* ── Upload form ── */
.ts-upload-form {
  background: #111; border: 1px solid #2a2a2a; border-top: 3px solid #f5c500;
  padding: 1.25rem; margin-bottom: 1.5rem; border-radius: 2px;
}

/* ── Portfolio cards ── */
.ts-portfolio-card {
  display: block; text-decoration: none;
  background: #111; border: 1px solid #2a2a2a;
  overflow: hidden; border-radius: 2px; transition: border-color .2s;
}
.ts-portfolio-card:hover { border-color: #f5c500; }
.ts-portfolio-card__thumb { overflow: hidden; }
.ts-portfolio-card__img { width: 100%; height: 200px; object-fit: cover; display: block; transition: transform .3s; }
.ts-portfolio-card:hover .ts-portfolio-card__img { transform: scale(1.04); }
.ts-portfolio-card__empty {
  width: 100%; height: 200px; background: #0d0d0d;
  display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: #333;
}
.ts-portfolio-card__info { padding: 0.85rem 1rem; }
.ts-portfolio-card__name { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: #fff; }
.ts-portfolio-card__count { display: block; font-size: 12px; color: #555; margin-top: 2px; }

/* ── Events ── */
.ts-event {
  display: flex; gap: 1.25rem; align-items: flex-start;
  padding: 1rem 1.25rem; background: #111;
  border: 1px solid #2a2a2a; border-left: 3px solid #f5c500;
  margin-bottom: 0.75rem; border-radius: 0 2px 2px 0;
}
.ts-event__date { font-family: 'Bebas Neue', sans-serif; font-size: 0.95rem; color: #f5c500; white-space: nowrap; min-width: 100px; }
.ts-event__name { font-weight: 600; color: #fff; margin-bottom: 2px; font-size: 14px; }
.ts-event__loc { font-size: 12px; color: #666; }
.ts-event__desc { font-size: 13px; color: #555; margin-top: 4px; }

/* ── Reviews ── */
.ts-rating-summary { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; }
.ts-rating-big { font-family: 'Bebas Neue', sans-serif; font-size: 3.5rem; color: #f5c500; line-height: 1; }
.ts-stars { display: flex; gap: 2px; }
.ts-stars svg { width: 14px; height: 14px; }
.ts-review-card { background: #111; border: 1px solid #2a2a2a; padding: 1.1rem 1.25rem; border-radius: 2px; transition: border-color .2s; }
.ts-review-card:hover { border-color: #2e2e2e; }
.ts-review-card__header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem; }
.ts-review-card__author { font-family: 'Bebas Neue', sans-serif; font-size: 1rem; color: #f5c500; }
.ts-review-card__date { font-size: 11px; color: #444; }
.ts-review-card__comment { font-size: 13px; color: #777; line-height: 1.65; margin: 0; }

/* ── Sidebar ── */
.ts-sidebar { display: flex; flex-direction: column; gap: 1rem; overflow: hidden; }
.ts-sidebar-card { background: #111; border: 1px solid #1e1e1e; border-radius: 8px; padding: 1rem 1.1rem; }
.ts-sidebar-title { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: #555; margin-bottom: 0.75rem; }

.ts-shop-row { display: flex; align-items: center; gap: 0.65rem; padding: 0.5rem 0; border-bottom: 1px solid #1a1a1a; }
.ts-shop-row:last-child { border-bottom: none; }
.ts-shop-icon {
  width: 34px; height: 34px; background: rgba(200,168,75,0.08);
  border: 1px solid rgba(200,168,75,0.15); border-radius: 6px;
  display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0;
}
.ts-shop-name { font-size: 13px; font-weight: 500; color: #ddd; }
.ts-shop-loc { font-size: 11px; color: #555; }

.ts-avail-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; margin-bottom: 4px; }
.ts-avail-day-label { font-size: 9px; color: #444; text-align: center; }
.ts-avail-slots { display: flex; flex-direction: column; gap: 3px; }
.ts-avail-slot { height: 8px; border-radius: 1px; }
.ts-avail-slot--free { background: rgba(200,168,75,0.55); }
.ts-avail-slot--busy { background: rgba(255,255,255,0.05); }
.ts-avail-legend { display: flex; gap: 0.75rem; margin-top: 0.6rem; font-size: 10px; color: #555; }
.ts-avail-legend span { display: flex; align-items: center; gap: 4px; }
.ts-avail-legend-dot { width: 8px; height: 8px; border-radius: 1px; display: inline-block; }

.ts-review-mini { padding: 0.55rem 0; border-bottom: 1px solid #1a1a1a; }
.ts-review-mini:last-child { border-bottom: none; }
.ts-review-mini__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
.ts-review-mini__author { font-size: 12px; font-weight: 500; color: #ccc; }
.ts-review-mini__text { font-size: 11px; color: #555; line-height: 1.5; }
.ts-stars-sm { display: flex; gap: 1px; }
.ts-stars-sm svg { width: 9px; height: 9px; }

/* ── Lightbox ── */
.ts-lightbox {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.95); z-index: 9999;
  align-items: center; justify-content: center;
}
.ts-lightbox.open { display: flex; }
.ts-lightbox__img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: 2px; }
.ts-lightbox__nav {
  position: fixed; top: 50%; transform: translateY(-50%);
  background: none; border: none; color: #fff; font-size: 3rem;
  cursor: pointer; opacity: 0.35; transition: opacity .2s; padding: 0 1.25rem; line-height: 1;
}
.ts-lightbox__nav:hover { opacity: 1; }
.ts-lightbox__prev { left: 0; }
.ts-lightbox__next { right: 0; }
.ts-lightbox__close {
  position: fixed; top: 1rem; right: 1.5rem;
  background: none; border: none; color: #fff; font-size: 1.75rem;
  cursor: pointer; opacity: 0.4; transition: opacity .2s;
}
.ts-lightbox__close:hover { opacity: 1; }
.ts-lightbox__caption {
  position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
  color: #555; font-size: 12px; letter-spacing: 0.05em; white-space: nowrap;
}

.ts-empty { color: #444; font-size: 13px; }

@media (max-width: 700px) {
  .ts-body { grid-template-columns: 1fr; }
  .ts-sidebar { display: none; }
  .ts-identity { padding: 0 1rem; }
  .ts-stats { padding: 0 1rem; }
  .ts-body { padding: 0 1rem; }}
</style>

<div class="ts-profile">

  <%# ── Cover ── %>
  <div class="ts-cover">
    <% if @tatoueur.cover.attached? %>
      <%= image_tag url_for(@tatoueur.cover), class: "ts-cover__img" %>
    <% elsif @tatoueur.cover_color.present? %>
      <div class="ts-cover__img" style="background:<%= @tatoueur.cover_color %>;width:100%;height:100%;"></div>
    <% else %>
      <div class="ts-cover__pattern"></div>
    <% end %>
    <div class="ts-cover__overlay"></div>
    <div class="ts-cover__accent"></div>
    <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
      <div class="ts-cover__edit">
        <%= render "shared/cover_editor", record: @tatoueur, update_path: tatoueur_path(@tatoueur), param_name: "tatoueur" %>
      </div>
    <% end %>
  </div>

  <%# ── Identity ── %>
  <div class="ts-identity">
    <div class="ts-avatar-wrap">
      <% if @tatoueur.avatar.attached? %>
        <%= image_tag @tatoueur.avatar, class: "ts-avatar" %>
      <% else %>
        <div class="ts-avatar ts-avatar--placeholder">🖋️</div>
      <% end %>
      <div class="ts-avatar__ring"></div>
      <% if @tatoueur.verified? %>
        <div class="ts-avatar__verified">
          <svg viewBox="0 0 12 12" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="2,6 5,9 10,3"/>
          </svg>
        </div>
      <% end %>
    </div>
    <div class="ts-identity__info">
      <div class="ts-name-row">
        <h1 class="ts-name"><%= @tatoueur.nickname %></h1>
        <% if @tatoueur.featured? %>
          <span class="ts-featured-pill">⭐ Featured</span>
        <% end %>
      </div>
      <div class="ts-meta">
        <span class="ts-meta__item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <% if @tatoueur.address.present? %>
            <%= @tatoueur.address %>
          <% elsif @tatoueur.shops.any? %>
            <%= @tatoueur.shops.first.address %>
          <% else %>
            <span style="color:#444;">Localisation non renseignée</span>
          <% end %>
        </span>
        <span class="ts-meta__item">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          <% if @tatoueur.shops.any? %>
            <% @tatoueur.shops.each do |shop| %>
              <%= link_to shop.name, shop_path(shop) %>
            <% end %>
          <% else %>
            <span style="color:#444;">Indépendant</span>
          <% end %>
        </span>
      </div>
    </div>
  </div>

  <%# ── Stats ── %>
  <div class="ts-stats">
    <div class="ts-stat">
      <span class="ts-stat__val"><%= @tatoueur.portfolio_items.count %></span>
      <span class="ts-stat__label">Réalisations</span>
    </div>
    <% if @reviews.any? %>
      <div class="ts-stat">
        <span class="ts-stat__val"><%= number_with_precision(@reviews.average(:rating), precision: 1) %></span>
        <span class="ts-stat__label">Note</span>
      </div>
    <% end %>
    <div class="ts-stat">
      <span class="ts-stat__val"><%= @reviews.count %></span>
      <span class="ts-stat__label">Avis</span>
    </div>
    <div class="ts-stat">
      <span class="ts-stat__val"><%= @tatoueur.portfolios.count %></span>
      <span class="ts-stat__label">Portfolios</span>
    </div>
  </div>

  <%# ── Body ── %>
  <div class="ts-body">

    <%# ── Main ── %>
    <div>
      <% if @tatoueur.tattoo_styles.any? %>
        <div class="ts-styles">
          <% @tatoueur.tattoo_styles.each do |style| %>
            <span class="ts-style-tag"><%= style.name %></span>
          <% end %>
        </div>
      <% end %>

      <% if @tatoueur.description.present? %>
        <p class="ts-bio"><%= @tatoueur.description %></p>
      <% end %>

      <%# Actions %>
      <%# Actions %>
        <div class="ts-actions">
          <% if user_signed_in? %>
            <% unless current_user.tatoueur == @tatoueur %>
              <%= link_to conversations_path(tatoueur_id: @tatoueur.id),
                    data: { turbo_method: :post }, class: "ts-btn ts-btn--primary" do %>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                Contacter
              <% end %>
              <%= link_to new_tatoueur_booking_path(@tatoueur), class: "ts-btn ts-btn--outline" do %>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Réserver
              <% end %>
            <% end %>
          <% else %>
            <%= link_to new_user_session_path, class: "ts-btn ts-btn--primary" do %>
              Connectez-vous pour contacter
            <% end %>
          <% end %>

          <% unless current_user&.tatoueur == @tatoueur %>
            <%= render "favorites/button", favoritable: @tatoueur %>
            <%= render "shared/share_button",
                record: @tatoueur,
                record_type: "Tatoueur",
                record_name: @tatoueur.nickname %>
          <% end %>

          <% if user_signed_in? && policy(@tatoueur).update? %>
            <%= link_to edit_tatoueur_path(@tatoueur), class: "ts-btn ts-btn--ghost ts-btn--sm" do %>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Modifier
            <% end %>
          <% end %>

          <% if current_user&.tatoueur == @tatoueur %>
            <% unless @tatoueur.verified? %>
              <%= link_to verification_tatoueur_path(@tatoueur), class: "ts-btn ts-btn--ghost ts-btn--sm" do %>
                Faire vérifier mon profil
              <% end %>
            <% end %>
            <% if @tatoueur.paypal_onboarded? %>
              <span class="ts-badge-success">✓ PayPal connecté</span>
            <% else %>
              <%= link_to connect_paypal_tatoueur_path(@tatoueur), class: "ts-btn ts-btn--ghost ts-btn--sm" do %>
                Connecter PayPal
              <% end %>
            <% end %>
          <% end %>
        </div>

      <%# Tabs %>
      <div class="ts-tabs">
        <% tabs = [] %>
        <% tabs << { key: "portfolio", label: "Portfolio", count: @tatoueur.portfolio_items.count } if @portfolios.any? || @gallery_photos.any? %>
        <% tabs << { key: "disponibilites", label: "Disponibilités", count: nil } %>
        <% tabs << { key: "evenements",     label: "Événements",     count: @events.count } if @events.any? %>
        <% tabs << { key: "avis",           label: "Avis",           count: @reviews.count } %>
        <% tabs.each_with_index do |tab, i| %>
          <button class="ts-tab <%= i == 0 ? 'ts-tab--active' : '' %>"
                  id="tab-btn-<%= tab[:key] %>"
                  onclick="showTab('<%= tab[:key] %>')">
            <%= tab[:label] %>
            <% if tab[:count].present? && tab[:count] > 0 %>
              <span class="ts-tab__count">(<%= tab[:count] %>)</span>
            <% end %>
          </button>
        <% end %>
      </div>

     <%# ── Tab : Portfolio ── %>
<% if @portfolios.any? || @gallery_photos.any? %>
  <div id="tab-portfolio" class="tab-content">


    <%# Portfolios existants %>
    <% if @portfolios.any? %>
      <h2 class="ts-section-title">Portfolios</h2>
      <div class="row g-3 mb-4">
        <% @portfolios.each do |portfolio| %>
          <div class="col-md-4">
            <%= link_to tatoueur_portfolio_path(@tatoueur, portfolio), class: "ts-portfolio-card" do %>
              <div class="ts-portfolio-card__thumb">
                <% first_item = portfolio.portfolio_items.first %>
                <% if first_item&.images&.attached? %>
                  <%= image_tag first_item.images.first, class: "ts-portfolio-card__img" %>
                <% else %>
                  <div class="ts-portfolio-card__empty">🖼️</div>
                <% end %>
              </div>
              <div class="ts-portfolio-card__info">
                <span class="ts-portfolio-card__name"><%= portfolio.name %></span>
                <span class="ts-portfolio-card__count"><%= portfolio.portfolio_items.count %> réalisation(s)</span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Galerie enrichie %>
    <% if @gallery_photos.any? || (user_signed_in? && current_user.tatoueur == @tatoueur) %>
      <div class="ts-section-header">
        <h2 class="ts-section-title mb-0">Réalisations</h2>
        <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
          <%= link_to "Gérer la galerie →", tatoueur_panel_photos_path,
                class: "ts-btn ts-btn--ghost ts-btn--sm" %>
        <% end %>
      </div>

      <%# Filtres par style %>
      <% styles_present = @gallery_photos.map(&:tattoo_style).compact.uniq %>
      <% if styles_present.any? %>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1.25rem;">
          <button onclick="filterGallery(null)" class="ts-gallery-filter ts-gallery-filter--active" data-style="">
            ✦ Tous
          </button>
          <% styles_present.each do |style| %>
            <button onclick="filterGallery('<%= style.id %>')"
                    class="ts-gallery-filter" data-style="<%= style.id %>">
              <%= style.name %>
            </button>
          <% end %>
        </div>
        <style>
          .ts-gallery-filter {
            background: #111;
            border: 1px solid #2a2a2a;
            color: #555;
            padding: 5px 16px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 0.85rem;
            letter-spacing: 0.08em;
            cursor: pointer;
            border-radius: 2px;
            transition: all 0.2s;
          }
          .ts-gallery-filter:hover {
            color: #F5C500;
            border-color: rgba(245,197,0,0.4);
            background: rgba(245,197,0,0.05);
          }
          .ts-gallery-filter--active {
            background: rgba(245,197,0,0.12);
            color: #F5C500;
            border-color: rgba(245,197,0,0.5);
            box-shadow: 0 0 8px rgba(245,197,0,0.1);
          }
        </style>
      <% end %>

      <% if @gallery_photos.any? %>
        <div class="ts-photo-grid" id="gallery-public">
          <% @gallery_photos.each do |photo| %>
            <div class="ts-photo-item gallery-pub-item" data-style="<%= photo.tattoo_style_id %>">
              <img src="<%= url_for(photo.image) %>"
                   class="ts-photo-img"
                   data-lightbox="true"
                   data-src="<%= url_for(photo.image) %>"
                   data-caption="<%= photo.title.presence || "Réalisation" %>"
                   onclick="openLightbox(this)" />
              <%# Badge style %>
              <% if photo.style_name.present? %>
                <span style="position:absolute;bottom:0.4rem;left:0.4rem;
                             background:rgba(0,0,0,0.75);color:#F5C500;font-size:10px;
                             padding:2px 7px;letter-spacing:0.05em;">
                  <%= photo.style_name %>
                </span>
              <% end %>
              <%# Titre au hover %>
              <% if photo.title.present? %>
                <span style="position:absolute;bottom:0.4rem;right:0.4rem;
                             background:rgba(0,0,0,0.75);color:#fff;font-size:10px;
                             padding:2px 7px;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                  <%= photo.title %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="ts-empty">Aucune réalisation pour le moment.</p>
      <% end %>
    <% end %>

  </div>
<% end %>

      <%# ── Tab : Disponibilités ── %>
      <div id="tab-disponibilites" class="tab-content" style="display:none;">
        <h2 class="ts-section-title">Disponibilités</h2>
        <%= render "tatoueurs/calendar", tatoueur: @tatoueur %>
      </div>

      <%# ── Tab : Événements ── %>
      <% if @events.any? %>
        <div id="tab-evenements" class="tab-content" style="display:none;">
          <h2 class="ts-section-title">Événements à venir</h2>
          <% @events.each do |event| %>
            <div class="ts-event">
              <div class="ts-event__date"><%= event.start_date&.strftime("%d %b %Y") %></div>
              <div>
                <div class="ts-event__name"><%= event.name %></div>
                <div class="ts-event__loc">📍 <%= event.location %></div>
                <% if event.description.present? %>
                  <p class="ts-event__desc"><%= event.description.truncate(120) %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ── Tab : Avis ── %>
      <div id="tab-avis" class="tab-content" style="display:none;">
        <% if @reviews.any? %>
          <div class="ts-rating-summary">
            <span class="ts-rating-big"><%= number_with_precision(@reviews.average(:rating), precision: 1) %></span>
            <div>
              <div class="ts-stars">
                <% avg = @reviews.average(:rating).to_f %>
                <% 5.times do |i| %>
                  <svg viewBox="0 0 24 24" fill="<%= i < avg ? '#f5c500' : 'none' %>" stroke="#f5c500" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                <% end %>
              </div>
              <span style="font-size:11px;color:#444;"><%= @reviews.count %> avis</span>
            </div>
          </div>
          <div class="row g-3">
            <% @reviews.each do |review| %>
              <div class="col-md-6">
                <div class="ts-review-card">
                  <div class="ts-review-card__header">
                    <span class="ts-review-card__author"><%= review.user.nickname %></span>
                    <span class="ts-review-card__date"><%= review.created_at.strftime("%d/%m/%Y") %></span>
                  </div>
                  <div class="ts-stars" style="margin-bottom:0.5rem;">
                    <% 5.times do |i| %>
                      <svg viewBox="0 0 24 24" fill="<%= i < review.rating ? '#f5c500' : 'none' %>" stroke="<%= i < review.rating ? '#f5c500' : '#333' %>" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    <% end %>
                  </div>
                  <p class="ts-review-card__comment"><%= review.comment %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="ts-empty">Aucun avis pour le moment.</p>
        <% end %>
      </div>
    </div>

    

    <%# ── Sidebar ── %>
    <div class="ts-sidebar">

      <%# Shop %>
      <% if @tatoueur.shops.any? %>
        <div class="ts-sidebar-card">
          <div class="ts-sidebar-title">Studio</div>
          <% @tatoueur.shops.each do |shop| %>
            <%= link_to shop_path(shop), style: "text-decoration:none;" do %>
              <div class="ts-shop-row">
                <div class="ts-shop-icon">🏠</div>
                <div>
                  <div class="ts-shop-name"><%= shop.name %></div>
                  <div class="ts-shop-loc"><%= shop.address&.truncate(35) %></div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Disponibilités compactes %>
      <div class="ts-sidebar-card">
        <div class="ts-sidebar-title">Disponibilités cette semaine</div>
        <% days = %w[L M M J V S D] %>
        <div class="ts-avail-days">
          <% days.each do |d| %>
            <div class="ts-avail-day-label"><%= d %></div>
          <% end %>
        </div>
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;">
          <% availabilities_by_day = @tatoueur.availabilities.group_by { |a| a.date.wday } rescue {} %>
          <% [1,2,3,4,5,6,0].each do |wday| %>
            <div class="ts-avail-slots">
              <% 3.times do |slot| %>
                <% free = availabilities_by_day[wday]&.any? rescue false %>
                <div class="ts-avail-slot <%= free ? 'ts-avail-slot--free' : 'ts-avail-slot--busy' %>"></div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="ts-avail-legend">
          <span><span class="ts-avail-legend-dot" style="background:rgba(200,168,75,0.55);"></span>Dispo</span>
          <span><span class="ts-avail-legend-dot" style="background:rgba(255,255,255,0.05);"></span>Occupé</span>
        </div>
      </div>

      <%# Derniers avis %>
      <% if @reviews.any? %>
        <div class="ts-sidebar-card">
          <div class="ts-sidebar-title">Derniers avis</div>
          <% @reviews.last(3).each do |review| %>
            <div class="ts-review-mini">
              <div class="ts-review-mini__header">
                <span class="ts-review-mini__author"><%= review.user.nickname %></span>
                <div class="ts-stars-sm">
                  <% 5.times do |i| %>
                    <svg viewBox="0 0 24 24" fill="<%= i < review.rating ? '#f5c500' : 'none' %>" stroke="<%= i < review.rating ? '#f5c500' : '#333' %>" stroke-width="2">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  <% end %>
                </div>
              </div>
              <p class="ts-review-mini__text"><%= review.comment&.truncate(70) %></p>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<%# ── Lightbox ── %>
<div id="lightbox" onclick="if(event.target===this) closeLightbox()" class="ts-lightbox">
  <button onclick="shiftLightbox(-1)" class="ts-lightbox__nav ts-lightbox__prev">&#8249;</button>
  <button onclick="shiftLightbox(1)"  class="ts-lightbox__nav ts-lightbox__next">&#8250;</button>
  <button onclick="closeLightbox()"   class="ts-lightbox__close">✕</button>
  <img id="lightbox-img" class="ts-lightbox__img" src="" alt="">
  <div id="lightbox-caption" class="ts-lightbox__caption"></div>
</div>

<script>
  if (!window._tatoueurShowInitialized) {
  window._tatoueurShowInitialized = true
  const allTabs = ["portfolio", "disponibilites", "evenements", "avis"]

  function showTab(key) {
    allTabs.forEach(t => {
      const content = document.getElementById(`tab-${t}`)
      const btn     = document.getElementById(`tab-btn-${t}`)
      if (!content || !btn) return
      const active = t === key
      content.style.display = active ? "block" : "none"
      btn.classList.toggle("ts-tab--active", active)
    })
  }

  function toggleUploadForm() {
    const f = document.getElementById("upload-form")
    if (f) f.style.display = f.style.display === "none" ? "block" : "none"
  }

  let allImgs = [], currentIdx = 0
  function buildIndex() { allImgs = Array.from(document.querySelectorAll("[data-lightbox]")) }
  function openLightbox(el) {
    buildIndex(); currentIdx = allImgs.indexOf(el); showAt(currentIdx)
    document.getElementById("lightbox").classList.add("open")
    document.body.style.overflow = "hidden"
  }
  function showAt(idx) {
    const el = allImgs[idx]
    document.getElementById("lightbox-img").src             = el.dataset.src
    document.getElementById("lightbox-caption").textContent = el.dataset.caption || ""
  }
  function shiftLightbox(dir) { currentIdx = (currentIdx + dir + allImgs.length) % allImgs.length; showAt(currentIdx) }
  function closeLightbox() {
    document.getElementById("lightbox").classList.remove("open")
    document.getElementById("lightbox-img").src = ""
    document.body.style.overflow = ""
  }
  document.addEventListener("keydown", e => {
    const lb = document.getElementById("lightbox")
    if (!lb || !lb.classList.contains("open")) return
    if (e.key === "Escape")     closeLightbox()
    if (e.key === "ArrowRight") shiftLightbox(1)
    if (e.key === "ArrowLeft")  shiftLightbox(-1)
  })

  function filterGallery(styleId) {
    document.querySelectorAll(".gallery-pub-item").forEach(el => {
      el.style.display = (!styleId || el.dataset.style == styleId) ? "" : "none"
    })
    document.querySelectorAll(".ts-gallery-filter").forEach(btn => {
      btn.classList.toggle("ts-gallery-filter--active",
        (!styleId && btn.dataset.style === "") || btn.dataset.style == styleId)
    })
  }
  }
</script>