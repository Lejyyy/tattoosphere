<% content_for :title, @tatoueur.nickname %>

<%# ================================ %>
<%# HERO %>
<%# ================================ %>
<% bg_style = if @tatoueur.cover.attached?
    "background-image:url('#{url_for(@tatoueur.cover)}');background-size:cover;background-position:center;"
  elsif @tatoueur.cover_color.present?
    "background-color:#{@tatoueur.cover_color};"
  else
    "background:linear-gradient(135deg,#1A1A1A 0%,#0D0D0D 100%);"
  end %>

<section style="position:relative;min-height:480px;display:flex;align-items:flex-end;overflow:hidden;">

  <div style="position:absolute;top:0;left:0;right:0;bottom:0;<%= bg_style %>"></div>
  <div style="position:absolute;top:0;left:0;right:0;bottom:0;
              background:linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(13,13,13,0.98) 100%);"></div>

  <div class="container position-relative py-5">
    <div class="row align-items-end g-4">

      <%# Avatar %>
      <div class="col-auto">
        <% if @tatoueur.avatar.attached? %>
          <%= image_tag @tatoueur.avatar,
              style: "width:130px;height:130px;object-fit:cover;
                      border:3px solid #F5C500;box-shadow:0 4px 24px rgba(0,0,0,0.6);" %>
        <% else %>
          <div style="width:130px;height:130px;background:#1A1A1A;border:3px solid #2A2A2A;
                      display:flex;align-items:center;justify-content:center;font-size:3rem;
                      box-shadow:0 4px 24px rgba(0,0,0,0.6);">🖋️</div>
        <% end %>
      </div>

      <%# Infos %>
      <div class="col">
        <div class="d-flex align-items-center gap-3 flex-wrap mb-1">
          <h1 style="font-family:'Bebas Neue',sans-serif;font-size:3.5rem;letter-spacing:0.04em;
                     text-shadow:0 2px 12px rgba(0,0,0,0.8);margin-bottom:0;">
            <%= @tatoueur.nickname %>
          </h1>
          <%= render "verified_badge", tatoueur: @tatoueur %>
        </div>

        <%# Méta %>
        <div class="d-flex flex-wrap gap-3 mb-3" style="color:#bbb;font-size:0.9rem;">
          <% if @tatoueur.address.present? %>
            <span>📍 <%= @tatoueur.address %></span>
          <% elsif @tatoueur.shops.any? %>
            <span>📍 <%= @tatoueur.shops.first.address %></span>
          <% else %>
            <span style="color:#555;">📍 Localisation non renseignée</span>
          <% end %>
          <% if @tatoueur.shops.any? %>
            <span>
              🏠
              <% @tatoueur.shops.each do |shop| %>
                <%= link_to shop.name, shop_path(shop),
                    style: "color:#F5C500;font-weight:700;text-decoration:none;" %>
              <% end %>
            </span>
          <% else %>
            <span style="color:#555;">🏠 Indépendant</span>
          <% end %>
        </div>

        <%# Stats %>
        <div class="d-flex gap-4 mb-4">
          <div class="text-center">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:#F5C500;line-height:1;">
              <%= @tatoueur.portfolio_items.count %>
            </div>
            <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#888;">
              Réalisations
            </div>
          </div>
          <div style="width:1px;background:#2A2A2A;margin:0.2rem 0;"></div>
          <div class="text-center">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:#F5C500;line-height:1;">
              <%= @reviews.count %>
            </div>
            <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#888;">
              Avis
            </div>
          </div>
          <% if @reviews.any? %>
            <div style="width:1px;background:#2A2A2A;margin:0.2rem 0;"></div>
            <div class="text-center">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:2.2rem;color:#F5C500;line-height:1;">
                <%= number_with_precision(@reviews.average(:rating), precision: 1) %>
              </div>
              <div style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;color:#888;">
                Note / 5
              </div>
            </div>
          <% end %>
        </div>

        <%# Styles %>
        <div class="d-flex flex-wrap gap-2 mb-3">
          <% @tatoueur.tattoo_styles.each do |style| %>
            <span class="card-badge"><%= style.name %></span>
          <% end %>
        </div>

        <%# Actions %>
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <% if user_signed_in? %>
            <% unless current_user.tatoueur == @tatoueur %>
              <%= link_to "✉️ Contacter",
                  conversations_path(tatoueur_id: @tatoueur.id),
                  data: { turbo_method: :post },
                  class: "hero-cta" %>
              <% if @tatoueur.shops.any? %>
                <%= link_to "📅 Réserver",
                    new_shop_booking_path(@tatoueur.shops.first),
                    class: "hero-cta-outline" %>
              <% else %>
                <span class="hero-cta disabled">Réservation indisponible</span>
              <% end %>
            <% end %>
          <% else %>
            <%= link_to "Connectez-vous pour contacter", new_user_session_path, class: "hero-cta" %>
          <% end %>

          <% unless current_user&.tatoueur == @tatoueur %>
            <%= render "favorites/button", favoritable: @tatoueur %>
          <% end %>

          <% if user_signed_in? && policy(@tatoueur).update? %>
            <%= link_to "✏️ Modifier", edit_tatoueur_path(@tatoueur), class: "btn btn-outline-primary btn-sm" %>
          <% end %>
          <% if current_user&.tatoueur == @tatoueur && !@tatoueur.verified? %>
            <%= link_to "Faire vérifier mon profil", verification_tatoueur_path(@tatoueur),
                class: "btn btn-outline-warning btn-sm" %>
          <% end %>
          <% if current_user&.tatoueur == @tatoueur %>
            <% if @tatoueur.paypal_onboarded? %>
              <span class="badge bg-success">✅ PayPal connecté</span>
            <% else %>
              <%= link_to "Connecter PayPal", connect_paypal_tatoueur_path(@tatoueur),
                  class: "btn btn-warning btn-sm" %>
            <% end %>
          <% end %>
        </div>

        <% if @tatoueur.description.present? %>
          <div class="mt-4 pt-4" style="border-top:1px solid rgba(255,255,255,0.08);">
            <p style="max-width:700px;line-height:1.8;color:#bbb;">
              <%= @tatoueur.description %>
            </p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</section>

<%# Éditeur de fond %>
<% if user_signed_in? && current_user.tatoueur == @tatoueur %>
  <%= render "shared/cover_editor",
      record:      @tatoueur,
      update_path: tatoueur_path(@tatoueur),
      param_name:  "tatoueur" %>
<% end %>

<hr style="border-color:#2A2A2A;margin:0;">

<%# ================================ %>
<%# TABS %>
<%# ================================ %>
<div class="container">

  <div style="display:flex;border-bottom:1px solid #2A2A2A;margin-bottom:2rem;">
    <% tabs = [] %>
    <% tabs << { key: "portfolio", label: "Portfolio", count: @tatoueur.portfolio_items.count } if @portfolios.any? || @tatoueur.photos.attached? %>
    <% tabs << { key: "disponibilites", label: "Disponibilités", count: nil } %>
    <% tabs << { key: "evenements", label: "Événements", count: @events.count } if @events.any? %>
    <% tabs << { key: "avis", label: "Avis", count: @reviews.count } %>

    <% tabs.each_with_index do |tab, i| %>
      <button onclick="showTab('<%= tab[:key] %>')"
              id="tab-btn-<%= tab[:key] %>"
              style="background:transparent;border:none;
                     color:<%= i == 0 ? '#F5C500' : '#888' %>;
                     font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:0.05em;
                     padding:1rem 1.5rem;cursor:pointer;
                     border-bottom:<%= i == 0 ? '2px solid #F5C500' : '2px solid transparent' %>;
                     margin-bottom:-1px;transition:all 0.2s;">
        <%= tab[:label] %>
        <% if tab[:count].present? && tab[:count] > 0 %>
          <span style="font-size:0.8rem;color:#555;margin-left:0.25rem;">(<%= tab[:count] %>)</span>
        <% end %>
      </button>
    <% end %>
  </div>

  <%# ======= TAB PORTFOLIO ======= %>
  <% if @portfolios.any? || @tatoueur.photos.attached? %>
    <div id="tab-portfolio" class="tab-content">

      <%# ── Portfolios ── %>
      <% if @portfolios.any? %>
        <h2 class="section-title mb-4">Portfolios</h2>
        <div class="row g-4 mb-5">
          <% @portfolios.each do |portfolio| %>
            <div class="col-md-4">
              <%= link_to tatoueur_portfolio_path(@tatoueur, portfolio), style: "text-decoration:none;" do %>
                <div style="background:#1A1A1A;border:1px solid #2A2A2A;
                            overflow:hidden;transition:border-color 0.2s;"
                     onmouseover="this.style.borderColor='#F5C500'"
                     onmouseout="this.style.borderColor='#2A2A2A'">
                  <% first_item = portfolio.portfolio_items.first %>
                  <% if first_item&.images&.attached? %>
                    <div style="overflow:hidden;">
                      <%= image_tag first_item.images.first,
                          style: "width:100%;height:220px;object-fit:cover;
                                  transition:transform 0.3s;display:block;",
                          onmouseover: "this.style.transform='scale(1.05)'",
                          onmouseout:  "this.style.transform='scale(1)'" %>
                    </div>
                  <% else %>
                    <div style="width:100%;height:220px;background:#111;
                                display:flex;align-items:center;justify-content:center;font-size:3rem;">🖼️</div>
                  <% end %>
                  <div style="padding:1rem;">
                    <div style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#fff;">
                      <%= portfolio.name %>
                    </div>
                    <div style="color:#555;font-size:0.85rem;">
                      <%= portfolio.portfolio_items.count %> réalisation(s)
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ── Réalisations libres ── %>
      <% if @tatoueur.photos.attached? || (user_signed_in? && current_user.tatoueur == @tatoueur) %>
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="section-title mb-0">Réalisations</h2>
          <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
            <button onclick="toggleUploadForm()"
                    style="background:transparent;border:1px solid #F5C500;color:#F5C500;
                           font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:0.05em;
                           padding:0.4rem 1rem;cursor:pointer;">
              ➕ Ajouter des photos
            </button>
          <% end %>
        </div>

        <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
          <div id="upload-form"
               style="display:none;background:#1A1A1A;border:1px solid #2A2A2A;
                      border-top:3px solid #F5C500;padding:1.5rem;margin-bottom:2rem;">
            <%= form_with url: update_photos_tatoueur_path(@tatoueur),
                          method: :patch,
                          html: { enctype: "multipart/form-data" } do |f| %>
              <p style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;
                        color:#888;margin-bottom:0.75rem;">
                Sélectionne une ou plusieurs photos
              </p>
              <%= f.file_field :photos, multiple: true, accept: "image/*",
                  style: "color:#fff;font-family:'Barlow Condensed',sans-serif;
                          width:100%;margin-bottom:1rem;" %>
              <%= f.submit "Uploader",
                  style: "background:#F5C500;color:#000;border:none;
                          font-family:'Bebas Neue',sans-serif;font-size:1.1rem;
                          letter-spacing:0.08em;padding:0.6rem 2rem;cursor:pointer;",
                  onmouseover: "this.style.background='#d4a800'",
                  onmouseout:  "this.style.background='#F5C500'" %>
            <% end %>
          </div>
        <% end %>

        <% if @tatoueur.photos.attached? %>
          <div class="row row-cols-1 row-cols-md-3 g-3">
            <% @tatoueur.photos.each_with_index do |photo, idx| %>
              <div class="col">
                <div style="position:relative;overflow:hidden;"
                     onmouseover="this.querySelector('.del-btn') && (this.querySelector('.del-btn').style.opacity='1')"
                     onmouseout="this.querySelector('.del-btn') && (this.querySelector('.del-btn').style.opacity='0')">
                  <%= image_tag photo,
                      style: "width:100%;height:280px;object-fit:cover;border:1px solid #2A2A2A;
                              cursor:zoom-in;transition:transform 0.3s,border-color 0.2s;display:block;",
                      data: { lightbox: true, src: url_for(photo), caption: "Réalisation #{idx + 1}" },
                      onclick: "openLightbox(this)",
                      onmouseover: "this.style.transform='scale(1.03)';this.style.borderColor='#F5C500'",
                      onmouseout:  "this.style.transform='scale(1)';this.style.borderColor='#2A2A2A'" %>
                  <% if user_signed_in? && current_user.tatoueur == @tatoueur %>
                    <%= link_to "✕",
                        delete_photo_tatoueur_path(@tatoueur, photo_id: photo.id),
                        data: { turbo_method: :delete, turbo_confirm: "Supprimer cette photo ?" },
                        class: "del-btn",
                        style: "position:absolute;top:0.5rem;right:0.5rem;background:rgba(0,0,0,0.75);
                                color:#fff;width:28px;height:28px;display:flex;align-items:center;
                                justify-content:center;font-size:0.8rem;text-decoration:none;
                                cursor:pointer;opacity:0;transition:opacity 0.2s;" %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p style="color:#555;">Aucune réalisation pour le moment.</p>
        <% end %>
      <% end %>

    </div>
  <% end %>

  <%# ======= TAB DISPONIBILITÉS ======= %>
  <div id="tab-disponibilites" class="tab-content" style="display:none;">
    <h2 class="section-title mb-4">Disponibilités</h2>
    <%= render "tatoueurs/calendar", tatoueur: @tatoueur %>
  </div>

  <%# ======= TAB ÉVÉNEMENTS ======= %>
  <% if @events.any? %>
    <div id="tab-evenements" class="tab-content" style="display:none;">
      <h2 class="section-title mb-4">Événements à venir</h2>
      <% @events.each do |event| %>
        <div class="event-item">
          <div class="event-date"><%= event.start_date&.strftime("%d %B %Y") %></div>
          <div class="event-name"><%= event.name %></div>
          <div class="event-location">📍 <%= event.location %></div>
          <% if event.description.present? %>
            <p style="color:#888;margin-top:0.5rem;margin-bottom:0;font-size:0.9rem;">
              <%= event.description.truncate(120) %>
            </p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ======= TAB AVIS ======= %>
  <div id="tab-avis" class="tab-content" style="display:none;">
    <% if @reviews.any? %>
      <div class="d-flex align-items-center gap-3 mb-4">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:3rem;color:#F5C500;line-height:1;">
          <%= number_with_precision(@reviews.average(:rating), precision: 1) %>
        </div>
        <div>
          <div style="display:flex;gap:0.2rem;margin-bottom:0.25rem;">
            <% avg = @reviews.average(:rating).to_f %>
            <% 5.times do |i| %>
              <svg width="18" height="18" viewBox="0 0 24 24"
                   fill="<%= i < avg.floor ? '#F5C500' : (i < avg ? 'url(#half)' : 'none') %>"
                   stroke="#F5C500" stroke-width="2">
                <defs>
                  <linearGradient id="half">
                    <stop offset="50%" stop-color="#F5C500"/>
                    <stop offset="50%" stop-color="transparent"/>
                  </linearGradient>
                </defs>
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            <% end %>
          </div>
          <div style="color:#888;font-size:0.85rem;"><%= @reviews.count %> avis</div>
        </div>
      </div>

      <div class="row g-4">
        <% @reviews.each do |review| %>
          <div class="col-md-6">
            <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <span style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;">
                    <%= review.user.nickname %>
                  </span>
                  <div style="display:flex;gap:0.15rem;margin-top:0.25rem;">
                    <% 5.times do |i| %>
                      <svg width="14" height="14" viewBox="0 0 24 24"
                           fill="<%= i < review.rating ? '#F5C500' : 'none' %>"
                           stroke="<%= i < review.rating ? '#F5C500' : '#444' %>"
                           stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    <% end %>
                  </div>
                </div>
                <span style="color:#555;font-size:0.8rem;">
                  <%= review.created_at.strftime("%d/%m/%Y") %>
                </span>
              </div>
              <p style="color:#888;margin-bottom:0;line-height:1.6;"><%= review.comment %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color:#555;">Aucun avis pour le moment.</p>
    <% end %>
  </div>

</div>

<script>
  const allTabs = ["portfolio", "disponibilites", "evenements", "avis"]

  function showTab(key) {
    allTabs.forEach(t => {
      const content = document.getElementById(`tab-${t}`)
      const btn     = document.getElementById(`tab-btn-${t}`)
      if (!content || !btn) return
      if (t === key) {
        content.style.display = "block"
        btn.style.color        = "#F5C500"
        btn.style.borderBottom = "2px solid #F5C500"
      } else {
        content.style.display = "none"
        btn.style.color        = "#888"
        btn.style.borderBottom = "2px solid transparent"
      }
    })
  }

  function toggleUploadForm() {
    const f = document.getElementById('upload-form')
    if (f) f.style.display = f.style.display === 'none' ? 'block' : 'none'
  }

  let allImgs    = []
  let currentIdx = 0

  function buildIndex() {
    allImgs = Array.from(document.querySelectorAll('[data-lightbox]'))
  }

  function openLightbox(el) {
    buildIndex()
    currentIdx = allImgs.indexOf(el)
    showAt(currentIdx)
    document.getElementById('lightbox').style.display = 'flex'
    document.body.style.overflow = 'hidden'
  }

  function showAt(idx) {
    const el = allImgs[idx]
    document.getElementById('lightbox-img').src            = el.dataset.src
    document.getElementById('lightbox-caption').textContent = el.dataset.caption || ''
  }

  function shiftLightbox(dir) {
    currentIdx = (currentIdx + dir + allImgs.length) % allImgs.length
    showAt(currentIdx)
  }

  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none'
    document.getElementById('lightbox-img').src       = ''
    document.body.style.overflow = ''
  }

  document.addEventListener('keydown', (e) => {
    const lb = document.getElementById('lightbox')
    if (!lb || lb.style.display === 'none') return
    if (e.key === 'Escape')     closeLightbox()
    if (e.key === 'ArrowRight') shiftLightbox(1)
    if (e.key === 'ArrowLeft')  shiftLightbox(-1)
  })
</script>

<div id="lightbox"
     onclick="if(event.target===this) closeLightbox()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.93);
            z-index:9999;align-items:center;justify-content:center;">
  <button onclick="shiftLightbox(-1)"
          style="position:fixed;left:1.5rem;top:50%;transform:translateY(-50%);
                 background:none;border:none;color:#fff;font-size:2.5rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">&#8249;</button>
  <button onclick="shiftLightbox(1)"
          style="position:fixed;right:1.5rem;top:50%;transform:translateY(-50%);
                 background:none;border:none;color:#fff;font-size:2.5rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">&#8250;</button>
  <button onclick="closeLightbox()"
          style="position:fixed;top:1.25rem;right:1.5rem;background:none;border:none;
                 color:#fff;font-size:1.75rem;cursor:pointer;opacity:0.6;"
          onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">✕</button>
  <img id="lightbox-img"
       style="max-width:90vw;max-height:90vh;object-fit:contain;
              box-shadow:0 0 60px rgba(0,0,0,0.8);" src="" alt="">
  <div id="lightbox-caption"
       style="position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);
              color:#666;font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;
              letter-spacing:0.05em;white-space:nowrap;"></div>
</div>