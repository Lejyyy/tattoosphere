<% content_for :title, "Demande de vérification" %>

<div class="container py-5" style="max-width:720px;">

  <%# En-tête %>
  <div class="mb-5">
    <%= link_to "← Retour", tatoueur_path(@tatoueur),
        style: "font-size:0.8rem;font-weight:700;text-transform:uppercase;
                letter-spacing:0.08em;color:#888;text-decoration:none;" %>
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:3rem;
               letter-spacing:0.05em;margin-top:1rem;margin-bottom:0.25rem;">
      Demande de <span style="color:#F5C500;">vérification</span>
    </h1>
    <p style="color:#888;font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;">
      Obtiens le badge ✅ Vérifié et augmente ta crédibilité auprès des clients.
    </p>
  </div>

  <%# Statut actuel %>
  <% if @tatoueur.pending_verification? %>
    <div style="background:rgba(230,126,34,0.1);border:1px solid #E67E22;
                padding:1.25rem;margin-bottom:2rem;display:flex;gap:1rem;align-items:flex-start;">
      <span style="font-size:1.5rem;">⏳</span>
      <div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#E67E22;
                    letter-spacing:0.05em;">Dossier en cours d'examen</div>
        <p style="color:#888;font-size:0.9rem;margin:0.25rem 0 0;">
          Nous avons bien reçu ta demande. Tu recevras un email dès qu'une décision sera prise.
        </p>
      </div>
    </div>
  <% elsif @tatoueur.verification_status == "rejected" %>
    <div style="background:rgba(231,76,60,0.1);border:1px solid #E74C3C;
                padding:1.25rem;margin-bottom:2rem;display:flex;gap:1rem;align-items:flex-start;">
      <span style="font-size:1.5rem;">❌</span>
      <div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#E74C3C;
                    letter-spacing:0.05em;">Demande refusée</div>
        <% if @tatoueur.verification_rejected_reason.present? %>
          <p style="color:#E74C3C;font-size:0.9rem;margin:0.25rem 0 0.5rem;">
            <%= @tatoueur.verification_rejected_reason %>
          </p>
        <% end %>
        <p style="color:#888;font-size:0.85rem;margin:0;">
          Corrige les éléments mentionnés et soumet à nouveau ton dossier.
        </p>
      </div>
    </div>
  <% end %>

  <%# Checklist progression %>
  <% checks = [
    [@tatoueur.first_name.present? && @tatoueur.last_name.present?, "Nom & Prénom"],
    [@tatoueur.siren.present?, "Numéro SIREN"],
    [@tatoueur.identity_document.attached?, "Pièce d'identité"],
    [@tatoueur.hygiene_certificate.attached?, "Certification hygiène"],
    [@tatoueur.bank_details_complete?, "Coordonnées bancaires"],
  ] %>
  <% done = checks.count { |ok, _| ok } %>

  <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;margin-bottom:2rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
      <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin:0;">
        Statut du dossier
      </h3>
      <span style="font-family:'Bebas Neue',sans-serif;font-size:1rem;
                   color:<%= done == checks.size ? '#27AE60' : '#E67E22' %>;">
        <%= done %>/<%= checks.size %> complété<%= done > 1 ? "s" : "" %>
      </span>
    </div>

    <%# Barre de progression %>
    <div style="background:#0D0D0D;height:6px;border-radius:3px;margin-bottom:1.25rem;">
      <div style="background:<%= done == checks.size ? '#27AE60' : '#F5C500' %>;
                  height:6px;border-radius:3px;width:<%= (done.to_f / checks.size * 100).round %>%;
                  transition:width 0.3s;"></div>
    </div>

    <div style="display:flex;flex-direction:column;gap:0.5rem;">
      <% checks.each do |ok, label| %>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <div style="width:20px;height:20px;border-radius:50%;flex-shrink:0;
                      background:<%= ok ? '#27AE60' : '#2A2A2A' %>;
                      display:flex;align-items:center;justify-content:center;font-size:0.7rem;">
            <%= ok ? "✓" : "" %>
          </div>
          <span style="font-size:0.9rem;color:<%= ok ? '#bbb' : '#555' %>;">
            <%= label %>
          </span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Formulaire %>
  <%= form_with url: submit_verification_tatoueur_path(@tatoueur),
                method: :post,
                html: { enctype: "multipart/form-data" } do |f| %>

    <%# ── Identité civile ── %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;border-top:3px solid #F5C500;
                padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Identité civile
      </h2>

      <div class="row g-3">
        <div class="col-md-6">
          <label style="<%= label_style %>">Prénom <span style="color:#E74C3C;">*</span></label>
          <%= f.text_field :first_name, value: @tatoueur.first_name,
              placeholder: "Jean",
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <label style="<%= label_style %>">Nom <span style="color:#E74C3C;">*</span></label>
          <%= f.text_field :last_name, value: @tatoueur.last_name,
              placeholder: "Dupont",
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <label style="<%= label_style %>">Numéro SIREN <span style="color:#E74C3C;">*</span></label>
          <%= f.text_field :siren, value: @tatoueur.siren,
              placeholder: "123456789", maxlength: 9,
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
          <p style="font-size:0.75rem;color:#555;margin-top:0.3rem;">9 chiffres, sans espaces</p>
        </div>
      </div>
    </div>

    <%# ── Documents ── %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Documents
      </h2>

      <%# Pièce d'identité %>
      <div class="mb-4">
        <label style="<%= label_style %>">
          Pièce d'identité (recto) <span style="color:#E74C3C;">*</span>
        </label>
        <% if @tatoueur.identity_document.attached? %>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;
                      background:#0D0D0D;border:1px solid #27AE60;padding:0.6rem 1rem;">
            <span style="color:#27AE60;font-size:0.8rem;">✓ Document fourni</span>
            <%= link_to "Voir →", url_for(@tatoueur.identity_document), target: "_blank",
                style: "color:#F5C500;font-size:0.8rem;text-decoration:none;margin-left:auto;" %>
          </div>
        <% end %>
        <%= f.file_field :identity_document,
            accept: "image/png,image/jpeg,image/webp,application/pdf",
            style: "color:#888;font-family:'Barlow Condensed',sans-serif;
                    font-size:0.9rem;width:100%;margin-bottom:0.25rem;" %>
        <p style="font-size:0.75rem;color:#555;margin:0;">PNG, JPG, WEBP ou PDF · Max 5 Mo</p>
      </div>

      <%# Photo avec pièce d'identité %>
      <div class="mb-4">
        <label style="<%= label_style %>">
          Photo de toi tenant ta pièce d'identité <span style="color:#E74C3C;">*</span>
        </label>
        <div style="background:#0D0D0D;border:1px solid #2A2A2A;padding:1rem;
                    margin-bottom:0.75rem;">
          <p style="color:#888;font-size:0.85rem;margin:0;line-height:1.6;">
            📸 Prends une photo de toi en tenant ta pièce d'identité ouverte, bien lisible,
            à côté de ton visage. Les deux doivent être visibles sur la même photo.
          </p>
        </div>
        <%= f.file_field :identity_selfie,
            accept: "image/png,image/jpeg,image/webp",
            style: "color:#888;font-family:'Barlow Condensed',sans-serif;
                    font-size:0.9rem;width:100%;margin-bottom:0.25rem;" %>
        <p style="font-size:0.75rem;color:#555;margin:0;">PNG, JPG ou WEBP · Max 5 Mo</p>
      </div>

      <%# Certification hygiène %>
      <div>
        <label style="<%= label_style %>">
          Certification hygiène & sécurité <span style="color:#E74C3C;">*</span>
        </label>
        <% if @tatoueur.hygiene_certificate.attached? %>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;
                      background:#0D0D0D;border:1px solid #27AE60;padding:0.6rem 1rem;">
            <span style="color:#27AE60;font-size:0.8rem;">✓ Document fourni</span>
            <%= link_to "Voir →", url_for(@tatoueur.hygiene_certificate), target: "_blank",
                style: "color:#F5C500;font-size:0.8rem;text-decoration:none;margin-left:auto;" %>
          </div>
        <% end %>
        <%= f.file_field :hygiene_certificate,
            accept: "image/png,image/jpeg,image/webp,application/pdf",
            style: "color:#888;font-family:'Barlow Condensed',sans-serif;
                    font-size:0.9rem;width:100%;margin-bottom:0.25rem;" %>
        <p style="font-size:0.75rem;color:#555;margin:0;">PNG, JPG, WEBP ou PDF · Max 5 Mo</p>
      </div>
    </div>

    <%# ── Coordonnées bancaires ── %>
    <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:2rem;margin-bottom:1.5rem;">
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#F5C500;
                 border-left:4px solid #F5C500;padding-left:0.75rem;margin-bottom:1.5rem;">
        Coordonnées bancaires
      </h2>
      <p style="color:#555;font-size:0.85rem;margin-bottom:1.25rem;">
        Nécessaires pour recevoir les acomptes des réservations.
      </p>

      <div class="row g-3">
        <div class="col-12">
          <label style="<%= label_style %>">IBAN <span style="color:#E74C3C;">*</span></label>
          <%= f.text_field :iban, value: @tatoueur.iban,
              placeholder: "FR76 XXXX XXXX XXXX XXXX XXXX XXX",
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <label style="<%= label_style %>">BIC <span style="color:#E74C3C;">*</span></label>
          <%= f.text_field :bic, value: @tatoueur.bic,
              placeholder: "BNPAFRPP",
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
        <div class="col-md-6">
          <label style="<%= label_style %>">Banque</label>
          <%= f.text_field :bank_name, value: @tatoueur.bank_name,
              placeholder: "BNP Paribas",
              style: input_style,
              onfocus: "this.style.borderColor='#F5C500'",
              onblur:  "this.style.borderColor='#2A2A2A'" %>
        </div>
      </div>
    </div>

    <%# Engagement %>
    <div style="background:rgba(245,197,0,0.06);border:1px solid rgba(245,197,0,0.2);
                padding:1rem 1.25rem;margin-bottom:1.5rem;">
      <label style="display:flex;align-items:flex-start;gap:0.75rem;cursor:pointer;">
        <input type="checkbox" id="confirm-check" required
               style="width:18px;height:18px;accent-color:#F5C500;flex-shrink:0;margin-top:0.1rem;">
        <span style="font-size:0.85rem;color:#888;line-height:1.6;">
          Je certifie que les informations et documents fournis sont authentiques et exacts.
          Je comprends que toute fausse déclaration entraînera la suppression de mon compte.
        </span>
      </label>
    </div>

    <%= f.submit "Soumettre mon dossier de vérification",
        style: "width:100%;background:#F5C500;color:#000;border:none;
                font-family:'Bebas Neue',sans-serif;font-size:1.2rem;
                letter-spacing:0.1em;padding:1rem;cursor:pointer;",
        onmouseover: "this.style.background='#d4a800'",
        onmouseout:  "this.style.background='#F5C500'",
        data: { turbo_confirm: "Confirmes-tu la soumission de ton dossier ?" } %>

  <% end %>
</div>

<%# Helpers inline pour éviter la répétition %>
<% label_style = "display:block;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.4rem;" %>
<% input_style = "width:100%;background:#0D0D0D;border:1px solid #2A2A2A;color:#fff;padding:0.85rem 1rem;font-family:'Barlow Condensed',sans-serif;font-size:1rem;outline:none;" %>