<div class="container py-5" style="max-width: 700px;">

  <div class="d-flex align-items-center gap-3 mb-4">
    <%= link_to "← Retour", tatoueur_path(@tatoueur), class: "btn btn-outline-secondary btn-sm" %>
    <h1 class="h4 mb-0">Demande de vérification</h1>
  </div>

  <%# STATUT ACTUEL %>
  <% if @tatoueur.pending_verification? %>
    <div class="alert alert-warning">
      Votre demande est en cours d'examen. Vous recevrez un email dès qu'une décision sera prise.
    </div>
  <% elsif @tatoueur.verification_status == "rejected" %>
    <div class="alert alert-danger">
      <strong>Demande rejetée.</strong>
      <% if @tatoueur.verification_rejected_reason.present? %>
        <br><%= @tatoueur.verification_rejected_reason %>
      <% end %>
      <br><small>Vous pouvez soumettre une nouvelle demande après correction.</small>
    </div>
  <% end %>

  <%# EXPLICATIONS %>
  <div class="card border-secondary mb-4">
    <div class="card-body">
      <h2 class="h6 text-warning mb-3">Pourquoi se faire vérifier ?</h2>
      <p class="text-secondary small mb-2">Le badge "Vérifié" rassure vos clients et augmente votre taux de réservation. Pour l'obtenir, nous avons besoin de :</p>
      <ul class="text-secondary small mb-0">
        <li>Une pièce d'identité valide (carte d'identité ou passeport)</li>
        <li>Votre certification hygiène et sécurité</li>
        <li>Votre numéro SIREN</li>
        <li>Vos coordonnées bancaires (IBAN + BIC)</li>
      </ul>
    </div>
  </div>

  <%# FORMULAIRE %>
  <%= form_with url: submit_verification_tatoueur_path(@tatoueur),
                method: :post,
                multipart: true do |f| %>

    <%# Pièce d'identité %>
    <div class="mb-4">
      <label class="form-label fw-semibold">Pièce d'identité <span class="text-danger">*</span></label>
      <% if @tatoueur.identity_document.attached? %>
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge bg-success">Fournie</span>
          <%= link_to "Voir", url_for(@tatoueur.identity_document), target: "_blank", class: "text-secondary small" %>
        </div>
      <% end %>
      <%= f.file_field :identity_document,
          class: "form-control",
          accept: "image/png,image/jpeg,application/pdf" %>
      <div class="form-text text-secondary">PNG, JPG ou PDF — max 5 Mo</div>
    </div>

    <%# Certification hygiène %>
    <div class="mb-4">
      <label class="form-label fw-semibold">Certification hygiène & sécurité <span class="text-danger">*</span></label>
      <% if @tatoueur.hygiene_certificate.attached? %>
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge bg-success">Fournie</span>
          <%= link_to "Voir", url_for(@tatoueur.hygiene_certificate), target: "_blank", class: "text-secondary small" %>
        </div>
      <% end %>
      <%= f.file_field :hygiene_certificate,
          class: "form-control",
          accept: "image/png,image/jpeg,application/pdf" %>
      <div class="form-text text-secondary">PNG, JPG ou PDF — max 5 Mo</div>
    </div>

    <%# SIREN %>
    <div class="mb-4">
      <label class="form-label fw-semibold">Numéro SIREN <span class="text-danger">*</span></label>
      <%= f.text_field :siren,
          value: @tatoueur.siren,
          placeholder: "123456789",
          class: "form-control",
          maxlength: 9 %>
      <div class="form-text text-secondary">9 chiffres, sans espaces</div>
    </div>

    <%# Coordonnées bancaires %>
    <div class="mb-4">
      <label class="form-label fw-semibold">Coordonnées bancaires <span class="text-danger">*</span></label>
      <div class="row g-2">
        <div class="col-md-6">
          <%= f.text_field :iban,
              value: @tatoueur.iban,
              placeholder: "FR76...",
              class: "form-control" %>
          <div class="form-text text-secondary">IBAN</div>
        </div>
        <div class="col-md-3">
          <%= f.text_field :bic,
              value: @tatoueur.bic,
              placeholder: "BNPAFRPP",
              class: "form-control" %>
          <div class="form-text text-secondary">BIC</div>
        </div>
        <div class="col-md-3">
          <%= f.text_field :bank_name,
              value: @tatoueur.bank_name,
              placeholder: "BNP Paribas",
              class: "form-control" %>
          <div class="form-text text-secondary">Banque</div>
        </div>
      </div>
    </div>

    <%# CHECKLIST %>
    <div class="card border-secondary mb-4">
      <div class="card-body">
        <h2 class="h6 text-secondary mb-3">Statut de votre dossier</h2>
        <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
          <li class="d-flex align-items-center gap-2">
            <span class="badge <%= @tatoueur.identity_document.attached? ? "bg-success" : "bg-secondary" %>">
              <%= @tatoueur.identity_document.attached? ? "OK" : "Manquant" %>
            </span>
            <span class="small text-secondary">Pièce d'identité</span>
          </li>
          <li class="d-flex align-items-center gap-2">
            <span class="badge <%= @tatoueur.hygiene_certificate.attached? ? "bg-success" : "bg-secondary" %>">
              <%= @tatoueur.hygiene_certificate.attached? ? "OK" : "Manquant" %>
            </span>
            <span class="small text-secondary">Certification hygiène</span>
          </li>
          <li class="d-flex align-items-center gap-2">
            <span class="badge <%= @tatoueur.siren.present? ? "bg-success" : "bg-secondary" %>">
              <%= @tatoueur.siren.present? ? "OK" : "Manquant" %>
            </span>
            <span class="small text-secondary">SIREN</span>
          </li>
          <li class="d-flex align-items-center gap-2">
            <span class="badge <%= @tatoueur.bank_details_complete? ? "bg-success" : "bg-secondary" %>">
              <%= @tatoueur.bank_details_complete? ? "OK" : "Manquant" %>
            </span>
            <span class="small text-secondary">Coordonnées bancaires</span>
          </li>
        </ul>
      </div>
    </div>

    <%= f.submit "Soumettre ma demande de vérification",
        class: "btn btn-warning w-100 fw-bold",
        data: { confirm: "Confirmez-vous la soumission de votre dossier ?" } %>
  <% end %>

</div>