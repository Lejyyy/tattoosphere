<div class="container py-5">

  <%# Header %>
  <div class="mb-5">
    <h1 class="section-title mb-2">Styles de tatouage</h1>
    <p class="text-secondary">Explore les différents styles et trouve l'artiste qui correspond à ta vision.</p>
  </div>

  <%# Grille des styles %>
  <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
    <% styles_data = {
      "Old School"    => { emoji: "⚓", desc: "Trait épais, couleurs vives, iconographie marine et vintage" },
      "Réalisme"      => { emoji: "🎨", desc: "Reproduction fidèle de photos, portraits et scènes réelles" },
      "Japonais"      => { emoji: "🐉", desc: "Dragons, carpes koï, cerisiers et vagues traditionnels" },
      "Géométrique"   => { emoji: "🔷", desc: "Formes précises, symétrie et mandalas contemporains" },
      "Dotwork"       => { emoji: "✦", desc: "Texture pointilliste, nuances subtiles et profondeur" },
      "Fine Line"     => { emoji: "🖊️", desc: "Traits fins et délicats, minimalisme élégant" },
      "Néo-trad"      => { emoji: "🌹", desc: "Modernisation du traditionnel avec plus de détails" },
      "Noir & Gris"   => { emoji: "🌑", desc: "Monochrome, ombrages subtils et profondeur visuelle" },
      "Aquarelle"     => { emoji: "🎭", desc: "Taches de couleur fluides imitant la peinture aquarelle" },
      "Tribal"        => { emoji: "🌀", desc: "Motifs ancestraux, pleins noirs et formes organiques" },
      "Biomécanique"  => { emoji: "⚙️", desc: "Fusion corps humain et mécanique, effet science-fiction" },
      "Lettering"     => { emoji: "✍️", desc: "Typographie artistique, citations et noms stylisés" },
    } %>

    <% @tattoo_styles.each_with_index do |style, i| %>
      <% data = styles_data[style.name] || { emoji: "🖋️", desc: "Style de tatouage unique et artistique" } %>
      <% count = Tatoueur.joins(:tattoo_styles).where(tattoo_styles: { id: style.id }, is_active: true).count %>
      <div class="col">
        <%= link_to tatoueurs_path(style_id: style.id), style: "text-decoration:none;" do %>
          <div style="background:#1A1A1A;border:1px solid #2A2A2A;padding:1.5rem;height:100%;transition:all 0.2s;position:relative;overflow:hidden;"
               onmouseover="this.style.borderColor='#F5C500';this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.4)'"
               onmouseout="this.style.borderColor='#2A2A2A';this.style.transform='translateY(0)';this.style.boxShadow='none'">

            <%# Numéro de fond %>
            <div style="position:absolute;top:-0.5rem;right:0.75rem;font-family:'Bebas Neue',sans-serif;font-size:4rem;color:rgba(245,197,0,0.05);line-height:1;user-select:none;">
              <%= (i + 1).to_s.rjust(2, "0") %>
            </div>

            <%# Emoji %>
            <div style="font-size:2rem;margin-bottom:0.75rem;"><%= data[:emoji] %></div>

            <%# Nom %>
            <div style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#fff;letter-spacing:0.05em;margin-bottom:0.5rem;">
              <%= style.name %>
            </div>

            <%# Description %>
            <p style="font-size:0.8rem;color:#666;line-height:1.5;margin-bottom:1rem;">
              <%= data[:desc] %>
            </p>

            <%# Compteur tatoueurs %>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:0.75rem;color:#555;text-transform:uppercase;letter-spacing:0.05em;">
                <%= count %> tatoueur<%= count > 1 ? "s" : "" %>
              </span>
              <span style="color:#F5C500;font-size:0.85rem;">→</span>
            </div>

          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# CTA bas de page %>
  <div style="margin-top:4rem;background:#1A1A1A;border:1px solid #2A2A2A;border-left:4px solid #F5C500;padding:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
    <div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:#fff;">Tu ne sais pas encore quel style choisir ?</div>
      <p class="text-secondary mb-0" style="font-size:0.9rem;">Parcours tous nos tatoueurs et laisse-toi inspirer par leurs réalisations.</p>
    </div>
    <%= link_to "Explorer tous les tatoueurs →", tatoueurs_path, class: "hero-cta" %>
  </div>

</div>